import { Palette } from "palette.slint";
import { ThreadItem } from "types.slint";

// Thread list column -- Phase 2 of chat-panel-ui-theme-parity.md will
// extend this with a real search box + filtered model and a footer
// identity chip, without touching app.slint or chat-area.slint.
export component Sidebar inherits Rectangle {
    in property <[ThreadItem]> threads: [];
    in property <int> selected-thread: 0;
    in property <bool> compact: true;
    callback thread-selected(int);
    callback new-thread-requested();
    callback search-changed(string);

    // Reserve enough width for the active chat at the native 20%-width
    // dock target. The list remains selectable; secondary chat metadata
    // collapses in ChatArea when the remaining column is compact.
    width: compact ? 104px : 180px;
    background: Palette.sys-sidebar;

    VerticalLayout {
        Rectangle {
            height: 36px;
            background: Palette.sys-card;
            HorizontalLayout {
                padding: 8px;
                spacing: 6px;
                Text {
                    text: "Chats";
                    color: Palette.sys-text-primary;
                    font-size: 14px;
                    font-family: Palette.font-sans;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; preferred-width: 0px; min-width: 0px; }
                Rectangle {
                    width: 24px;
                    height: 24px;
                    background: new-thread-touch.has-hover ? Palette.sys-primary-container : transparent;
                    border-radius: Palette.radius-sm;
                    new-thread-touch := TouchArea {
                        clicked => { new-thread-requested(); }
                    }
                    Text {
                        text: "+";
                        color: Palette.sys-primary;
                        font-family: Palette.font-sans;
                        font-size: 18px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                Text {
                    // Visual-only placeholder pending the dynamic
                    // thread-list gap (settings-gear real behavior),
                    // tracked separately -- unchanged from pre-reskin.
                    text: "\u{2699}"; // gear glyph -- placement-only, per
                                       // Phase 2's scope (still no click
                                       // behavior, dynamic-thread-list gap
                                       // tracked separately).
                    color: Palette.sys-text-muted;
                    font-size: 13px;
                    font-family: Palette.font-sans;
                    vertical-alignment: center;
                }
            }
        }
        Rectangle {
            height: 32px;
            background: Palette.sys-sidebar;
            HorizontalLayout {
                padding: 6px;
                spacing: 4px;
                Text {
                    text: "\u{2315}"; // magnifier glyph
                    color: Palette.sys-text-muted;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                Rectangle {
                    // TextInput has no built-in placeholder support
                    // (that's std-widgets' LineEdit, which pulls in a
                    // heavier widget style dependency this crate doesn't
                    // otherwise use) -- a manually-overlaid Text shown
                    // only while empty reproduces the HTML's "Search
                    // active threads..." placeholder with no new deps.
                    Text {
                        text: "Search active threads...";
                        color: Palette.sys-text-muted;
                        font-family: Palette.font-sans;
                        font-size: 11px;
                        vertical-alignment: center;
                        visible: search-input.text == "";
                    }
                    search-input := TextInput {
                        color: Palette.sys-text-primary;
                        font-family: Palette.font-sans;
                        font-size: 11px;
                        vertical-alignment: center;
                        edited => { search-changed(self.text); }
                    }
                }
            }
        }
        // Thread card -- Phase 3 adds the one-line description (see
        // `models::describe_thread`) and an "ACTIVE" tag on the
        // selected row, matching index.html's `renderThreads()` (title
        // + truncated desc + state indicator + left accent border on
        // the active row).
        Flickable {
            vertical-stretch: 1;
            preferred-height: 0px;
            min-height: 0px;
            viewport-height: threads.length * 48px;
            VerticalLayout {
                for thread[i] in threads : Rectangle {
                    height: 48px;
                    background: i == selected-thread ? Palette.sys-chat : Palette.sys-sidebar;
                    TouchArea {
                        clicked => { thread-selected(i); }
                    }
                    HorizontalLayout {
                        Rectangle {
                            width: 3px;
                            background: i == selected-thread ? Palette.sys-primary : transparent;
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            preferred-width: 0px;
                            min-width: 0px;
                            padding-left: 8px;
                            padding-right: 8px;
                            padding-top: 6px;
                            padding-bottom: 6px;
                            spacing: 2px;
                            alignment: center;
                            HorizontalLayout {
                                spacing: 6px;
                                Text {
                                    text: thread.name;
                                    color: i == selected-thread ? Palette.sys-primary : Palette.sys-text-primary;
                                    font-size: 11px;
                                    font-weight: 700;
                                    font-family: Palette.font-sans;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                    preferred-width: 0px;
                                    min-width: 0px;
                                }
                                Rectangle { horizontal-stretch: 1; preferred-width: 0px; min-width: 0px; }
                                Text {
                                    text: i == selected-thread ? "ACTIVE" : "";
                                    color: Palette.sys-text-muted;
                                    font-size: 8px;
                                    font-family: Palette.font-mono;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    width: 6px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background: thread.status == "loading" ? Palette.sys-primary
                                        : thread.status == "error" ? Palette.sys-text-secondary
                                        : Palette.sys-text-muted;
                                }
                            }
                            Text {
                                text: thread.status == "error" ? "! " + thread.description : thread.description;
                                color: Palette.sys-text-secondary;
                                font-size: 10px;
                                font-family: Palette.font-sans;
                                overflow: elide;
                                horizontal-stretch: 1;
                                preferred-width: 0px;
                                min-width: 0px;
                            }
                        }
                    }
                }
            }
        }
        Rectangle { } // spacer -- pushes the footer chip to the bottom
        Rectangle {
            height: 40px;
            background: Palette.sys-card;
            border-color: Palette.sys-border;
            border-width: 1px;
            HorizontalLayout {
                padding: 8px;
                spacing: 6px;
                Rectangle {
                    width: 6px;
                    height: 6px;
                    border-radius: 3px;
                    background: Palette.sys-text-secondary;
                }
                Text {
                    // Static identity chip -- distinct from the header's
                    // per-thread `agent-badge` (Phase 3, in ChatArea);
                    // this is the workspace-level identity, unchanged
                    // regardless of which thread is selected.
                    text: "Media Conductor";
                    color: Palette.sys-text-secondary;
                    font-family: Palette.font-sans;
                    font-size: 11px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                }
            }
        }
    }
}
