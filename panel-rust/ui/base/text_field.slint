import { Theme } from "../tokens/theme.slint";
import { Metrics } from "../tokens/metrics.slint";
import { CursorHost } from "../tokens/cursor_host.slint";

// Layer 3 (base) -- the repeated "bordered box + inset TextInput" pattern
// hand-rolled at every free-text input site across the settings page
// (MCP server name/command, agent default-profile/permission-profile) --
// same background/border/radius, same left-inset TextInput. Extracted so
// every call site shares one definition instead of repeating the shape.
// Inset uses `Metrics.pad-md` (bumped up from `pad-sm`, the semantic
// alias for the `6px` every call site originally hardcoded -- felt too
// tight for a real bordered input box once extracted).
export component TextField inherits Rectangle {
    in-out property <string> text: "";
    in property <string> field-accessible-label: "";
    in property <length> field-font-size: 11px;
    callback edited();
    // See FilterSearchBar.input-has-focus's doc comment: real keystrokes
    // only reach any editable Slint surface when *something* in the
    // host's OR-chain aggregate reads true. Unlike FilterSearchBar, this
    // component never exposed its own focus state at all, so every call
    // site (MCP server name/command, agent default-profile/
    // permission-profile) was structurally unable to wire itself into
    // that chain -- clicking in focused the field (a real click), but
    // every typed keystroke afterward was silently dropped before ever
    // reaching Slint.
    out property <bool> has-focus: field-input.has-focus;

    height: 26px;
    background: Theme.bg-sidebar;
    border-width: 1px;
    border-color: Theme.border-default;
    border-radius: Theme.radius-sm;

    field-input := TextInput {
        accessible-label: root.field-accessible-label;
        accessible-action-default => { self.focus(); }
        text <=> root.text;
        color: Theme.text-primary;
        font-size: root.field-font-size * Theme.font-scale;
        x: Metrics.pad-md;
        // `settings_view_input_and_propagation` phase: this TextInput had
        // no explicit y/height, so it defaulted to its own single-line
        // preferred height anchored at y:0 -- leaving most of this 26px
        // field's lower area outside the actual clickable/focusable
        // element even though it visually looks like part of the input box,
        // matching the reported "input box doesn't accept input" symptom.
        y: 0px;
        height: parent.height;
        width: parent.width - 2 * Metrics.pad-md;
        vertical-alignment: center;
        edited => { root.edited(); }
        changed has-focus => { CursorHost.kind = self.has-focus ? "text" : "default"; }
    }
}
