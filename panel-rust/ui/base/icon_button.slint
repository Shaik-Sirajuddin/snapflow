import { Theme } from "../tokens/theme.slint";

// Layer 3 (base) -- the repeated hand-rolled "icon-only hover button"
// pattern found across `sidebar.slint` (collapse toggle, new-thread,
// settings-bar): a square/rect `Rectangle` whose background tints on
// hover, a sibling `TouchArea` (accessible-role/label/action/clicked),
// pointer cursor, and caller-supplied icon content via `@children`.
// Distinct from `Button` (fixed-size pill with a text label) -- this one
// has no label of its own and sizes to whatever's passed in.
export component IconButton inherits Rectangle {
    in property <string> button-accessible-label;
    in property <length> btn-width: 24px;
    in property <length> btn-height: 24px;
    // Sticky "on" state (e.g. a toggle whose panel is currently open) --
    // renders the same tint as `has-hover` even while the pointer isn't
    // over the button, so a caller can show both states with the one
    // primitive instead of re-deriving the hover tint itself.
    in property <bool> active: false;
    callback clicked();

    width: btn-width;
    height: btn-height;
    border-radius: Theme.radius-sm;
    background: (active || touch.has-hover) ? Theme.bg-primary-container : transparent;
    animate background { duration: 100ms; }

    touch := TouchArea {
        mouse-cursor: pointer;
        accessible-role: button;
        accessible-label: root.button-accessible-label;
        accessible-action-default => { root.clicked(); }
        clicked => { root.clicked(); }
    }
    // Center icon/glyph on both axes so header rows share one baseline
    // with adjacent Text (e.g. sidebar "Chats" + collapse/new buttons).
    VerticalLayout {
        width: 100%;
        height: 100%;
        alignment: center;
        HorizontalLayout {
            alignment: center;
            @children
        }
    }
}
