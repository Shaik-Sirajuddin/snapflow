// Layer 3 (base) helper -- string operations Slint's expression language
// lacks natively in this build (it has `to-lowercase` but no substring
// search), backed by a Rust implementation installed once at startup.
// Kept domain-free so any base primitive can depend on it.
export global TextUtil {
    // Case-insensitive substring test. Returns false until Rust installs
    // the implementation.
    pure callback contains-ci(string, string) -> bool;
    // Byte offset of the start of the word immediately before `cursor`
    // (given as a byte offset into the text) -- skips any run of
    // whitespace directly before the cursor, then the word itself. Used to
    // implement word-wise backspace by selecting `[result, cursor)`.
    // Returns `cursor` unchanged until Rust installs the implementation.
    pure callback word-boundary-before(string, int) -> int;
    // Compose slash-command helpers (layout-redesign.md Phase 4). The
    // "active token" is the whitespace-delimited run containing `cursor`.
    // Prefix is "/", "#", or "@" when that token starts with one of those
    // (else ""). Query is the rest of the token after the prefix.
    pure callback active-token-prefix(string, int) -> string;
    pure callback active-token-query(string, int) -> string;
    // Replace the full active token with `replacement` (caller usually
    // includes a trailing space). Returns the new full text.
    pure callback replace-active-token(string, int, string) -> string;

    // True once the host (or ui-dev-viewer) has installed contains-ci.
    public pure function filter-ready() -> bool {
        return contains-ci("AbC", "b");
    }

    // Filter helper for mention / dropdown lists.
    // - empty needle → match everything
    // - host installed → case-insensitive substring
    // - host missing → case-insensitive exact match only (avoids blanking
    //   the list when pure-callback defaults return false for every call)
    public pure function matches-filter(haystack: string, needle: string) -> bool {
        if (needle == "") {
            return true;
        }
        if (contains-ci(haystack, needle)) {
            return true;
        }
        if (filter-ready()) {
            return false;
        }
        return haystack.to-lowercase() == needle.to-lowercase();
    }
}
