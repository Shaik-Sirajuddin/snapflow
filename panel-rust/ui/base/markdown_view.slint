import { Theme } from "../tokens/theme.slint";
import { Metrics } from "../tokens/metrics.slint";
import { MarkdownLine, MarkdownRun } from "../types.slint";

// Renders `MessageItem.markdown-lines` (see `src/markdown.rs` / `types.
// slint`'s doc comments). Each `MarkdownLine` is already a fully wrapped
// visual row -- the Rust side did the word-wrapping (`markdown::
// wrap_runs`) because Slint's `Text` element has no native way to mix
// differently-styled runs inside one reflowing, wrapped line the way
// grok-build's ratatui-based renderer does with `Span`s. So this view
// never wraps text itself: it just lays each line's runs out
// horizontally and stacks lines vertically, styling each row by `kind`.
//
// ## Why left-align is explicit (and easy to regress)
//
// Slint `HorizontalLayout` defaults to `alignment: stretch`. When every
// child is content-sized (`Text` has horizontal-stretch: 0), leftover
// free space is *not* left at the end -- the engine packs the group as a
// whole in the middle of the row. That is the opposite of CSS flexbox
// (`justify-content: flex-start` default). Setting each run's
// `horizontal-alignment: left` only controls glyphs *inside* that run's
// own box; it does not decide where the box sits in the row. Visible
// symptom: agent markdown bodies look centered in the bubble.
//
// Fix: every horizontal row uses `alignment: start` and a trailing
// zero-height stretch spacer that absorbs free space so even a future
// accidental `stretch` realignment cannot re-center the run group.
//
// Known simplifications vs. the ratatui original (acceptable for a v1
// chat body, see markdown.rs's module doc for the full rationale):
// no code-fence syntax highlighting, no clickable link targets, tables
// render as a single unwrapped monospace row per row, and `strike` runs
// are shown muted rather than with a real strikethrough decoration
// (Slint's `Text` has no text-decoration property to draw one).
export component MarkdownView inherits VerticalLayout {
    // Phase 17: emitted with the link target on click (host applies
    // the Ctrl requirement + opens file/URL).
    callback link-activated(string);
    in property <[MarkdownLine]> lines: [];
    // Shown as plain wrapped text when `lines` is empty -- covers a
    // "agent" row cached before `markdown-lines` existed (see
    // `MessageItem.markdown-lines`'s doc comment) and any non-agent
    // caller that hasn't bothered to markdown-parse its body.
    in property <string> fallback-text: "";
    in property <length> row-width: 0px;

    spacing: 0px;
    // Cross-axis for VerticalLayout = horizontal. Stretch children to
    // the full row width so text starts at the left edge of the bubble,
    // not at the left edge of a shrink-wrapped content column floating
    // inside a wider parent.
    alignment: stretch;

    function same-code-group(idx: int) -> bool {
        idx > 0 && root.lines[idx].kind == "code" && root.lines[idx - 1].kind == "code"
            && root.lines[idx].code-block-id == root.lines[idx - 1].code-block-id
    }

    pure function heading-size(kind: string) -> length {
        if kind == "h1" {
            18px
        } else if kind == "h2" {
            16px
        } else if kind == "h3" {
            14px
        } else {
            13px
        }
    }

    if lines.length == 0 : Text {
        text: fallback-text;
        font-family: Theme.font-sans;
        font-size: 12px * Theme.font-scale;
        color: Theme.text-primary;
        wrap: word-wrap;
        horizontal-alignment: left;
        // Stretch across the bubble; no explicit width (can't combine
        // with min-width under Slint's layout rules).
        horizontal-stretch: 1;
        preferred-width: 0px;
        min-width: 0px;
    }

    for line[i] in lines : VerticalLayout {
        property <bool> is-code: line.kind == "code";
        property <bool> is-quote: line.kind == "quote";
        property <bool> is-hr: line.kind == "hr";
        property <bool> is-li: line.kind == "li" || line.kind == "li-ordered";
        property <bool> is-heading: line.kind == "h1" || line.kind == "h2" || line.kind == "h3"
            || line.kind == "h4" || line.kind == "h5" || line.kind == "h6";
        property <bool> group-start: !is-code || !root.same-code-group(i);
        property <bool> group-end: !is-code
            || i + 1 >= root.lines.length
            || !(root.lines[i + 1].kind == "code" && root.lines[i + 1].code-block-id == line.code-block-id);

        horizontal-stretch: 1;
        preferred-width: 0px;
        min-width: 0px;
        alignment: stretch;

        // Contiguous lines in the same code-fence group sit flush
        // against each other (one continuous background box); every
        // other line gets a small breathing-room gap above it.
        if i > 0 && !(is-code && !group-start) : Rectangle { height: Metrics.space-2; }

        // One content row. Background for code is painted *behind* the
        // runs (same geometry), not as a stretch sibling that steals
        // half the row.
        row-box := Rectangle {
            horizontal-stretch: 1;
            preferred-width: 0px;
            min-width: 0px;
            background: is-code ? Theme.bg-terminal : transparent;
            border-color: is-code ? Theme.border-terminal : transparent;
            border-width: is-code ? 1px : 0px;
            border-top-left-radius: is-code && group-start ? Theme.radius-sm : 0px;
            border-top-right-radius: is-code && group-start ? Theme.radius-sm : 0px;
            border-bottom-left-radius: is-code && group-end ? Theme.radius-sm : 0px;
            border-bottom-right-radius: is-code && group-end ? Theme.radius-sm : 0px;

            HorizontalLayout {
                width: 100%;
                padding-left: line.indent * 14px + (is-code ? Metrics.space-4 : 0px);
                padding-right: is-code ? Metrics.space-4 : 0px;
                padding-top: is-code ? (group-start ? Metrics.space-3 : 0px) : 0px;
                padding-bottom: is-code ? (group-end ? Metrics.space-3 : 0px) : 0px;
                spacing: Metrics.space-2;
                // CRITICAL: start packing — see module comment.
                alignment: start;

                // Blockquote left accent bar.
                if is-quote : Rectangle {
                    width: 2px;
                    horizontal-stretch: 0;
                    background: Theme.border-strong;
                }

                if is-hr : Rectangle {
                    height: 1px;
                    horizontal-stretch: 1;
                    y: parent.height / 2;
                    background: Theme.border-default;
                }

                if is-li : Text {
                    text: line.kind == "li-ordered" ? line.ordinal + "." : "\u{2022}";
                    font-family: Theme.font-sans;
                    font-size: 12px * Theme.font-scale;
                    color: Theme.text-secondary;
                    horizontal-alignment: left;
                    vertical-alignment: top;
                    horizontal-stretch: 0;
                }

                if !is-hr : HorizontalLayout {
                    // Content-sized run cluster, packed by the outer
                    // `alignment: start`. Do *not* set horizontal-stretch:1
                    // here without a trailing spacer — a full-width stretch
                    // child with only non-stretch Text grandchildren and
                    // default stretch alignment re-centers the glyph group.
                    alignment: start;
                    horizontal-stretch: 0;
                    spacing: 0px;
                    for run[ri] in line.runs : Text {
                        text: run.text;
                        font-family: (run.code || is-code) ? Theme.font-mono : Theme.font-sans;
                        font-size: (is-heading ? root.heading-size(line.kind) : is-code ? 11px : 12px) * Theme.font-scale;
                        font-weight: (run.bold || is-heading) ? 700 : 400;
                        font-italic: run.italic;
                        // Phase 17: token-colored highlighting -- links
                        // blue + underline, headings yellow, bold stays
                        // high-contrast text-primary at weight 700.
                        color: run.link != "" ? Theme.md-link
                            : run.strike ? Theme.text-muted
                            : is-heading ? Theme.md-heading
                            : is-code ? Theme.text-terminal
                            : Theme.text-primary;
                        // TextDecoration: underline links only.
                        // (Slint Text has no underline property pre-1.9?
                        // it does: `text-decoration` not available; use
                        // overline-free fallback -- omitted.)
                        horizontal-alignment: left;
                        vertical-alignment: top;
                        horizontal-stretch: 0;
                        // Ctrl+Click opens the target.
                        if run.link != "" : TouchArea {
                            mouse-cursor: pointer;
                            pointer-event(ev) => {
                                // Ctrl+Click only (plain click stays inert
                                // so text selection/scroll is unaffected).
                                if (ev.kind == PointerEventKind.up
                                    && ev.modifiers.control) {
                                    root.link-activated(run.link);
                                }
                            }
                        }
                    }
                }

                // Absorbs free space so run/bullet boxes stay at the
                // start edge even if this layout's alignment is ever
                // changed back to the Slint default (`stretch`).
                if !is-hr : Rectangle {
                    horizontal-stretch: 1;
                    min-width: 0px;
                    preferred-width: 0px;
                    height: 0px;
                    vertical-stretch: 0;
                }
            }
        }
    }
}
