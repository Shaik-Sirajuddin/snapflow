import { Theme } from "../tokens/theme.slint";
import { Metrics } from "../tokens/metrics.slint";
import { CursorHost } from "../tokens/cursor_host.slint";

// Layer 3 (base) -- the variable-width clickable text pill hand-rolled
// 3x in `pages/skills/skill_view.slint`'s editor header (copy-path,
// one per detected editor in a `for` loop, open-with-OS-default): a
// TouchArea wrapping a bordered token-tinted Rectangle with a small
// label. Neither `Button` (fixed-width) nor `IconButton` (icon-only)
// fits labels like "Open in Visual Studio Code" that need to size to
// their own content.
export component TextPillButton {
    in property <string> label;
    in property <string> button-accessible-label: root.label;
    callback clicked();

    touch := TouchArea {
        mouse-cursor: pointer;
        horizontal-stretch: 0;
        accessible-role: button;
        accessible-label: root.button-accessible-label;
        accessible-action-default => { root.clicked(); }
        clicked => { root.clicked(); }
        changed has-hover => { CursorHost.kind = self.has-hover ? "pointer" : "default"; }
        Rectangle {
            background: touch.has-hover
                ? Theme.bg-primary-container
                : Theme.bg-primary-container.with-alpha(0.6);
            border-width: 1px;
            border-color: Theme.border-default;
            border-radius: Theme.radius-sm;
            HorizontalLayout {
                padding-left: Metrics.space-2;
                padding-right: Metrics.space-2;
                padding-top: Metrics.space-1;
                padding-bottom: Metrics.space-1;
                Text {
                    text: root.label;
                    color: Theme.text-secondary;
                    font-size: 9px * Theme.font-scale;
                    font-family: Theme.font-sans;
                    font-weight: 600;
                    vertical-alignment: center;
                }
            }
        }
    }
}
