// Shared data-model structs, split out of app.slint so sidebar.slint /
// chat-area.slint / message-card.slint can each `import` just the types
// they need without a circular dependency on the root window component.
export struct ThreadItem {
    name: string,
    status: string, // "idle" | "loading" | "error"
    busy: bool,
    open: bool,
    // Panel-local presentation policy resolved from the durable default
    // and optional per-thread override. This is not an ACPX capability.
    background: bool,
    // Phase 3 (chat-panel-ui-theme-parity.md): one-line preview
    // synthesized from the thread's latest message (Rust-side --
    // `models::describe_thread`), matching index.html's `t.desc` field.
    // Empty string for a thread with no messages yet.
    description: string,
    // Coverage Matrix `session/close`/`session/delete` row: true once
    // an explicit `session/close` (or `session/delete`) has been sent
    // for this thread -- overrides `status`'s display value to
    // `"closed"` and swaps the sidebar row's close control for a
    // delete control. Never set implicitly by window/process teardown.
    closed: bool,
}

export struct MessageItem {
    // chat-items-redesign.md #5/#11: "tool-call" is being retired in
    // favor of the finer taxonomy `models::classify_tool_call_kind`
    // produces ("tool_use" / "mcp_server_call", "skill_load"/"skill_use"
    // reserved but not yet emitted) -- both old and new strings are
    // listed here during the migration since `message_card.slint` still
    // matches the old one until `chat_area.slint`'s routing change lands.
    kind: string, // "user" | "agent" | "thinking" | "tool-call" | "tool_use" | "mcp_server_call" | "skill_load" | "skill_use"
    text: string,
    // Phase 3: tool-call execution status, already-uppercased display
    // text (e.g. "COMPLETED") or "" for non-tool-call kinds / messages
    // cached before this field existed -- monochrome text badge only,
    // see message_card.slint's doc comment.
    status: string,
    // Phase 3: UI-only collapse state for the tool-call log body --
    // Rust-side `Vec<bool>` parallel to the message list (see
    // `PanelSingleton::expanded` in lib.rs), not part of
    // `rui_acp_client::ChatMessage` at all. Ignored for non-tool-call
    // kinds.
    expanded: bool,
    // Phase 3: this message's position in the currently-displayed
    // thread's message list -- round-tripped back through
    // `toggle-expanded(index)` so Rust knows which entry in its
    // `expanded: Vec<bool>` to flip.
    index: int,
    // chat-items-redesign.md #9 (execution-view "api-call" variant):
    // `ChatMessage::raw_input`/`raw_output`, pre-serialized to a display
    // string on the Rust side (Slint has no dynamic-JSON-value type) --
    // "" when the backend didn't provide one, same convention `status`
    // already uses for its own optional field.
    raw-input: string,
    raw-output: string,
}

// Interactive-relay addition: one pending agent-initiated request
// awaiting a user decision (`session/request_permission`, `fs/*`,
// `terminal/create`) -- see `panel-rust/src/permission.rs`'s
// `PendingRequestView`, which this mirrors field-for-field. `active`
// distinguishes "no pending request" (an all-empty/default struct,
// since Slint has no `Option<T>`) from a real one with an empty
// `relay-id` -- callers must check `active` first.
export struct PendingRequestItem {
    active: bool,
    relay-id: string,
    method: string,
    title: string,
    summary: string,
    supported: bool,
}

// Terminal-view addition: one live agent-created terminal known to the
// currently-displayed thread (`AgentBridge::active_terminal_ids` +
// `terminal_buffer`, see `agent_bridge.rs`). Rendered as a bounded
// max-height card docked above the compose bar (mirrors
// `PendingRequestItem`'s docking convention) with click-to-expand into
// a full-window floating overlay -- see `terminal_card.slint`.
export struct TerminalItem {
    terminal-id: string,
    output: string,
    truncated: bool,
    has-exited: bool,
    exit-code: int,
}

// Profile-picker addition: one profile row as returned by
// `AgentBridge::list_profiles` (`rui_acpx_client::ProfileSummary`, see
// `models::to_profile_options`). `terminal-enabled`/`fs-enabled` are
// shown as small inline badges so picking a profile makes clear whether
// it will actually unlock terminal/fs approval cards for a new thread,
// rather than the user discovering that only after a request silently
// auto-rejects.
export struct ProfileOption {
    name: string,
    agent-id: string,
    terminal-enabled: bool,
    fs-enabled: bool,
}

// Mode/config selector addition: one entry of the *currently selected
// thread's* live session mode advertisement (`AgentBridge::
// session_modes`, see `rui_acp_client::SessionModesEvent`). Only ever
// non-empty once `session/new`/`session/load` has actually resolved and
// the backend advertised at least one mode -- an empty `available-modes`
// list (Coverage Matrix's "capability-gated selection") means the
// selector renders nothing at all, not a disabled/greyed control.
export struct ModeOption {
    id: string,
    name: string,
    description: string,
}

// Mode/config selector addition: one *row* of the currently selected
// thread's live `configOptions[]` advertisement (`AgentBridge::
// config_options`, see `rui_acp_client::ConfigOptionInfo`). Slint has no
// nested-array-in-struct-in-array construct convenient for a `for`
// loop, so Rust flattens each `ConfigOptionInfo` into one `is-header`
// row (the option's own name/description, not clickable) followed by
// one row per `ConfigOptionInfo::options` entry (`is-header: false`,
// clickable, `is-current` highlighted) -- `chat_area.slint`/`app.slint`
// render this as a single flat `for` loop, switching row visuals on
// `is-header`.
export struct ConfigOptionRow {
    option-id: string,
    is-header: bool,
    // Header row: the option's own display name/description.
    // Value row: the selectable value's own display name/description.
    name: string,
    description: string,
    // Value row only: the literal value string sent back to
    // `session/set_config_option`'s own `value` field.
    value: string,
    is-current: bool,
}

// Settings-sheet addition: one centrally-registered MCP server row, as
// returned by `AgentBridge::list_mcp_servers` (`mcp_servers/list`, see
// `models::to_mcp_server_options`). `command` is shown as a small
// secondary label so the settings list is legible without opening an
// edit dialog -- full entry payloads (env, args, etc.) are opaque JSON
// on the Rust side (`acpx-core::McpServerStore` never interprets more
// than `"name"`), this struct only surfaces what the list view needs.
export struct McpServerOption {
    name: string,
    command: string,
}

// Recovery/import sheet addition (Coverage Matrix `session/list` row):
// one entry from `AgentBridge::recoverable_sessions` -- a real remote
// gateway session not currently bound to any local thread row.
// `title`/`updated_at` are backend-reported ACP metadata (may be
// empty -- not every backend sets them).
export struct RemoteSessionOption {
    session_id: string,
    provider: string,
    title: string,
    updated_at: string,
}

// Settings-sheet addition: one agent-catalog entry, as returned by
// `AgentBridge::list_agents` (`agents/list`, see `models::
// to_agent_catalog_entries`). `status` is the registry's own live
// detection string (`acpx_proto::AgentStatus`'s serde tag, e.g.
// "installed" / "not_installed" / "installed_no_session" /
// "runtime_missing") -- rendered as plain monochrome text, not a
// colored badge, matching this project's established no-status-color
// design language (see `component-style-system.md`).
export struct AgentCatalogEntry {
    id: string,
    name: string,
    version: string,
    status: string,
}

// Client-local PTY terminal addition: a snapshot of the currently
// selected thread's own client-spawned shell process (`AgentBridge::
// local_terminal_snapshot`, see `local_terminal::LocalTerminal`'s doc
// comment). Distinct from `TerminalItem` (agent-created, read-only,
// relayed from the gateway) -- this one is interactive: the card that
// renders it also captures keyboard input and forwards it back via
// `local-terminal-input(string)`. `open` mirrors `PendingRequestItem`'s
// "all-empty/default struct means nothing is open" convention (Slint
// has no `Option<T>`).
export struct LocalTerminalItem {
    open: bool,
    screen-text: string,
    cols: int,
    rows: int,
    cursor-row: int,
    cursor-col: int,
    has-exited: bool,
}

// Domain-neutral option row for `base/searchable_dropdown.slint` -- kept
// out of the chat-specific structs above so the base primitive depends on
// no domain type. Callers (the compose bar's mode/model selectors, later
// the slash-command popup) build these from their own source data (Rust
// `models::to_*_dropdown_entries`). A row with `is-header: true` renders
// as a non-selectable section label; `value` is the opaque payload handed
// back to the selection callback alongside `id` (e.g. a config option's
// `session/set_config_option` value; empty for a plain mode row).
export struct DropdownEntry {
    id: string,
    label: string,
    value: string,
    is-header: bool,
    is-current: bool,
}
