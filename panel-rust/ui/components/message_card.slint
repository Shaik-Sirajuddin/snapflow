import { Theme } from "../tokens/theme.slint";
import { Metrics } from "../tokens/metrics.slint";
import { Badge } from "../base/badge.slint";
import { MessageItem } from "../types.slint";

// One reusable message card, parameterized by kind (user/agent/tool-call/
// thinking) -- Phase 3 of chat-panel-ui-theme-parity.md. Visual source:
// ui_html/index.html's `renderChatBubbles()` for user/agent/thinking
// (plain bordered bubble, uppercase mono label header, no timestamp --
// this crate's `ChatMessage` carries no timestamp field, an accepted
// data-model gap not in this plan's scope) and `renderTimeline()`'s
// tool_use card for tool-call (status badge + collapsible log body),
// since the HTML's own bubble-layout tool rendering is a flat text dump
// with no collapse affordance and this plan explicitly asks for one.
//
// Status stays deliberately monochrome (see tokens/theme.slint's note) --
// `item.status` is already uppercased by `models::to_message_model`, so
// this file only lays it out, never colors by value.
export component MessageCard inherits Rectangle {
    in property <MessageItem> item;
    callback toggle-expanded(int);

    property <bool> is-user: item.kind == "user";
    property <bool> is-agent: item.kind == "agent";
    property <bool> is-tool-call: item.kind == "tool-call";
    property <bool> is-thinking: item.kind == "thinking";
    property <string> header-label: is-user ? "USER" : is-agent ? "AGENT" : is-thinking ? "THINKING" : "TOOL";

    // Thinking renders as plain muted/italic text, no bubble chrome at
    // all -- matches the timeline view's "agent text stream" treatment
    // for non-bubble content; user/agent/tool-call all get a bordered
    // card.
    background: is-thinking ? transparent
        : is-user ? Theme.bg-user-bubble
        : is-tool-call ? Theme.bg-card
        : Theme.bg-agent-bubble;
    border-color: is-user ? Theme.border-user-bubble
        : is-tool-call ? Theme.border-default
        : Theme.border-agent-bubble;
    border-width: is-thinking ? 0px : 1px;
    border-radius: Theme.radius-md;

    VerticalLayout {
        padding: is-thinking ? Metrics.space-2 : Metrics.space-5;
        spacing: Metrics.space-3;

        // Header row -- uppercase mono label, plus tool-name/status
        // badges for tool-call only.
        HorizontalLayout {
            spacing: Metrics.space-3;
            Text {
                text: header-label;
                font-family: Theme.font-mono;
                font-size: 9px * Theme.font-scale;
                font-weight: 700;
                letter-spacing: 0.5px;
                color: Theme.text-muted;
                vertical-alignment: center;
            }
            if is-tool-call && item.status != "" : Badge {
                label: item.status;
            }
            Rectangle { }
        }

        // Body -- plain wrapped text for user/agent/thinking; for
        // tool-call, a clickable summary line that toggles the log box.
        // Flickable-wrapped, height bound to the Text's own
        // `preferred-height` -- same fix `user_bubble.slint` needed for
        // its own body text (a bare stretch-sized Text in this position
        // risked blowing up to fill leftover row height).
        if !is-tool-call : Flickable {
            height: body-text.preferred-height;
            viewport-height: body-text.preferred-height;
            horizontal-stretch: 1;
            preferred-width: 0px;
            min-width: 0px;
            body-text := Text {
                text: item.text;
                font-italic: is-thinking;
                font-family: Theme.font-sans;
                font-size: (is-thinking ? 11px : 12px) * Theme.font-scale;
                color: is-user ? Theme.text-user-bubble
                    : is-thinking ? Theme.text-muted
                    : Theme.text-agent-bubble;
                wrap: word-wrap;
                overflow: elide;
                horizontal-alignment: left;
                vertical-alignment: top;
                width: parent.width;
            }
        }
        // Plain `Rectangle` (not a layout) so a sibling `TouchArea` can
        // cover the whole clickable summary+toggle-label area -- same
        // "TouchArea + Layout as siblings under a plain Rectangle" idiom
        // already used for the sidebar's thread-row click targets.
        if is-tool-call : Rectangle {
            background: tool-toggle-touch.has-hover ? Theme.bg-primary-container : transparent;
            animate background { duration: 100ms; }
            tool-toggle-touch := TouchArea {
                mouse-cursor: pointer;
                accessible-role: button;
                accessible-label: item.expanded ? "Hide logs" : "Show logs";
                accessible-action-default => { toggle-expanded(item.index); }
                clicked => { toggle-expanded(item.index); }
            }
            VerticalLayout {
                spacing: Metrics.space-3;
                HorizontalLayout {
                    spacing: Metrics.space-3;
                    Text {
                        text: item.text;
                        font-family: Theme.font-sans;
                        font-size: 12px * Theme.font-scale;
                        font-weight: 600;
                        color: Theme.text-primary;
                        wrap: word-wrap;
                        overflow: elide;
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                    }
                    Text {
                        text: item.expanded ? "[-] hide logs" : "[+] show logs";
                        font-family: Theme.font-mono;
                        font-size: 9px * Theme.font-scale;
                        color: Theme.text-secondary;
                        vertical-alignment: center;
                    }
                    Rectangle { }
                }
                if item.expanded : Rectangle {
                    background: Theme.bg-terminal;
                    border-color: Theme.border-terminal;
                    border-width: 1px;
                    border-radius: Theme.radius-sm;
                    HorizontalLayout {
                        padding: Metrics.space-4;
                        Text {
                            text: item.text;
                            font-family: Theme.font-mono;
                            font-size: 10px * Theme.font-scale;
                            color: Theme.text-terminal;
                            wrap: word-wrap;
                            overflow: elide;
                            horizontal-stretch: 1;
                            preferred-width: 0px;
                            min-width: 0px;
                        }
                    }
                }
            }
        }
    }
}
