import { Theme } from "../tokens/theme.slint";
import { Metrics } from "../tokens/metrics.slint";
import { Badge } from "../base/badge.slint";
import { MessageItem } from "../types.slint";
import { CursorHost } from "../tokens/cursor_host.slint";

// Agent / thinking / legacy tool-call card.
// Styling on top of the working baseline:
// - Agent: no "AGENT" label, no border, elevated fill, 3-corner radius
// - Thinking: transparent, small pad
// - Body keeps Flickable + preferred-height (baseline-stable)
// - Empty layout spacers must not fill parent height (Slint skill)
export component MessageCard inherits Rectangle {
    in property <MessageItem> item;
    callback toggle-expanded(int);

    property <bool> is-user: item.kind == "user";
    property <bool> is-agent: item.kind == "agent";
    property <bool> is-tool-call: item.kind == "tool-call";
    property <bool> is-thinking: item.kind == "thinking";
    property <string> header-label: is-user ? "USER" : is-agent ? "AGENT" : is-thinking ? "THINKING" : "TOOL";

    vertical-stretch: 0;

    // Agent uses primary-container so it contrasts bg-chat without a border.
    background: is-thinking ? transparent
        : is-user ? Theme.bg-user-bubble
        : is-tool-call ? Theme.bg-card
        : Theme.bg-primary-container;
    border-color: is-tool-call ? Theme.border-default : transparent;
    border-width: is-thinking ? 0px : is-tool-call ? 1px : 0px;

    border-top-left-radius: is-thinking ? 0px : Theme.radius-lg;
    border-top-right-radius: is-thinking ? 0px : Theme.radius-lg;
    border-bottom-left-radius: is-thinking ? 0px
        : is-agent ? Metrics.radius-corner-cut
        : Theme.radius-lg;
    border-bottom-right-radius: is-thinking ? 0px
        : is-user ? Metrics.radius-corner-cut
        : Theme.radius-lg;

    VerticalLayout {
        padding: is-thinking ? Metrics.space-2
            : is-agent ? Metrics.space-4
            : Metrics.space-5;
        spacing: Metrics.space-3;

        // No header for agent messages.
        if !is-agent : HorizontalLayout {
            spacing: Metrics.space-3;
            Text {
                text: header-label;
                font-family: Theme.font-mono;
                font-size: 9px * Theme.font-scale;
                font-weight: 700;
                letter-spacing: 0.5px;
                color: Theme.text-muted;
                vertical-alignment: center;
                horizontal-stretch: 0;
            }
            if is-tool-call && item.status != "" : Badge {
                label: item.status;
            }
            // Horizontal-only spacer (empty rect fills parent by default).
            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 0;
                height: 0px;
                preferred-height: 0px;
            }
        }

        if !is-tool-call : Flickable {
            height: body-text.preferred-height;
            viewport-height: body-text.preferred-height;
            horizontal-stretch: 1;
            preferred-width: 0px;
            min-width: 0px;
            body-text := Text {
                text: item.text;
                font-italic: is-thinking;
                font-family: Theme.font-sans;
                font-size: (is-thinking ? 11px : 12px) * Theme.font-scale;
                color: is-user ? Theme.text-user-bubble
                    : is-thinking ? Theme.text-muted
                    : Theme.text-primary;
                wrap: word-wrap;
                overflow: elide;
                horizontal-alignment: left;
                vertical-alignment: top;
                width: parent.width;
            }
        }

        if is-tool-call : Rectangle {
            background: tool-toggle-touch.has-hover ? Theme.bg-primary-container : transparent;
            animate background { duration: 100ms; }
            tool-toggle-touch := TouchArea {
                mouse-cursor: pointer;
                accessible-role: button;
                accessible-label: item.expanded ? "Hide logs" : "Show logs";
                accessible-action-default => { toggle-expanded(item.index); }
                clicked => { toggle-expanded(item.index); }
                changed has-hover => { CursorHost.kind = self.has-hover ? "pointer" : "default"; }
            }
            VerticalLayout {
                spacing: Metrics.space-3;
                HorizontalLayout {
                    spacing: Metrics.space-3;
                    Text {
                        text: item.text;
                        font-family: Theme.font-sans;
                        font-size: 12px * Theme.font-scale;
                        font-weight: 600;
                        color: Theme.text-primary;
                        wrap: word-wrap;
                        overflow: elide;
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                    }
                    Text {
                        text: item.expanded ? "[-] hide logs" : "[+] show logs";
                        font-family: Theme.font-mono;
                        font-size: 9px * Theme.font-scale;
                        color: Theme.text-secondary;
                        vertical-alignment: center;
                        horizontal-stretch: 0;
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 0;
                        height: 0px;
                        preferred-height: 0px;
                    }
                }
                if item.expanded : Rectangle {
                    background: Theme.bg-terminal;
                    border-color: Theme.border-terminal;
                    border-width: 1px;
                    border-radius: Theme.radius-sm;
                    HorizontalLayout {
                        padding: Metrics.space-4;
                        Text {
                            text: item.text;
                            font-family: Theme.font-mono;
                            font-size: 10px * Theme.font-scale;
                            color: Theme.text-terminal;
                            wrap: word-wrap;
                            overflow: elide;
                            horizontal-stretch: 1;
                            preferred-width: 0px;
                            min-width: 0px;
                        }
                    }
                }
            }
        }
    }
}
