import { Theme } from "../tokens/theme.slint";
import { Button } from "../base/button.slint";
import { LocalTerminalItem } from "../types.slint";

// Client-local PTY terminal view -- companion to `terminal_card.slint`'s
// agent-created (read-only) `TerminalCard`/`TerminalOverlay`. This one
// is a real interactive terminal the *client itself* spawned
// (`AgentBridge::open_local_terminal`, see `local_terminal.rs`'s doc
// comment): the card/overlay both capture keyboard input via a
// `FocusScope` and forward every keystroke to Rust through
// `local-terminal-key(text)`, which writes it straight to the real
// PTY's input side. `screen-text` is the VT100 parser's real rendered
// screen (cursor-tracked, control sequences interpreted), monochrome
// per this project's design language (see `local_terminal.rs`'s doc
// comment on why colors are intentionally not reproduced).
export component LocalTerminalCard inherits Rectangle {
    in property <LocalTerminalItem> item;
    in property <bool> compact: true;
    callback expand();
    callback key-input(string);
    callback close-requested();
    out property <bool> has-focus: focus-scope.has-focus;

    background: Theme.bg-terminal;
    border-color: Theme.border-terminal;
    border-width: 1px;
    border-radius: Theme.radius-md;
    height: compact ? 120px : 180px;

    focus-scope := FocusScope {
        key-pressed(event) => {
            key-input(event.text);
            accept
        }
        VerticalLayout {
            padding: 8px;
            spacing: 4px;
            Rectangle {
                height: 18px;
                TouchArea {
                    accessible-role: button;
                    accessible-label: "Focus local terminal";
                    accessible-action-default => {
                        focus-scope.focus();
                    }
                    clicked => {
                        focus-scope.focus();
                    }
                }
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "\u{2318}"; // terminal glyph stand-in, same as TerminalCard
                        color: Theme.bg-primary;
                        font-size: 11px * Theme.font-scale;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "local terminal";
                        color: Theme.text-primary;
                        font-family: Theme.font-mono;
                        font-size: 10px * Theme.font-scale;
                        font-weight: 700;
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                    if item.has-exited : Text {
                        text: "exited";
                        color: Theme.text-muted;
                        font-family: Theme.font-mono;
                        font-size: 9px * Theme.font-scale;
                        vertical-alignment: center;
                    }
                    if !item.has-exited : Text {
                        text: focus-scope.has-focus ? "focused" : "click to focus";
                        color: Theme.text-secondary;
                        font-family: Theme.font-mono;
                        font-size: 9px * Theme.font-scale;
                        vertical-alignment: center;
                    }
                    Button {
                        label: "Kill";
                        button-accessible-label: "Close local terminal";
                        btn-width: 44px;
                        btn-height: 16px;
                        font-size: 8px;
                        font-weight: 400;
                        bg: Theme.bg-card;
                        fg: Theme.text-secondary;
                        clicked => { close-requested(); }
                    }
                    local-terminal-expand := TouchArea {
                        width: 16px;
                        accessible-role: button;
                        accessible-label: "Expand local terminal";
                        accessible-action-default => { expand(); }
                        clicked => { expand(); }
                        Text {
                            text: "\u{2922}"; // expand glyph, same as TerminalCard
                            color: Theme.text-muted;
                            font-size: 11px * Theme.font-scale;
                            vertical-alignment: center;
                        }
                    }
                }
            }
            Flickable {
                viewport-height: log.preferred-height;
                log := Text {
                    text: item.screen-text;
                    color: Theme.text-terminal;
                    font-family: Theme.font-mono;
                    font-size: 10px * Theme.font-scale;
                    wrap: no-wrap;
                    overflow: clip;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                }
            }
        }
    }
}

// Full-window floating overlay -- same docking convention as
// `TerminalOverlay`/the settings sheet.
export component LocalTerminalOverlay inherits Rectangle {
    in property <LocalTerminalItem> item;
    in property <length> container-width;
    in property <length> container-height;
    callback close();
    callback key-input(string);
    callback close-requested();
    out property <bool> has-focus: focus-scope.has-focus;

    x: 8px;
    y: 8px;
    width: container-width - 16px;
    height: container-height - 16px;
    background: Theme.bg-terminal;
    border-color: Theme.border-strong;
    border-width: 1px;
    border-radius: Theme.radius-md;

    focus-scope := FocusScope {
        key-pressed(event) => {
            key-input(event.text);
            accept
        }
        VerticalLayout {
            padding: 10px;
            spacing: 8px;
            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: "local terminal" + (item.has-exited ? " (exited)" : "");
                    color: Theme.text-primary;
                    font-family: Theme.font-mono;
                    font-size: 12px * Theme.font-scale;
                    font-weight: 700;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                    overflow: elide;
                    vertical-alignment: center;
                }
                Button {
                    label: "Kill";
                    button-accessible-label: "Close local terminal";
                    btn-width: 60px;
                    btn-height: 24px;
                    font-weight: 400;
                    clicked => { close-requested(); }
                }
                Button {
                    label: "Close";
                    button-accessible-label: "Close local terminal overlay";
                    btn-width: 60px;
                    btn-height: 24px;
                    font-weight: 400;
                    clicked => { close(); }
                }
            }
            Rectangle { height: 1px; background: Theme.border-default; }
            Flickable {
                viewport-height: full-log.preferred-height;
                full-log := Text {
                    text: item.screen-text;
                    color: Theme.text-terminal;
                    font-family: Theme.font-mono;
                    font-size: 11px * Theme.font-scale;
                    wrap: no-wrap;
                    overflow: clip;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                }
            }
        }
    }

    init => { focus-scope.focus(); }
}
