import { Theme } from "../tokens/theme.slint";
import { Metrics } from "../tokens/metrics.slint";
import { Icon } from "../base/icon.slint";
import { IconButton } from "../base/icon_button.slint";
import { HoverSurface } from "../base/hover.slint";
import { ThreadItem } from "../types.slint";

// Thread list column -- Phase 2 of chat-panel-ui-theme-parity.md will
// extend this with a real search box + filtered model and a footer
// identity chip, without touching app.slint or chat-area.slint.
export component Sidebar inherits Rectangle {
    in property <[ThreadItem]> threads: [];
    in property <int> selected-thread: 0;
    in property <bool> compact: true;
    in property <bool> expanded: false;
    callback thread-selected(int);
    callback new-thread-requested();
    callback search-changed(string);
    callback toggle-expanded();
    callback thread-close-requested(int);
    callback thread-delete-requested(int);
    callback thread-archive-requested(int);
    callback settings-requested();

    // Two-step arm/confirm state for the sidebar row close/delete
    // controls -- same pattern as `settings_sheet.slint`'s
    // `profile-pending-delete`, keyed by row index (not name -- thread
    // names are not guaranteed unique) rather than an `in property`
    // since this is purely local UI state no Rust caller needs to
    // drive or observe.
    property <int> pending-close-index: -1;
    property <int> pending-delete-index: -1;

    // Per-thread identity accent -- deliberately the one departure from
    // this project's usual monochrome status language (see theme.slint's
    // note), scoped narrowly to "which thread is this" rather than "what
    // state is this thread in". Cycled by row index so it stays stable
    // as long as thread order doesn't change, with no per-thread color
    // field on `ThreadItem` itself to keep this a presentation-only
    // concern.
    property <[color]> thread-accent-colors: [
        #f43f5e, #f97316, #eab308, #22c55e,
        #06b6d4, #6366f1, #a855f7, #ec4899,
    ];
    function thread-accent(i: int) -> color {
        return thread-accent-colors[Math.mod(i, thread-accent-colors.length)];
    }

    // Reserve enough width for the active chat at the native 20%-width
    // dock target. The list remains selectable; secondary chat metadata
    // collapses in ChatArea when the remaining column is compact.
    width: expanded ? (compact ? 200px : 260px) : 48px;
    animate width { duration: 180ms; easing: ease-in-out; }
    background: Theme.bg-sidebar;

    // Settings footer: outer margin + box height. Main column ends above it
    // so the control always snaps to the bottom of the thread bar.
    property <length> settings-margin: Metrics.pad-sm;
    property <length> settings-box-h: compact ? 32px : 36px;
    property <length> settings-footer-h: settings-box-h + 2 * settings-margin;

    // Header + search + thread list only (fills space above settings).
    VerticalLayout {
        width: parent.width;
        height: parent.height - settings-footer-h;
        y: 0px;
        spacing: Metrics.space-5;
        Rectangle {
            height: 36px;
            background: Theme.bg-card;
            // Collapse / "Chats" / new-thread on one vertical midline.
            HorizontalLayout {
                width: 100%;
                height: 100%;
                padding-left: compact ? Metrics.space-2 : Metrics.space-4;
                padding-right: compact ? Metrics.space-2 : Metrics.space-4;
                spacing: compact ? 2px : 6px;
                IconButton {
                    button-accessible-label: expanded ? "Collapse thread sidebar" : "Expand thread sidebar";
                    clicked => { toggle-expanded(); }
                    Icon {
                        source: @image-url("../assets/icons/panel-left.svg");
                        size: 16px;
                        color: Theme.text-secondary;
                    }
                }
                if expanded : Text {
                    text: "Chats";
                    color: Theme.text-primary;
                    font-size: 14px * Theme.font-scale;
                    font-family: Theme.font-sans;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 0;
                }
                Rectangle {
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                    vertical-stretch: 0;
                    height: 0px;
                    preferred-height: 0px;
                }
                if expanded : IconButton {
                    button-accessible-label: "New thread";
                    clicked => { new-thread-requested(); }
                    Icon {
                        source: @image-url("../assets/icons/plus.svg");
                        size: 16px;
                        color: Theme.bg-primary;
                    }
                }
            }
        }
        Rectangle {
            height: 32px;
            background: Theme.bg-canvas;
            HorizontalLayout {
                padding: Metrics.space-3;
                spacing: Metrics.space-2;
                alignment: expanded ? stretch : center;
                VerticalLayout {
                    alignment: center;
                    Icon {
                        source: @image-url("../assets/icons/search.svg");
                        size: 13px;
                        color: Theme.text-muted;
                    }
                }
                // Always mounted (not `if expanded`) so Ctrl+K /
                // `focus-search()` can target it after the panel expands
                // the rail. Collapsed: invisible, no stretch.
                Rectangle {
                    horizontal-stretch: expanded ? 1 : 0;
                    preferred-width: 0px;
                    min-width: 0px;
                    visible: expanded;
                    clip: true;
                    // TextInput has no built-in placeholder support
                    // (that's std-widgets' LineEdit, which pulls in a
                    // heavier widget style dependency this crate doesn't
                    // otherwise use) -- a manually-overlaid Text shown
                    // only while empty reproduces the HTML's "Search
                    // active threads..." placeholder with no new deps.
                    Text {
                        text: "Search active threads...";
                        color: Theme.text-muted;
                        font-family: Theme.font-sans;
                        font-size: 11px * Theme.font-scale;
                        vertical-alignment: center;
                        visible: search-input.text == "";
                    }
                    search-input := TextInput {
                        accessible-label: "Search threads";
                        color: Theme.text-primary;
                        font-family: Theme.font-sans;
                        font-size: 11px * Theme.font-scale;
                        vertical-alignment: center;
                        edited => { search-changed(self.text); }
                    }
                }
            }
        }
        // Thread card: title row (+ optional model). No description line.
        Flickable {
            vertical-stretch: 1;
            preferred-height: 0px;
            min-height: 0px;
            viewport-height: thread-list-col.preferred-height;
            thread-list-col := VerticalLayout {
                spacing: Metrics.space-1;
                for thread[i] in threads : HoverSurface {
                    // Taller only when the model line is shown under the name.
                    height: expanded && thread.model != "" ? 52px : 44px;
                    idle-bg: Theme.bg-sidebar;
                    selected-bg: Theme.bg-chat;
                    selected: i == selected-thread;
                    button-accessible-label: thread.name;
                    clicked => { thread-selected(i); }
                    HorizontalLayout {
                        Rectangle {
                            width: 3px;
                            background: i == selected-thread ? Theme.bg-primary : transparent;
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            preferred-width: 0px;
                            min-width: 0px;
                            padding-left: compact ? Metrics.space-6 : Metrics.space-8;
                            padding-right: compact ? Metrics.space-6 : Metrics.space-8;
                            padding-top: Metrics.space-5;
                            padding-bottom: Metrics.space-5;
                            spacing: Metrics.space-3;
                            alignment: center;
                            HorizontalLayout {
                                spacing: Metrics.space-4;
                                // Left-end state icon: a spinner glyph while the thread
                                // is actively fetching (blink disabled for now -- static
                                // icon only), a raised-hand glyph when it needs user
                                // attention (error/awaiting input), otherwise the plain
                                // status dot this replaced.
                                state-icon-blink := Timer {
                                    interval: 500ms;
                                    running: false;
                                    triggered => { state-icon-lit = !state-icon-lit; }
                                }
                                property <bool> state-icon-lit: true;
                                if thread.status == "loading" : Icon {
                                    source: @image-url("../assets/icons/loader-circle.svg");
                                    size: 14px;
                                    color: Theme.bg-primary;
                                    opacity: state-icon-lit ? 1.0 : 0.3;
                                    animate opacity { duration: 200ms; }
                                }
                                if thread.status == "error" : Icon {
                                    source: @image-url("../assets/icons/hand.svg");
                                    size: 14px;
                                    color: Theme.text-secondary;
                                }
                                if thread.status != "loading" && thread.status != "error" : Rectangle {
                                    width: 6px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background: Theme.text-muted;
                                }
                                if expanded : Text {
                                    text: thread.name;
                                    color: i == selected-thread ? Theme.bg-primary : Theme.text-primary;
                                    font-size: 11px * Theme.font-scale;
                                    font-weight: 700;
                                    font-family: Theme.font-sans;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                    preferred-width: 0px;
                                    min-width: 0px;
                                }
                                if expanded && thread.background : Icon {
                                    source: @image-url("../assets/icons/moon.svg");
                                    size: Metrics.icon-sm;
                                    color: Theme.text-tertiary;
                                }
                                if expanded && !thread.background && i == selected-thread : Text {
                                    text: "ACTIVE";
                                    color: Theme.text-muted;
                                    font-size: 8px * Theme.font-scale;
                                    font-family: Theme.font-mono;
                                    vertical-alignment: center;
                                }
                                // Coverage Matrix `session/close`/
                                // `session/delete` row: explicit,
                                // confirm-gated lifecycle controls per
                                // thread row -- an open thread shows a
                                // close (power) icon, a closed one
                                // shows a delete (trash) icon instead,
                                // both armed by a first click and only
                                // acted on by a second, explicit
                                // confirm -- same two-step pattern as
                                // `settings_sheet.slint`'s profile
                                // delete control.
                                if expanded && !thread.closed && root.pending-close-index != i : IconButton {
                                    btn-width: 18px;
                                    btn-height: 18px;
                                    button-accessible-label: "Close thread " + thread.name;
                                    clicked => { root.pending-close-index = i; }
                                    Icon {
                                        source: @image-url("../assets/icons/power.svg");
                                        size: 13px;
                                        color: Theme.text-muted;
                                    }
                                }
                                if expanded && !thread.closed && root.pending-close-index == i : HorizontalLayout {
                                    spacing: Metrics.space-1;
                                    IconButton {
                                        btn-width: 18px;
                                        btn-height: 18px;
                                        button-accessible-label: "Confirm close thread " + thread.name;
                                        clicked => {
                                            root.pending-close-index = -1;
                                            root.thread-close-requested(i);
                                        }
                                        Icon {
                                            source: @image-url("../assets/icons/circle-check.svg");
                                            size: Metrics.icon-sm;
                                            color: Theme.bg-primary;
                                        }
                                    }
                                    IconButton {
                                        btn-width: 18px;
                                        btn-height: 18px;
                                        button-accessible-label: "Cancel close thread " + thread.name;
                                        clicked => { root.pending-close-index = -1; }
                                        Icon {
                                            source: @image-url("../assets/icons/x.svg");
                                            size: 13px;
                                            color: Theme.text-secondary;
                                        }
                                    }
                                }
                                if expanded && thread.closed && root.pending-delete-index != i : IconButton {
                                    btn-width: 18px;
                                    btn-height: 18px;
                                    button-accessible-label: "Delete thread " + thread.name;
                                    clicked => { root.pending-delete-index = i; }
                                    Icon {
                                        source: @image-url("../assets/icons/trash-2.svg");
                                        size: 13px;
                                        color: Theme.text-muted;
                                    }
                                }
                                if expanded && thread.closed && root.pending-delete-index == i : HorizontalLayout {
                                    spacing: Metrics.space-1;
                                    IconButton {
                                        btn-width: 18px;
                                        btn-height: 18px;
                                        button-accessible-label: "Confirm delete thread " + thread.name;
                                        clicked => {
                                            root.pending-delete-index = -1;
                                            root.thread-delete-requested(i);
                                        }
                                        Icon {
                                            source: @image-url("../assets/icons/circle-check.svg");
                                            size: Metrics.icon-sm;
                                            color: Theme.bg-primary;
                                        }
                                    }
                                    IconButton {
                                        btn-width: 18px;
                                        btn-height: 18px;
                                        button-accessible-label: "Cancel delete thread " + thread.name;
                                        clicked => { root.pending-delete-index = -1; }
                                        Icon {
                                            source: @image-url("../assets/icons/x.svg");
                                            size: 13px;
                                            color: Theme.text-secondary;
                                        }
                                    }
                                }
                                if expanded : IconButton {
                                    btn-width: 18px;
                                    btn-height: 18px;
                                    button-accessible-label: "Archive thread " + thread.name;
                                    clicked => { root.thread-archive-requested(i); }
                                    Icon {
                                        source: @image-url("../assets/icons/archive.svg");
                                        size: 13px;
                                        color: Theme.text-muted;
                                    }
                                }
                            }
                            // Phase 8: active model (provider · model when known).
                            if expanded && thread.model != "" : Text {
                                text: thread.provider != "" ? thread.provider + " \u{00B7} " + thread.model : thread.model;
                                color: Theme.text-muted;
                                font-size: 9px * Theme.font-scale;
                                font-family: Theme.font-mono;
                                overflow: elide;
                                horizontal-stretch: 1;
                                preferred-width: 0px;
                                min-width: 0px;
                            }
                        }
                        Rectangle {
                            width: 3px;
                            background: expanded ? transparent : root.thread-accent(i);
                        }
                    }
                }
            }
        }
    }

    // Settings — absolute bottom of the thread bar: margined box, bg + radius, no border.
    settings-footer := Rectangle {
        x: 0px;
        y: parent.height - self.height;
        width: parent.width;
        height: root.settings-footer-h;
        background: Theme.bg-sidebar;
        // Inset margin around the settings chip.
        settings-box := HoverSurface {
            x: root.settings-margin;
            y: root.settings-margin;
            width: parent.width - 2 * root.settings-margin;
            height: root.settings-box-h;
            idle-bg: Theme.bg-tertiary;
            selected: false;
            button-accessible-label: "Open settings";
            clicked => { root.settings-requested(); }
            border-width: 0px;
            border-radius: Theme.radius-md;
            HorizontalLayout {
                width: 100%;
                height: 100%;
                padding-left: Metrics.pad-sm;
                padding-right: Metrics.pad-sm;
                spacing: Metrics.gap-sm;
                alignment: expanded ? start : center;
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 0;
                    Icon {
                        source: @image-url("../assets/icons/settings.svg");
                        size: Metrics.icon-md;
                        color: Theme.text-secondary;
                    }
                }
                if expanded : Text {
                    text: "Settings";
                    color: Theme.text-secondary;
                    font-size: 11px * Theme.font-scale;
                    font-family: Theme.font-sans;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }
    }

    // Ctrl+K target -- focus the thread search box (expanded) so the
    // panel-level keybinding can jump here without re-finding the input.
    public function focus-search() {
        search-input.focus();
    }
}
