import { Theme } from "../tokens/theme.slint";
import { Metrics } from "../tokens/metrics.slint";
import { Icon } from "../base/icon.slint";
import { IconButton } from "../base/icon_button.slint";
import { HoverSurface } from "../base/hover.slint";
import { FilterSearchBar } from "../base/filter_search_bar.slint";
import { NamePromptDialog } from "../base/name_prompt_dialog.slint";
import { TextUtil } from "../base/text_util.slint";
import { CursorHost } from "../tokens/cursor_host.slint";
import { ThreadItem, SkillOption } from "../types.slint";
import { SidebarThreadRow } from "./sidebar_thread_row.slint";

// Thread list column -- Phase 2 of chat-panel-ui-theme-parity.md will
// extend this with a real search box + filtered model and a footer
// identity chip, without touching app.slint or chat-area.slint.
export component Sidebar inherits Rectangle {
    in property <[ThreadItem]> threads: [];
    in property <int> selected-thread: 0;
    // `thread_item_project_context` phase: the panel's current active
    // project, forwarded straight from ChatPanel -- compared per-row
    // against each thread's own project-path to decide badge visibility.
    in property <string> active-project-path: "";
    in property <bool> compact: true;
    in property <bool> narrow: false;
    in property <bool> expanded: false;
    // Aggregates thread-search's own FilterSearchBar.input-has-focus, the
    // per-row inline thread-rename TextInput, and the shared "new skill"
    // NamePromptDialog -- see that property's doc comment for why this
    // needs re-exposing at every component boundary up to the root gate
    // in app.slint. Without rename-input-has-focus/new-skill-dialog.has-focus
    // here, both renaming a thread and naming a new skill would silently
    // drop every typed keystroke (TextField.has-focus's doc comment names
    // the exact same failure mode).
    out property <bool> search-has-focus:
        thread-search.input-has-focus
        || rename-input-has-focus
        || new-skill-dialog.has-focus;
    // rename-input lives inside a `for thread[i] in threads` repeater, so
    // there's no single element id to reference from search-has-focus
    // above -- only ever one row is in rename mode at a time
    // (rename-thread-index gates it), so each row's own `changed
    // has-focus` handler converging this property nets out correctly.
    property <bool> rename-input-has-focus: false;
    callback thread-selected(int);
    callback new-thread-requested();
    callback search-changed(string);
    callback toggle-expanded();
    callback collapse-requested();
    // Force the rail open (no-op if already expanded). Used by the
    // search-icon click and by callers that must not toggle-close.
    callback expand-requested();
    callback thread-close-requested(int);
    callback thread-delete-requested(int);
    callback thread-archive-requested(int);
    callback thread-rename-started(int);
    callback thread-rename-cancelled();
    callback thread-rename-confirmed(int, string);
    callback search-submitted(string, bool, bool);
    callback settings-requested();
    callback skills-settings-requested();

    // Skill-manager sidebar mode -- `sidebar_skill_tree_and_new_skill_flow`
    // phase. `skill-mode` sibling-swaps the thread list for a skill list
    // in this same column, rather than a separate panel, matching
    // `assistant-sidebar refine`'s "thread view + skill-manager" ask.
    in-out property <bool> skill-mode: false;
    in property <[SkillOption]> skills: [];
    // Project skills are the primary list. This control adds global skills
    // to the current project view; it is not a mutually-exclusive scope tab.
    property <bool> show-global-skills: false;
    in-out property <string> search-query: "";
    // Fired with the user-entered name and selected scope once the
    // dialog is confirmed; Rust creates the scaffolded SKILL.md and
    // re-scans the matching storage directory.
    callback new-skill-requested(string, string);
    property <bool> new-skill-dialog-open: false;
    // `active_pane_and_editor_view` phase: fired with a skill's path
    // when its row is clicked, so the host can switch the main content
    // area to the skill editor.
    callback skill-selected(string);

    // Two-step arm/confirm state for the sidebar row close/delete
    // controls -- same pattern as `settings_sheet.slint`'s
    // `profile-pending-delete`, keyed by row index (not name -- thread
    // names are not guaranteed unique) rather than an `in property`
    // since this is purely local UI state no Rust caller needs to
    // drive or observe.
    property <int> pending-close-index: -1;
    property <int> pending-delete-index: -1;
    in-out property <int> rename-thread-index: -1;
    in property <string> rename-focus-target: "";
    property <int> rename-focus-index: -1;
    in-out property <string> rename-thread-draft: "";

    function begin-thread-rename(index: int) {
        if (index < 0 || index >= root.threads.length) {
            return;
        }
        root.thread-rename-started(index);
    }

    function cancel-thread-rename() {
        root.rename-focus-index = -1;
        root.thread-rename-cancelled();
    }

    function confirm-thread-rename(index: int) {
        if (root.rename-thread-draft != "") {
            root.thread-rename-confirmed(index, root.rename-thread-draft);
        }
    }

    changed rename-thread-index => {
        if (root.rename-thread-index >= 0 && root.rename-focus-target == "sidebar") {
            root.rename-focus-index = root.rename-thread-index;
        }
    }

    // Per-thread identity accent -- deliberately the one departure from
    // this project's usual monochrome status language (see theme.slint's
    // note), scoped narrowly to "which thread is this" rather than "what
    // state is this thread in". Cycled by row index so it stays stable
    // as long as thread order doesn't change, with no per-thread color
    // field on `ThreadItem` itself to keep this a presentation-only
    // concern.
    property <[color]> thread-accent-colors: [
        #f43f5e, #f97316, #eab308, #22c55e,
        #06b6d4, #6366f1, #a855f7, #ec4899,
    ];
    function thread-accent(i: int) -> color {
        return thread-accent-colors[Math.mod(i, thread-accent-colors.length)];
    }

    // Reserve enough width for the active chat at the native 20%-width
    // dock target. The list remains selectable; secondary chat metadata
    // collapses in ChatArea when the remaining column is compact.
    width: expanded ? (compact ? 200px : 260px) : 48px;
    animate width { duration: 180ms; easing: ease-in-out; }
    background: Theme.bg-sidebar;

    // Settings footer: inset + box height. The inset positions its icon
    // center on ChatInputLayout's second-row center line (36px above the
    // panel bottom) in both compact and regular layouts.
    property <length> settings-margin: compact
        ? Metrics.pad-lg + Metrics.space-2
        : Metrics.pad-lg + Metrics.space-1;
    property <length> settings-box-h: compact ? 32px : 36px;
    property <length> skills-config-h: skill-mode && expanded ? 32px : 0px;
    // When Skills config is present, use the same inset above it, between
    // it and Settings, and below Settings.
    property <length> settings-footer-h: skills-config-h > 0px
        ? skills-config-h + settings-box-h + 3 * settings-margin
        : settings-box-h + 2 * settings-margin;

    // Header + search + thread list only (fills space above settings).
    VerticalLayout {
        width: parent.width;
        height: parent.height - settings-footer-h;
        y: 0px;
        // In collapsed mode, a small tokenized gap plus centered glyph
        // aligns its top edge with ChatArea's 48px header divider. The
        // expanded search field keeps the roomier separation.
        spacing: expanded ? Metrics.space-5 : Metrics.space-1;
        Rectangle {
            height: 36px;
            background: Theme.bg-card;
            // Collapse / "Chats" / new-thread on one vertical midline.
            HorizontalLayout {
                width: 100%;
                height: 100%;
                padding-left: compact ? Metrics.space-2 : Metrics.space-4;
                padding-right: compact ? Metrics.space-2 : Metrics.space-4;
                spacing: compact ? 2px : 6px;
                if !expanded : VerticalLayout {
                    width: 100%;
                    height: parent.height;
                    alignment: center;
                    HorizontalLayout {
                        alignment: center;
                        sidebar-toggle := IconButton {
                            button-accessible-label: "Expand thread sidebar";
                            clicked => { toggle-expanded(); }
                            Icon {
                                source: @image-url("../assets/icons/panel-left.svg");
                                size: 16px;
                                color: Theme.text-secondary;
                            }
                        }
                    }
                }
                if expanded : VerticalLayout {
                    horizontal-stretch: 0;
                    height: parent.height;
                    alignment: center;
                    sidebar-toggle-collapse := IconButton {
                        button-accessible-label: "Collapse thread sidebar";
                        clicked => { toggle-expanded(); }
                        Icon {
                            source: @image-url("../assets/icons/panel-left.svg");
                            size: 16px;
                            color: Theme.text-secondary;
                        }
                    }
                }
                if expanded : VerticalLayout {
                    horizontal-stretch: 0;
                    height: parent.height;
                    alignment: center;
                    Text {
                        text: skill-mode ? "Skills" : "Chats";
                        color: Theme.text-primary;
                        font-size: 14px * Theme.font-scale;
                        font-family: Theme.font-sans;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                    vertical-stretch: 0;
                    height: 0px;
                    preferred-height: 0px;
                }
                if expanded && !skill-mode : VerticalLayout {
                    horizontal-stretch: 0;
                    height: parent.height;
                    alignment: center;
                    IconButton {
                        button-accessible-label: "New thread";
                        clicked => { new-thread-requested(); }
                        Icon {
                            source: @image-url("../assets/icons/plus.svg");
                            size: 16px;
                            color: Theme.bg-primary;
                        }
                    }
                }
                if expanded && skill-mode : VerticalLayout {
                    horizontal-stretch: 0;
                    height: parent.height;
                    alignment: center;
                    IconButton {
                        button-accessible-label: "New skill";
                        clicked => { new-skill-dialog-open = true; }
                        Icon {
                            source: @image-url("../assets/icons/plus.svg");
                            size: 16px;
                            color: Theme.bg-primary;
                        }
                    }
                }
            }
        }
        // Threads / Skills tab row -- `assistant-sidebar refine`'s
        // "thread view + skill-manager" sibling-mode switch.
        if expanded : Rectangle {
            height: 28px;
            background: Theme.bg-canvas;
            HorizontalLayout {
                padding-left: Metrics.space-3;
                padding-right: Metrics.space-3;
                spacing: Metrics.space-3;
                threads-tab := TouchArea {
                    mouse-cursor: pointer;
                    accessible-role: button;
                    accessible-label: "Show threads";
                    // Every other interactive control in this file (HoverSurface,
                    // IconButton, Button) wires accessible-action-default
                    // alongside clicked -- this TouchArea and skills-tab below
                    // were missing it, so a keyboard/screen-reader "activate"
                    // was a silent no-op despite both being fully labelled and
                    // roled as buttons (found via a real e2e test never
                    // switching skill-mode).
                    accessible-action-default => { skill-mode = false; }
                    clicked => { skill-mode = false; }
                    changed has-hover => { CursorHost.kind = self.has-hover ? "pointer" : "default"; }
                    Text {
                        text: "Threads";
                        color: !skill-mode ? Theme.bg-primary : Theme.text-muted;
                        font-size: 11px * Theme.font-scale;
                        font-weight: !skill-mode ? 700 : 400;
                        vertical-alignment: center;
                    }
                }
                skills-tab := TouchArea {
                    mouse-cursor: pointer;
                    accessible-role: button;
                    accessible-label: "Show skills";
                    accessible-action-default => { skill-mode = true; }
                    clicked => { skill-mode = true; }
                    changed has-hover => { CursorHost.kind = self.has-hover ? "pointer" : "default"; }
                    Text {
                        text: "Skills";
                        color: skill-mode ? Theme.bg-primary : Theme.text-muted;
                        font-size: 11px * Theme.font-scale;
                        font-weight: skill-mode ? 700 : 400;
                        vertical-alignment: center;
                    }
                }
            }
        }
        // Project skills stay visible by default. Global skills can be
        // included in the list without replacing the current project view.
        if expanded && skill-mode : Rectangle {
            height: 28px;
            background: Theme.bg-canvas;
            HorizontalLayout {
                padding-left: Metrics.space-3;
                padding-right: Metrics.space-3;
                spacing: Metrics.space-2;
                show-global-skills-touch := TouchArea {
                    mouse-cursor: pointer;
                    horizontal-stretch: 0;
                    accessible-role: button;
                    accessible-label: root.show-global-skills
                        ? "Hide global skills"
                        : "Show global skills";
                    accessible-action-default => { root.show-global-skills = !root.show-global-skills; }
                    clicked => { root.show-global-skills = !root.show-global-skills; }
                    Rectangle {
                        height: 24px;
                        background: root.show-global-skills || show-global-skills-touch.has-hover
                            ? Theme.bg-primary-container
                            : transparent;
                        animate background { duration: 100ms; }
                        border-radius: Theme.radius-sm;
                        HorizontalLayout {
                            padding-left: Metrics.space-2;
                            padding-right: Metrics.space-2;
                            spacing: Metrics.space-1;
                            Text {
                                text: "Show global skills";
                                color: root.show-global-skills || show-global-skills-touch.has-hover
                                    ? Theme.text-primary
                                    : Theme.text-secondary;
                                font-size: 10px * Theme.font-scale;
                                font-weight: root.show-global-skills ? 700 : 400;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
        Rectangle {
            height: 32px;
            // Collapsed rail: whole row is hit target (ui.yaml thread-view).
            background: !expanded && search-rail-hit.has-hover
                ? Theme.bg-primary-container
                : Theme.bg-canvas;
            animate background { duration: 100ms; }

            search-rail-hit := TouchArea {
                width: expanded ? 0px : parent.width;
                height: expanded ? 0px : parent.height;
                enabled: !expanded;
                mouse-cursor: pointer;
                accessible-role: button;
                accessible-label: "Expand sidebar and search threads";
                accessible-action-default => { root.open-search(); }
                clicked => { root.open-search(); }
            }
            // Collapsed: centered search glyph in the rail.
            if !expanded : VerticalLayout {
                width: 100%;
                height: 100%;
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Icon {
                        source: @image-url("../assets/icons/search.svg");
                        size: Metrics.icon-sm;
                        color: search-rail-hit.has-hover ? Theme.text-primary : Theme.text-muted;
                    }
                }
            }

            // Expanded: shared FilterSearchBar (same base as settings /
            // mention / dropdown). Always mounted so focus-search() works
            // after expand; hidden when collapsed. Cursor-kind reporting
            // (pointer/text) lives inside FilterSearchBar itself.
            thread-search := FilterSearchBar {
                x: Metrics.space-3;
                y: (parent.height - self.height) / 2;
                width: parent.width - 2 * Metrics.space-3;
                visible: expanded;
                // Keep mounted for focus-search even when not visible.
                placeholder: skill-mode ? "Search skills..." : "Search active threads...";
                bar-accessible-label: skill-mode ? "Search skills" : "Search threads";
                show-icon: true;
                icon-trailing: true;
                bar-height: 28px;
                bar-bg: Theme.bg-sidebar;
                query <=> root.search-query;
                edited => { search-changed(self.query); }
                icon-clicked => { root.open-search(); }
                key-pressed(event) => {
                    if (event.text == Key.Return) {
                        root.search-submitted(
                            root.search-query,
                            root.skill-mode,
                            root.show-global-skills,
                        );
                        return EventResult.accept;
                    }
                    return EventResult.reject;
                }
            }
        }
        // Skill list -- file-tree-flat row per discovered skill (name,
        // description, scope badge, started-from provenance). No
        // selection/open wiring yet (`active_pane_and_editor_view`
        // phase's job); this phase is discovery + the new-skill flow.
        if skill-mode : Flickable {
            vertical-stretch: 1;
            preferred-height: 0px;
            min-height: 0px;
            viewport-height: skill-list-col.preferred-height;
            skill-list-col := VerticalLayout {
                spacing: Metrics.space-1;
                for skill in skills : HoverSurface {
                    property <bool> row-visible: (skill.scope == "project"
                        || root.show-global-skills)
                        && TextUtil.matches-filter(
                            skill.name + "\n" + skill.description,
                            root.search-query,
                        );
                    height: row-visible ? (expanded ? 48px : 32px) : 0px;
                    width: 100%;
                    visible: row-visible;
                    clip: true;
                    idle-bg: Theme.bg-sidebar;
                    selected-bg: Theme.bg-chat;
                    selected: false;
                    button-accessible-label: "Open skill " + skill.name;
                    clicked => { root.skill-selected(skill.path); }
                    double-clicked => {
                        if (root.expanded) {
                            root.collapse-requested();
                        }
                    }
                    // Collapsed rail: name only, elide overflow (no scope
                    // chips — they force the row past 48px and kill elide).
                    VerticalLayout {
                        width: 100%;
                        height: 100%;
                        padding-left: expanded
                            ? (compact ? Metrics.space-6 : Metrics.space-8)
                            : Metrics.space-2;
                        padding-right: expanded
                            ? (compact ? Metrics.space-6 : Metrics.space-8)
                            : Metrics.space-2;
                        padding-top: expanded ? Metrics.space-3 : 0px;
                        padding-bottom: expanded ? Metrics.space-3 : 0px;
                        alignment: center;
                        HorizontalLayout {
                            width: 100%;
                            spacing: Metrics.space-3;
                            alignment: expanded ? stretch : center;
                            cross-axis-alignment: center;
                            Text {
                                text: skill.name;
                                color: Theme.text-primary;
                                font-size: (expanded ? 11px : 9px) * Theme.font-scale;
                                font-family: Theme.font-sans;
                                font-weight: 600;
                                vertical-alignment: center;
                                horizontal-alignment: expanded ? left : center;
                                horizontal-stretch: 1;
                                preferred-width: 0px;
                                min-width: 0px;
                                overflow: elide;
                            }
                            if expanded && skill.scope == "project" && skill.started-from != "" : Text {
                                text: "\u{2192} " + skill.started-from;
                                color: Theme.text-tertiary;
                                font-size: 9px * Theme.font-scale;
                                font-family: Theme.font-mono;
                                vertical-alignment: center;
                                horizontal-stretch: 0;
                                overflow: elide;
                                max-width: 72px;
                            }
                            if expanded : Text {
                                text: skill.scope;
                                color: Theme.text-muted;
                                font-size: 9px * Theme.font-scale;
                                font-family: Theme.font-mono;
                                vertical-alignment: center;
                                horizontal-stretch: 0;
                            }
                        }
                        if expanded && skill.description != "" : Text {
                            text: skill.description;
                            color: Theme.text-muted;
                            font-size: 10px * Theme.font-scale;
                            font-family: Theme.font-sans;
                            horizontal-stretch: 1;
                            preferred-width: 0px;
                            min-width: 0px;
                            overflow: elide;
                        }
                    }
                }
            }
        }
        // Thread lists: active threads fill the top (scrollable);
        // archived threads pin to a bottom section with a max height
        // so they never push active rows off the top of the rail.
        if !skill-mode : VerticalLayout {
            vertical-stretch: 1;
            preferred-height: 0px;
            min-height: 0px;
            spacing: 0px;

            // --- Active (and, when collapsed, all) threads -------------
            Flickable {
                vertical-stretch: 1;
                preferred-height: 0px;
                min-height: 0px;
                viewport-height: active-thread-col.preferred-height;
                active-thread-col := VerticalLayout {
                    spacing: Metrics.space-1;
                    for thread[i] in threads : active-row := SidebarThreadRow {
                        // Expanded: hide archived here (they live below).
                        // Collapsed: keep every thread so rail icons remain.
                        property <bool> show-here: !root.expanded || !thread.archived;
                        height: show-here
                            ? (root.expanded && thread.model != "" ? 52px : 44px)
                            : 0px;
                        visible: show-here;
                        width: 100%;
                        thread: thread;
                        index: i;
                        selected-thread: root.selected-thread;
                        expanded: root.expanded;
                        compact: root.compact;
                        active-project-path: root.active-project-path;
                        rename-thread-index: root.rename-thread-index;
                        rename-thread-draft <=> root.rename-thread-draft;
                        rename-focus-index <=> root.rename-focus-index;
                        pending-close-index <=> root.pending-close-index;
                        pending-delete-index <=> root.pending-delete-index;
                        accent-color: root.thread-accent(i);
                        show-archived-badge: true;
                        show-archive-action: true;
                        row-selected => { root.thread-selected(i); }
                        collapse-if-expanded => {
                            if (root.expanded) {
                                root.collapse-requested();
                            }
                        }
                        begin-rename => { root.begin-thread-rename(i); }
                        confirm-rename => { root.confirm-thread-rename(i); }
                        cancel-rename => { root.cancel-thread-rename(); }
                        close-requested => { root.thread-close-requested(i); }
                        delete-requested => { root.thread-delete-requested(i); }
                        archive-requested => { root.thread-archive-requested(i); }
                        rename-focus-changed(has-focus) => {
                            root.rename-input-has-focus = has-focus;
                        }
                    }
                }
            }

            // --- Archived (bottom, expanded only, max-height) ----------
            // Caps at ~header + 3 tall rows so active list keeps majority
            // of the rail. Section collapses entirely when empty.
            if root.expanded : VerticalLayout {
                vertical-stretch: 0;
                spacing: 0px;
                // Header + up to ~3 model-rows of content.
                max-height: 22px + 156px;

                archived-header := Rectangle {
                    height: archived-thread-col.preferred-height > 0px ? 22px : 0px;
                    visible: archived-thread-col.preferred-height > 0px;
                    width: 100%;
                    background: Theme.bg-canvas;
                    HorizontalLayout {
                        padding-left: Metrics.space-3;
                        padding-right: Metrics.space-3;
                        spacing: Metrics.space-2;
                        Text {
                            text: "Archived";
                            color: Theme.text-muted;
                            font-size: 10px * Theme.font-scale;
                            font-weight: 700;
                            font-family: Theme.font-sans;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Icon {
                            source: @image-url("../assets/icons/archive.svg");
                            size: 12px;
                            color: Theme.text-muted;
                        }
                    }
                }

                Flickable {
                    vertical-stretch: 0;
                    // Grow with content up to 3 rows, then scroll.
                    // Prefer content height; cap via max-height only (do not
                    // also bind `height` -- Slint rejects height+max-height).
                    preferred-height: archived-thread-col.preferred-height;
                    max-height: 156px;
                    min-height: 0px;
                    visible: archived-thread-col.preferred-height > 0px;
                    viewport-height: archived-thread-col.preferred-height;
                    archived-thread-col := VerticalLayout {
                        spacing: Metrics.space-1;
                        for thread[i] in threads : archived-row := SidebarThreadRow {
                            property <bool> show-here: thread.archived;
                            height: show-here
                                ? (thread.model != "" ? 52px : 44px)
                                : 0px;
                            visible: show-here;
                            width: 100%;
                            thread: thread;
                            index: i;
                            selected-thread: root.selected-thread;
                            expanded: true;
                            compact: root.compact;
                            active-project-path: root.active-project-path;
                            rename-thread-index: root.rename-thread-index;
                            rename-thread-draft <=> root.rename-thread-draft;
                            rename-focus-index <=> root.rename-focus-index;
                            pending-close-index <=> root.pending-close-index;
                            pending-delete-index <=> root.pending-delete-index;
                            accent-color: root.thread-accent(i);
                            // Already in the Archived section.
                            show-archived-badge: false;
                            show-archive-action: false;
                            row-selected => { root.thread-selected(i); }
                            collapse-if-expanded => {
                                if (root.expanded) {
                                    root.collapse-requested();
                                }
                            }
                            begin-rename => { root.begin-thread-rename(i); }
                            confirm-rename => { root.confirm-thread-rename(i); }
                            cancel-rename => { root.cancel-thread-rename(); }
                            close-requested => { root.thread-close-requested(i); }
                            delete-requested => { root.thread-delete-requested(i); }
                            archive-requested => { }
                            rename-focus-changed(has-focus) => {
                                root.rename-input-has-focus = has-focus;
                            }
                        }
                    }
                }
            }
        }
    }

    // Skills config sits directly above Settings in the Skills sidebar.
    settings-footer := Rectangle {
        x: 0px;
        y: parent.height - self.height;
        width: parent.width;
        height: root.settings-footer-h;
        background: Theme.bg-sidebar;
        if root.skills-config-h > 0px : skills-config := HoverSurface {
            x: root.settings-margin;
            y: root.settings-margin;
            width: parent.width - 2 * root.settings-margin;
            height: root.skills-config-h;
            idle-bg: transparent;
            selected: false;
            button-accessible-label: "Open Skills settings";
            clicked => { root.skills-settings-requested(); }
            border-width: 0px;
            border-radius: Theme.radius-md;
            HorizontalLayout {
                width: 100%;
                height: 100%;
                padding-left: Metrics.pad-sm;
                padding-right: Metrics.pad-sm;
                spacing: Metrics.gap-sm;
                cross-axis-alignment: center;
                Text {
                    text: "Skills config";
                    color: Theme.text-secondary;
                    font-size: 10px * Theme.font-scale;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Icon {
                    source: @image-url("../assets/icons/chevron-right.svg");
                    size: Metrics.icon-sm;
                    color: Theme.text-muted;
                }
            }
        }
        // Expanded: full-width settings row with the normal hover surface.
        if expanded : settings-box := HoverSurface {
            x: root.settings-margin;
            y: root.skills-config-h > 0px
                ? root.skills-config-h + 2 * root.settings-margin
                : root.settings-margin;
            width: parent.width - 2 * root.settings-margin;
            height: root.settings-box-h;
            idle-bg: Theme.bg-tertiary;
            selected: false;
            button-accessible-label: "Open settings";
            clicked => { root.settings-requested(); }
            border-width: 0px;
            border-radius: Theme.radius-md;
            HorizontalLayout {
                width: 100%;
                height: 100%;
                padding-left: Metrics.pad-sm;
                padding-right: Metrics.pad-sm;
                spacing: Metrics.gap-sm;
                alignment: start;
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 0;
                    Icon {
                        source: @image-url("../assets/icons/settings.svg");
                        size: Metrics.icon-md;
                        color: Theme.text-secondary;
                    }
                }
                Text {
                    text: "Settings";
                    color: Theme.text-secondary;
                    font-size: 11px * Theme.font-scale;
                    font-family: Theme.font-sans;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }
        // Collapsed: use the same icon-button primitive as the header.
        // The expanded row's horizontal padding cannot fit a 48px rail,
        // which made both its background and hover hit area look broken.
        if !expanded : IconButton {
            x: (parent.width - self.width) / 2;
            y: root.skills-config-h > 0px
                ? root.skills-config-h + 2 * root.settings-margin
                    + (root.settings-box-h - self.height) / 2
                : (parent.height - self.height) / 2;
            btn-width: 28px;
            btn-height: 28px;
            button-accessible-label: "Open settings";
            clicked => { root.settings-requested(); }
            Icon {
                source: @image-url("../assets/icons/settings.svg");
                size: Metrics.icon-md;
                color: Theme.text-secondary;
            }
        }
    }

    // Ctrl+K / search-icon target -- focus the thread search box so the
    // panel-level keybinding and the collapsed-rail search button can
    // jump here without re-finding the input.
    public function focus-search() {
        thread-search.focus-input();
    }

    // Expand the rail if needed, then put keyboard focus in the filter.
    // Uses `expand-requested` (not toggle) so an already-open sidebar
    // never bounces closed. Focus runs after a short delay so the width
    // animation + `visible: expanded` on the TextInput have applied
    // (same-frame focus on a still-hidden input is a no-op).
    property <bool> pending-search-focus: false;
    search-focus-delay := Timer {
        interval: 200ms;
        running: pending-search-focus;
        triggered => {
            pending-search-focus = false;
            thread-search.focus-input();
        }
    }
    public function open-search() {
        if (!expanded) {
            pending-search-focus = true;
            expand-requested();
        } else {
            thread-search.focus-input();
        }
    }

    // Shared NamePromptDialog (base/) -- cursor-kind reporting (pointer/
    // text) lives inside it, so this call site inherits it.
    new-skill-dialog := NamePromptDialog {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        open <=> root.new-skill-dialog-open;
        title: "New skill";
        field-accessible-label: "New skill name";
        confirm-label: "Create";
        // Prefer a project-local skill when a project is open so the new
        // entry is visible under the default sidebar filter (project
        // skills always show; global skills need the "Show global
        // skills" toggle). Fall back to global when no project is open
        // -- hard-coding "project" used to fail CreateSkill with
        // "cannot create a project skill without an open project", so
        // the dialog closed, nothing was written, and the list never
        // gained the skill (setup-followups skill_not_listed_after_creation).
        confirmed(name) => {
            if (root.active-project-path == "") {
                // Make the new global skill visible immediately rather
                // than requiring a separate toggle discovery.
                root.show-global-skills = true;
                root.new-skill-requested(name, "global");
            } else {
                root.new-skill-requested(name, "project");
            }
        }
    }
}
