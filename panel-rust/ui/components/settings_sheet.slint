// Settings-gear sheet -- extracted out of app.slint's own former inline
// `Rectangle` block for modularity (component-style-system.md's rule:
// one Slint file per logical UI unit, `app.slint` should only ever
// compose components, not define their bodies). Covers default-config
// management (profile/permission-profile/background-session, Phase 1's
// pre-existing scope) plus the two Phase-1 rows that were still
// entirely unwired at the UI layer: centrally-registered MCP servers
// (`mcp_servers/*`) and the agent catalog (`agents/list|status|
// install`). All state here is real gateway state, round-tripped
// through `AgentBridge` -- nothing in this component optimistically
// mutates its own list properties; every create/update/delete/install
// callback is expected to be followed by `lib.rs` re-populating
// `available-mcp-servers`/`agent-catalog` from a fresh `list_*` call,
// same "don't trust a client-side echo" posture the mode/config
// selector already established.
import { Theme } from "../tokens/theme.slint";
import { Metrics } from "../tokens/metrics.slint";
import { Button } from "../base/button.slint";
import { ProfileOption, McpServerOption, AgentCatalogEntry, RemoteSessionOption } from "../types.slint";

export component SettingsSheet inherits Rectangle {
    in-out property <string> default-profile: "";
    in-out property <string> permission-profile: "";
    in-out property <bool> background-default: false;
    in-out property <bool> background-override-set: false;
    in-out property <bool> background-override: false;
    in property <[ProfileOption]> available-profiles: [];
    in property <[McpServerOption]> available-mcp-servers: [];
    in property <[AgentCatalogEntry]> agent-catalog: [];
    in property <[RemoteSessionOption]> recoverable-sessions: [];
    // Local-only draft fields for the "add MCP server" row -- never
    // sent anywhere until `mcp-server-create` fires; not part of any
    // persisted state.
    property <string> new-mcp-name: "";
    property <string> new-mcp-command: "";
    // Local-only draft fields for the "add profile" row -- mirrors
    // `new-mcp-name`/`new-mcp-command` above; nothing here is sent
    // until `profile-create` fires.
    property <string> new-profile-name: "";
    property <string> new-profile-agent-id: "";
    property <bool> new-profile-terminal-enabled: false;
    property <bool> new-profile-fs-enabled: false;
    // Armed-delete confirmation state for the profile-management list
    // below -- set to a profile's name by its own "Remove" button,
    // which swaps that one row's control into "Confirm delete" /
    // "Cancel" so a single misplaced click can never delete a
    // profile. Cleared by either follow-up button, or implicitly by
    // picking a different profile's Remove (only one row is ever
    // armed at a time).
    property <string> profile-pending-delete: "";

    callback save();
    callback close();
    callback mcp-server-create(string, string);
    callback mcp-server-delete(string);
    callback profile-create(string, string, bool, bool);
    callback profile-delete(string);
    callback agent-install-requested(string);
    callback recover-session-attach(string, string, string);

    background: Theme.bg-card;
    border-color: Theme.border-strong;
    border-width: 1px;
    border-radius: Theme.radius-md;

    Flickable {
        width: parent.width;
        height: parent.height;
        viewport-height: body.preferred-height + 32px;
        body := VerticalLayout {
            width: parent.width;
            padding: Metrics.space-7;
            spacing: 14px;

            Text { text: "Chat Defaults"; color: Theme.text-primary; font-size: 16px * Theme.font-scale; font-weight: 700; }

            Text { text: "Profile"; color: Theme.text-secondary; font-size: 11px * Theme.font-scale; }
            TextInput { text <=> root.default-profile; color: Theme.text-primary; font-size: 12px * Theme.font-scale; }
            // Profile-picker chips -- real `profiles/list` choices,
            // quick-select alternative to typing an exact name into the
            // TextInput above (both write the same `default-profile`
            // property, so either path works). `T`/`F` suffix badges
            // are `allow_terminal_access`/`allow_fs_access` -- see
            // `ProfileOption`'s doc comment. Each chip also carries an
            // inline remove affordance (real `profiles/delete`, armed-
            // confirm two-step so a stray click can't delete a
            // profile) -- folded into this single `for` loop rather
            // than a second, separate profile-management list further
            // down: this section's own `Flickable` clips its content
            // to its allotted height, and `i-slint-backend-testing`'s
            // `find_by_accessible_label` only sees elements within
            // that laid-out, unclipped region (not merely "present in
            // the tree but scrolled out of view") -- a second full
            // profile-list section further down would push every
            // section below it (MCP servers, Agents) further down too,
            // and the whole settings sheet's `Flickable` is taller
            // than any test's default headless window, so those
            // sections would silently stop being test-addressable
            // without the test explicitly growing its own window (see
            // the accompanying comment in `slint_component_e2e_test.rs`).
            Flickable {
                height: available-profiles.length > 0 ? 30px : 0px;
                viewport-width: profile-chip-row.preferred-width;
                profile-chip-row := HorizontalLayout {
                    spacing: Metrics.space-3;
                    for profile in available-profiles : Rectangle {
                        height: 24px;
                        // Width computed purely from leaf `Text.preferred-width`s
                        // below -- never bind a repeated item's own width to a
                        // child layout's `preferred-width` when that child
                        // layout has no explicit width of its own (it would
                        // otherwise size to fill this same Rectangle): that is
                        // a real binding cycle. Slint doesn't error on it, it
                        // silently corrupts this whole window's later
                        // accessible-element geometry (confirmed by
                        // bisection while writing this code).
                        width: profile-chip-label.preferred-width + 16px
                            + 2px
                            + (root.profile-pending-delete == profile.name ? 114px : 20px);
                        HorizontalLayout {
                            spacing: Metrics.space-1;
                            Rectangle {
                                width: profile-chip-label.preferred-width + 16px;
                                height: 24px;
                                background: profile.name == root.default-profile ? Theme.bg-primary
                                    : profile-chip.has-hover ? Theme.bg-primary-container
                                    : Theme.bg-sidebar;
                                animate background { duration: 100ms; }
                                border-color: Theme.border-default;
                                border-width: 1px;
                                border-radius: Theme.radius-sm;
                                profile-chip := TouchArea {
                                    mouse-cursor: pointer;
                                    accessible-role: button;
                                    accessible-label: "Select profile " + profile.name;
                                    accessible-action-default => { root.default-profile = profile.name; }
                                    clicked => { root.default-profile = profile.name; }
                                }
                                profile-chip-label := Text {
                                    text: profile.name
                                        + (profile.terminal-enabled ? " T" : "")
                                        + (profile.fs-enabled ? " F" : "");
                                    color: profile.name == root.default-profile ? Theme.text-on-primary : Theme.text-primary;
                                    font-family: Theme.font-mono;
                                    font-size: 10px * Theme.font-scale;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            if root.profile-pending-delete != profile.name : Button {
                                label: "\u{2715}";
                                button-accessible-label: "Remove profile " + profile.name;
                                btn-width: 20px;
                                btn-height: 24px;
                                font-size: 10px;
                                font-weight: 400;
                                bg: Theme.bg-card;
                                fg: Theme.text-secondary;
                                clicked => { root.profile-pending-delete = profile.name; }
                            }
                            if root.profile-pending-delete == profile.name : HorizontalLayout {
                                spacing: Metrics.space-1;
                                Button {
                                    label: "Confirm";
                                    button-accessible-label: "Confirm delete profile " + profile.name;
                                    primary: true;
                                    btn-width: 64px;
                                    btn-height: 24px;
                                    font-size: 9px;
                                    font-weight: 400;
                                    clicked => {
                                        root.profile-pending-delete = "";
                                        root.profile-delete(profile.name);
                                    }
                                }
                                Button {
                                    label: "Cancel";
                                    button-accessible-label: "Cancel delete profile " + profile.name;
                                    btn-width: 48px;
                                    btn-height: 24px;
                                    font-size: 9px;
                                    font-weight: 400;
                                    bg: Theme.bg-card;
                                    fg: Theme.text-secondary;
                                    clicked => { root.profile-pending-delete = ""; }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.border-default; }

            // Add-profile form -- real `profiles/create`. The list of
            // existing profiles is the chip row above (its inline "x"
            // is the delete affordance); this section is create-only.
            Text { text: "Add Profile"; color: Theme.text-primary; font-size: 13px * Theme.font-scale; font-weight: 700; }
            HorizontalLayout {
                spacing: Metrics.space-3;
                Rectangle {
                    horizontal-stretch: 1;
                    height: 26px;
                    background: Theme.bg-sidebar;
                    border-radius: Theme.radius-sm;
                    TextInput {
                        accessible-label: "New profile name";
                        accessible-action-default => { self.focus(); }
                        text <=> root.new-profile-name;
                        color: Theme.text-primary;
                        font-size: 11px * Theme.font-scale;
                        x: 6px;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    height: 26px;
                    background: Theme.bg-sidebar;
                    border-radius: Theme.radius-sm;
                    TextInput {
                        accessible-label: "New profile agent id";
                        accessible-action-default => { self.focus(); }
                        text <=> root.new-profile-agent-id;
                        color: Theme.text-primary;
                        font-size: 11px * Theme.font-scale;
                        x: 6px;
                        vertical-alignment: center;
                    }
                }
                Button {
                    label: "T";
                    button-accessible-label: "Toggle new profile terminal access";
                    btn-width: 28px;
                    btn-height: 26px;
                    font-size: 10px;
                    font-weight: 400;
                    bg: root.new-profile-terminal-enabled ? Theme.bg-primary : Theme.bg-sidebar;
                    fg: root.new-profile-terminal-enabled ? Theme.text-on-primary : Theme.text-secondary;
                    clicked => { root.new-profile-terminal-enabled = !root.new-profile-terminal-enabled; }
                }
                Button {
                    label: "F";
                    button-accessible-label: "Toggle new profile filesystem access";
                    btn-width: 28px;
                    btn-height: 26px;
                    font-size: 10px;
                    font-weight: 400;
                    bg: root.new-profile-fs-enabled ? Theme.bg-primary : Theme.bg-sidebar;
                    fg: root.new-profile-fs-enabled ? Theme.text-on-primary : Theme.text-secondary;
                    clicked => { root.new-profile-fs-enabled = !root.new-profile-fs-enabled; }
                }
                Button {
                    label: "Add";
                    button-accessible-label: "Add profile";
                    primary: true;
                    btn-width: 56px;
                    btn-height: 26px;
                    font-size: 11px;
                    font-weight: 400;
                    clicked => {
                        if (root.new-profile-name != "") {
                            root.profile-create(
                                root.new-profile-name,
                                root.new-profile-agent-id,
                                root.new-profile-terminal-enabled,
                                root.new-profile-fs-enabled);
                            root.new-profile-name = "";
                            root.new-profile-agent-id = "";
                            root.new-profile-terminal-enabled = false;
                            root.new-profile-fs-enabled = false;
                        }
                    }
                }
            }

            Text { text: "Permission profile"; color: Theme.text-secondary; font-size: 11px * Theme.font-scale; }
            TextInput { text <=> root.permission-profile; color: Theme.text-primary; font-size: 12px * Theme.font-scale; }

            Rectangle {
                height: 28px;
                background: background-default-toggle.has-hover ? Theme.bg-primary-container : Theme.bg-sidebar;
                animate background { duration: 100ms; }
                border-radius: Theme.radius-sm;
                background-default-toggle := TouchArea {
                    mouse-cursor: pointer;
                    accessible-role: button;
                    accessible-label: "Toggle background session default";
                    accessible-action-default => { root.background-default = !root.background-default; }
                    clicked => { root.background-default = !root.background-default; }
                }
                Text {
                    text: root.background-default ? "Background sessions: enabled" : "Background sessions: disabled";
                    color: Theme.text-primary; x: 8px; vertical-alignment: center; font-size: 11px * Theme.font-scale;
                }
            }
            Rectangle {
                height: 28px;
                background: background-override-toggle.has-hover ? Theme.bg-primary-container : Theme.bg-sidebar;
                animate background { duration: 100ms; }
                border-radius: Theme.radius-sm;
                background-override-toggle := TouchArea {
                    mouse-cursor: pointer;
                    accessible-role: button;
                    accessible-label: "Toggle background session override";
                    accessible-action-default => {
                        root.background-override-set = !root.background-override-set;
                        if (root.background-override-set) {
                            root.background-override = root.background-default;
                        }
                    }
                    clicked => {
                        root.background-override-set = !root.background-override-set;
                        if (root.background-override-set) {
                            root.background-override = root.background-default;
                        }
                    }
                }
                Text {
                    text: root.background-override-set
                        ? "This chat: " + (root.background-override ? "background" : "foreground")
                        : "This chat: use default";
                    color: Theme.text-primary;
                    x: 8px;
                    vertical-alignment: center;
                    font-size: 11px * Theme.font-scale;
                }
            }
            if root.background-override-set : Rectangle {
                height: 24px;
                background: background-override-value-toggle.has-hover ? Theme.bg-primary-container : Theme.bg-card;
                animate background { duration: 100ms; }
                border-color: Theme.border-default;
                border-width: 1px;
                border-radius: Theme.radius-sm;
                background-override-value-toggle := TouchArea {
                    mouse-cursor: pointer;
                    accessible-role: button;
                    accessible-label: "Toggle selected chat background session";
                    accessible-action-default => {
                        root.background-override = !root.background-override;
                    }
                    clicked => { root.background-override = !root.background-override; }
                }
                Text {
                    text: root.background-override ? "Set this chat foreground" : "Set this chat background";
                    color: Theme.text-secondary;
                    x: 8px;
                    vertical-alignment: center;
                    font-size: 10px * Theme.font-scale;
                }
            }

            Rectangle { height: 1px; background: Theme.border-default; }

            // MCP servers section -- centrally-registered `mcp_servers/*`
            // entries, merged additively into every session that uses a
            // profile naming them (see `acpx-core::mcp_servers::
            // merge_mcp_servers`'s doc comment). Real list, real create/
            // delete round trip -- no optimistic local mutation.
            Text { text: "MCP Servers"; color: Theme.text-primary; font-size: 13px * Theme.font-scale; font-weight: 700; }
            for server in available-mcp-servers : Rectangle {
                height: 26px;
                background: Theme.bg-sidebar;
                border-radius: Theme.radius-sm;
                HorizontalLayout {
                    padding-left: Metrics.space-4;
                    padding-right: Metrics.space-4;
                    spacing: Metrics.space-4;
                    Text {
                        text: server.name;
                        color: Theme.text-primary;
                        font-size: 11px * Theme.font-scale;
                        font-family: Theme.font-mono;
                        vertical-alignment: center;
                        horizontal-stretch: 0;
                        overflow: elide;
                    }
                    Text {
                        text: server.command;
                        color: Theme.text-secondary;
                        font-size: 10px * Theme.font-scale;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    Button {
                        label: "Remove";
                        button-accessible-label: "Remove MCP server " + server.name;
                        btn-width: 44px;
                        btn-height: 20px;
                        font-size: 9px;
                        font-weight: 400;
                        bg: Theme.bg-card;
                        fg: Theme.text-secondary;
                        clicked => { root.mcp-server-delete(server.name); }
                    }
                }
            }
            HorizontalLayout {
                spacing: Metrics.space-3;
                Rectangle {
                    horizontal-stretch: 1;
                    height: 26px;
                    background: Theme.bg-sidebar;
                    border-radius: Theme.radius-sm;
                    new-mcp-name-input := TextInput {
                        accessible-label: "New MCP server name";
                        accessible-action-default => { self.focus(); }
                        text <=> root.new-mcp-name;
                        color: Theme.text-primary;
                        font-size: 11px * Theme.font-scale;
                        x: 6px;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    height: 26px;
                    background: Theme.bg-sidebar;
                    border-radius: Theme.radius-sm;
                    TextInput {
                        accessible-label: "New MCP server command";
                        accessible-action-default => { self.focus(); }
                        text <=> root.new-mcp-command;
                        color: Theme.text-primary;
                        font-size: 11px * Theme.font-scale;
                        x: 6px;
                        vertical-alignment: center;
                    }
                }
                Button {
                    label: "Add";
                    button-accessible-label: "Add MCP server";
                    primary: true;
                    btn-width: 56px;
                    btn-height: 26px;
                    font-size: 11px;
                    font-weight: 400;
                    clicked => {
                        if (root.new-mcp-name != "") {
                            root.mcp-server-create(root.new-mcp-name, root.new-mcp-command);
                            root.new-mcp-name = "";
                            root.new-mcp-command = "";
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.border-default; }

            // Agent catalog section -- `agents/list`'s real registry
            // entries with each entry's own live detection `status`
            // (`acpx_proto::AgentStatus`, plain monochrome text, no
            // color-coded badge per this project's design language).
            Text { text: "Agents"; color: Theme.text-primary; font-size: 13px * Theme.font-scale; font-weight: 700; }
            for agent in agent-catalog : Rectangle {
                height: 26px;
                background: Theme.bg-sidebar;
                border-radius: Theme.radius-sm;
                HorizontalLayout {
                    padding-left: Metrics.space-4;
                    padding-right: Metrics.space-4;
                    spacing: Metrics.space-4;
                    Text {
                        text: agent.name != "" ? agent.name : agent.id;
                        color: Theme.text-primary;
                        font-size: 11px * Theme.font-scale;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    Text {
                        text: agent.status;
                        color: Theme.text-secondary;
                        font-size: 10px * Theme.font-scale;
                        font-family: Theme.font-mono;
                        vertical-alignment: center;
                        horizontal-stretch: 0;
                    }
                    Button {
                        label: "Install";
                        button-accessible-label: "Install agent " + agent.name;
                        btn-width: 52px;
                        btn-height: 20px;
                        font-size: 9px;
                        font-weight: 400;
                        bg: Theme.bg-card;
                        fg: Theme.text-secondary;
                        clicked => { root.agent-install-requested(agent.id); }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.border-default; }

            // Recovery/import section (Coverage Matrix `session/list`
            // row): real remote gateway sessions not currently bound to
            // any local thread row, for the active thread's own
            // provider -- refreshed by `recover-sessions-requested()`
            // (see `lib.rs`'s `on_settings_requested`, same "populate on
            // open" convention `available-profiles`/`agent-catalog` use).
            // Attaching binds via `session/load`, explicitly never
            // `session/new` (`AgentBridge::add_thread_recovering_
            // session`).
            Text { text: "Recoverable Sessions"; color: Theme.text-primary; font-size: 13px * Theme.font-scale; font-weight: 700; }
            if recoverable-sessions.length == 0 : Text {
                text: "No orphaned sessions for this provider.";
                color: Theme.text-muted;
                font-size: 10px * Theme.font-scale;
            }
            for session in recoverable-sessions : Rectangle {
                height: 26px;
                background: Theme.bg-sidebar;
                border-radius: Theme.radius-sm;
                HorizontalLayout {
                    padding-left: Metrics.space-4;
                    padding-right: Metrics.space-4;
                    spacing: Metrics.space-4;
                    Text {
                        text: (session.title != "" ? session.title : session.session-id) + " (" + session.provider + ")";
                        color: Theme.text-primary;
                        font-size: 11px * Theme.font-scale;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    Button {
                        label: "Attach";
                        button-accessible-label: "Attach recovered session " + session.session-id;
                        btn-width: 52px;
                        btn-height: 20px;
                        font-size: 9px;
                        font-weight: 400;
                        bg: Theme.bg-card;
                        fg: Theme.text-secondary;
                        clicked => { root.recover-session-attach(session.session-id, session.provider, session.title); }
                    }
                }
            }

            Rectangle { height: 6px; }
            HorizontalLayout {
                spacing: Metrics.space-4;
                Button {
                    label: "Save";
                    button-accessible-label: "Save chat settings";
                    primary: true;
                    btn-width: 72px;
                    btn-height: 30px;
                    font-size: 13px;
                    font-weight: 400;
                    clicked => { root.save(); }
                }
                Button {
                    label: "Close";
                    button-accessible-label: "Close chat settings";
                    btn-width: 72px;
                    btn-height: 30px;
                    font-size: 13px;
                    font-weight: 400;
                    border-w: 0px;
                    clicked => { root.close(); }
                }
            }
        }
    }
}
