import { Theme } from "../tokens/theme.slint";
import { Metrics } from "../tokens/metrics.slint";
import { Icon } from "../base/icon.slint";
import { SearchableDropdown } from "../base/searchable_dropdown.slint";
import { FilterSearchBar } from "../base/filter_search_bar.slint";
import { ContextRing } from "../base/context_ring.slint";
import { Toggle } from "../base/toggle.slint";
import { TextUtil } from "../base/text_util.slint";
import { MentionPickRow } from "../base/mention_pick_row.slint";
import { DropdownEntry, SkillOption, McpServerOption } from "../types.slint";
import { CursorHost } from "../tokens/cursor_host.slint";

// ChatInputLayout — bottom compose surface for ChatArea:
//   row 1: multi-line user input + send/stop
//   row 2: context ring + mode + config/model selectors
//   overlay: / skills · @ mcp-servers · # files popup (ui.yaml chat-view)
//
// Owns focus for the composer (`compose-has-focus`, `focus-compose`) so
// ChatArea / overlays can restore keyboard focus without reaching into
// the TextInput id.
export component ChatInputLayout inherits Rectangle {
    // Phase 14 (disabled_input_convention): one root gate for every
    // interactive control in the compose surface. False renders each
    // control visibly disabled (dimmed, no hover/cursor affordance,
    // accessible-enabled false) -- used e.g. for archived threads.
    in property <bool> inputs-enabled: true;
    // Phase 19: explicit blocking overlay (drawn last, swallows clicks)
    // whenever inputs are disabled -- archived threads read as read-only
    // rather than merely dimmed.
    in-out property <string> compose-text: "";
    in property <bool> sending: false;
    in property <[DropdownEntry]> mode-dropdown-entries: [];
    in property <[DropdownEntry]> config-dropdown-entries: [];
    in property <string> mode-trigger-label: "";
    // Host-supplied current model/config label (ACP configOptions).
    in property <string> config-trigger-label: "";
    // Reasoning effort — own dropdown (not mixed into model).
    in property <[DropdownEntry]> reasoning-dropdown-entries: [];
    in property <string> reasoning-trigger-label: "";
    // setup-followups plan, provider_fastmode_profile_persistence:
    // profile/provider picker. Only ever interactive while the active
    // thread has no attached session yet (ThreadItem.has-session) --
    // ACP has no primitive for moving a live session to a different
    // backend, matching Zed's own AgentSessionConfigOptions precedent
    // (free agent choice on an empty draft, a new thread once real
    // content exists).
    in property <[DropdownEntry]> profile-dropdown-entries: [];
    in property <string> profile-trigger-label: "";
    in property <bool> active-thread-has-session: false;
    // Dedicated Fast toggle — binary ACP config option (id typically
    // "fastMode"). Host derives availability/values from configOptions[];
    // the model dropdown deliberately omits this option.
    in property <bool> fast-mode-available: false;
    in property <bool> fast-mode-enabled: false;
    in property <string> fast-mode-option-id: "fastMode";
    in property <string> fast-mode-on-value: "on";
    in property <string> fast-mode-off-value: "off";
    // Session context (ui.yaml chat-view-input). Host pushes real numbers
    // when available; defaults keep the ring useful in pure viewers.
    in property <float> context-ratio: 0.0;
    in property <int> context-used-tokens: 0;
    in property <int> context-limit-tokens: 0;
    // Slash/mention catalogs for the compose popup.
    in property <[SkillOption]> skill-options: [];
    in property <[McpServerOption]> mcp-options: [];
    in property <[string]> file-options: [];

    callback send-requested();
    callback stop-requested();
    callback mode-selected(string);
    callback config-option-selected(string, string);
    callback profile-selected(string);
    callback context-view-requested();
    // Phase 15: inline OAuth/connect from the @ MCP popup row.
    callback mcp-connect-requested(string);
    // Phase 15: inline enable/disable from the @ MCP popup row.
    callback mcp-enabled-changed(string, bool);
    // Panel chords (Ctrl+B/N/K/,, Escape, Ctrl+Enter approve) re-dispatched
    // while the composer owns focus — wired by ChatArea → ChatPanel.
    callback panel-shortcut(KeyEvent) -> EventResult;

    out property <bool> compose-has-focus: compose.has-focus;
    // Mode/model dropdown search fields and the /@# mention popup's own
    // filter field -- see FilterSearchBar.input-has-focus's doc comment.
    // mode-dropdown/config-dropdown only exist while their entry lists are
    // non-empty (conditional elements); referencing their property outside
    // that scope still resolves to false when absent.
    out property <bool> secondary-text-input-has-focus:
        mode-dropdown.search-has-focus
        || config-dropdown.search-has-focus
        || reasoning-dropdown.search-has-focus
        || profile-dropdown.search-has-focus
        || mention-search-bar.input-has-focus;
    callback focus-compose();

    // Local selection mirrors so dropdowns reflect the chosen option
    // immediately (ui.yaml: select options linked to real state), even
    // before the host rewrites the capability lists.
    property <string> local-mode-id: "";
    property <string> local-mode-label: "";
    property <string> local-config-id: "";
    property <string> local-config-value: "";
    property <string> local-config-label: "";
    property <string> local-reasoning-id: "";
    property <string> local-reasoning-value: "";
    property <string> local-reasoning-label: "";
    property <string> local-profile-id: "";
    property <string> local-profile-label: "";
    // Optimistic Fast toggle state until the host rewrites capabilities.
    property <bool> local-fast-mode: root.fast-mode-enabled;
    changed fast-mode-enabled => {
        local-fast-mode = root.fast-mode-enabled;
    }
    changed fast-mode-available => {
        if (!root.fast-mode-available) {
            local-fast-mode = false;
        }
    }

    // First control is **Provider** (was "Profile") — shows agent/provider
    // id; " ›" marks it as a chooser for the cascade (provider → models).
    property <string> profile-label-shown:
        local-profile-label != "" ? local-profile-label + " ›"
        : (root.profile-trigger-label != "" ? root.profile-trigger-label + " ›" : "Provider ›");

    property <string> mode-label-shown:
        local-mode-label != "" ? local-mode-label
        : (root.mode-trigger-label != "" ? root.mode-trigger-label : "Mode");
    property <string> config-label-shown:
        local-config-label != "" ? local-config-label
        : (root.config-trigger-label != "" ? root.config-trigger-label : "Model");
    property <string> reasoning-label-shown:
        local-reasoning-label != "" ? local-reasoning-label
        : (root.reasoning-trigger-label != "" ? root.reasoning-trigger-label : "Effort");

    // --- / @ # mention popup ---------------------------------------------
    // TextUtil.* callbacks are installed by the Rust host (lib.rs) or
    // ui-dev-viewer. Pure slint-viewer needs a local key-driven state
    // machine for open/close; filter uses TextUtil.matches-filter.
    property <bool> textutil-ready: TextUtil.filter-ready();
    property <int> cursor-off: compose.cursor-position-byte-offset;
    property <string> util-prefix:
        textutil-ready ? TextUtil.active-token-prefix(compose-text, cursor-off) : "";
    property <string> util-query:
        textutil-ready ? TextUtil.active-token-query(compose-text, cursor-off) : "";

    // Local fallback (viewer / before host wires callbacks).
    property <bool> local-mention-active: false;
    property <string> local-prefix: "";
    property <string> local-query: "";
    // Text before the mention token was opened (for replace without TextUtil).
    property <string> pre-mention-text: "";
    // Live filter for the mini search bar + list (synced from compose
    // token and editable in the popup search field).
    in-out property <string> mention-filter: "";
    // Keyboard highlight index into the active catalog (skills/mcp/files).
    // Closest/first match is selected by default; Up/Down move; Enter applies.
    property <int> mention-sel: 0;

    property <string> token-prefix:
        util-prefix != "" ? util-prefix
        : (local-mention-active ? local-prefix : "");
    property <string> token-query:
        util-prefix != "" ? util-query
        : local-query;
    property <bool> mention-open:
        compose.has-focus
        && (token-prefix == "/" || token-prefix == "@" || token-prefix == "#");
    property <length> mention-popup-h: 220px;

    // Keep mini-search + list filter in lockstep with the active token.
    changed token-query => {
        mention-filter = token-query;
        root.reselect-closest();
    }
    changed token-prefix => {
        if (token-prefix == "") {
            mention-filter = "";
            mention-sel = 0;
        } else {
            root.reselect-closest();
        }
    }
    changed mention-filter => {
        root.reselect-closest();
    }

    function open-local-mention(prefix: string) {
        // Capture text *before* the trigger char is inserted (key-pressed
        // runs prior to insertion when we return reject).
        pre-mention-text = compose-text;
        local-prefix = prefix;
        local-query = "";
        mention-filter = "";
        local-mention-active = true;
        root.reselect-closest();
    }
    function close-local-mention() {
        local-mention-active = false;
        local-prefix = "";
        local-query = "";
        mention-filter = "";
        mention-sel = 0;
        pre-mention-text = "";
    }
    function apply-mention-pick(insert: string) {
        // insert includes the trigger, e.g. "/skill-name "
        if (root.textutil-ready) {
            root.compose-text = TextUtil.replace-active-token(
                root.compose-text, root.cursor-off, insert);
        } else {
            root.compose-text = root.pre-mention-text + insert;
        }
        root.close-local-mention();
        compose.focus();
    }
    // Hide rows that don't match the live filter (name or secondary text).
    // Single contains-ci call — passing mention-filter twice into helpers
    // trips a SharedString move bug in generated Rust.
    function row-hidden(label: string, extra: string) -> bool {
        if (root.mention-filter == "") {
            return false;
        }
        if (TextUtil.contains-ci(label + "\n" + extra, root.mention-filter)) {
            return false;
        }
        // Host/viewer with TextUtil: no match → hide.
        // Pure slint-viewer (callback uninstalled): contains-ci always
        // false — keep rows visible so the list is not blanked.
        return TextUtil.filter-ready();
    }

    function catalog-len() -> int {
        if (root.token-prefix == "/") {
            return root.skill-options.length;
        }
        if (root.token-prefix == "@") {
            return root.mcp-options.length;
        }
        if (root.token-prefix == "#") {
            return root.file-options.length;
        }
        return 0;
    }
    function item-hidden(i: int) -> bool {
        if (i < 0 || i >= root.catalog-len()) {
            return true;
        }
        if (root.token-prefix == "/") {
            return root.row-hidden(root.skill-options[i].name, root.skill-options[i].description);
        }
        if (root.token-prefix == "@") {
            return root.row-hidden(root.mcp-options[i].name, root.mcp-options[i].command);
        }
        if (root.token-prefix == "#") {
            return root.row-hidden(root.file-options[i], "");
        }
        return true;
    }
    // Positive wrap of `from + steps` into [0, catalog-len).
    // `+ n*64` keeps the argument non-negative when `steps` is negative
    // (dir == -1); 64 is enough headroom for any realistic catalog size.
    function wrap-index(from: int, steps: int) -> int {
        let n = root.catalog-len();
        if (n <= 0) {
            return -1;
        }
        return Math.mod(from + steps + n * 64, n);
    }

    // Walk from `from` in `dir` (+1 / -1), skip filter-hidden rows, wrap.
    // Still step-unrolled: Slint forbids recursion / general loops in
    // component functions (they trip the property binding loop detector).
    // Previously this was sparse (1..10 then 12,16,20,24) and repeated the
    // same Math.mod expression twice per step — missed indices and was
    // hard to read. Now: wrap-index helper + consecutive steps 1..=32.
    function next-visible(from: int, dir: int) -> int {
        let n = root.catalog-len();
        if (n <= 0) {
            return -1;
        }
        // Cap walk at min(n, 32): enough for /@# pickers; longer catalogs
        // still find a match if one of the first 32 candidates in `dir` is
        // visible (typical filtered lists are short).
        let i1 = root.wrap-index(from, 1 * dir);
        if (!root.item-hidden(i1)) { return i1; }
        let i2 = root.wrap-index(from, 2 * dir);
        if (!root.item-hidden(i2)) { return i2; }
        let i3 = root.wrap-index(from, 3 * dir);
        if (!root.item-hidden(i3)) { return i3; }
        let i4 = root.wrap-index(from, 4 * dir);
        if (!root.item-hidden(i4)) { return i4; }
        let i5 = root.wrap-index(from, 5 * dir);
        if (!root.item-hidden(i5)) { return i5; }
        let i6 = root.wrap-index(from, 6 * dir);
        if (!root.item-hidden(i6)) { return i6; }
        let i7 = root.wrap-index(from, 7 * dir);
        if (!root.item-hidden(i7)) { return i7; }
        let i8 = root.wrap-index(from, 8 * dir);
        if (!root.item-hidden(i8)) { return i8; }
        let i9 = root.wrap-index(from, 9 * dir);
        if (!root.item-hidden(i9)) { return i9; }
        let i10 = root.wrap-index(from, 10 * dir);
        if (!root.item-hidden(i10)) { return i10; }
        let i11 = root.wrap-index(from, 11 * dir);
        if (!root.item-hidden(i11)) { return i11; }
        let i12 = root.wrap-index(from, 12 * dir);
        if (!root.item-hidden(i12)) { return i12; }
        let i13 = root.wrap-index(from, 13 * dir);
        if (!root.item-hidden(i13)) { return i13; }
        let i14 = root.wrap-index(from, 14 * dir);
        if (!root.item-hidden(i14)) { return i14; }
        let i15 = root.wrap-index(from, 15 * dir);
        if (!root.item-hidden(i15)) { return i15; }
        let i16 = root.wrap-index(from, 16 * dir);
        if (!root.item-hidden(i16)) { return i16; }
        let i17 = root.wrap-index(from, 17 * dir);
        if (!root.item-hidden(i17)) { return i17; }
        let i18 = root.wrap-index(from, 18 * dir);
        if (!root.item-hidden(i18)) { return i18; }
        let i19 = root.wrap-index(from, 19 * dir);
        if (!root.item-hidden(i19)) { return i19; }
        let i20 = root.wrap-index(from, 20 * dir);
        if (!root.item-hidden(i20)) { return i20; }
        let i21 = root.wrap-index(from, 21 * dir);
        if (!root.item-hidden(i21)) { return i21; }
        let i22 = root.wrap-index(from, 22 * dir);
        if (!root.item-hidden(i22)) { return i22; }
        let i23 = root.wrap-index(from, 23 * dir);
        if (!root.item-hidden(i23)) { return i23; }
        let i24 = root.wrap-index(from, 24 * dir);
        if (!root.item-hidden(i24)) { return i24; }
        let i25 = root.wrap-index(from, 25 * dir);
        if (!root.item-hidden(i25)) { return i25; }
        let i26 = root.wrap-index(from, 26 * dir);
        if (!root.item-hidden(i26)) { return i26; }
        let i27 = root.wrap-index(from, 27 * dir);
        if (!root.item-hidden(i27)) { return i27; }
        let i28 = root.wrap-index(from, 28 * dir);
        if (!root.item-hidden(i28)) { return i28; }
        let i29 = root.wrap-index(from, 29 * dir);
        if (!root.item-hidden(i29)) { return i29; }
        let i30 = root.wrap-index(from, 30 * dir);
        if (!root.item-hidden(i30)) { return i30; }
        let i31 = root.wrap-index(from, 31 * dir);
        if (!root.item-hidden(i31)) { return i31; }
        let i32 = root.wrap-index(from, 32 * dir);
        if (!root.item-hidden(i32)) { return i32; }
        return -1;
    }
    function reselect-closest() {
        // First visible under the current filter (default selection).
        root.mention-sel = root.next-visible(-1, 1);
    }
    function mention-move(dir: int) {
        if (root.catalog-len() == 0) {
            return;
        }
        if (root.mention-sel < 0) {
            root.mention-sel = root.next-visible(-1, 1);
            return;
        }
        root.mention-sel = root.next-visible(root.mention-sel, dir);
    }
    function apply-mention-sel() {
        if (root.mention-sel < 0 || root.item-hidden(root.mention-sel)) {
            return;
        }
        if (root.token-prefix == "/") {
            root.apply-mention-pick("/" + root.skill-options[root.mention-sel].name + " ");
        } else if (root.token-prefix == "@") {
            root.apply-mention-pick("@" + root.mcp-options[root.mention-sel].name + " ");
        } else if (root.token-prefix == "#") {
            root.apply-mention-pick("#" + root.file-options[root.mention-sel] + " ");
        }
    }
    // Non-printable / navigation keys — never append their private
    // unicode text to the filter (Left/Right were producing junk glyphs).
    pure function is-nav-or-edit-key(t: string) -> bool {
        return t == Key.LeftArrow
            || t == Key.RightArrow
            || t == Key.UpArrow
            || t == Key.DownArrow
            || t == Key.Home
            || t == Key.End
            || t == Key.PageUp
            || t == Key.PageDown
            || t == Key.Backspace
            || t == Key.Delete
            || t == Key.Tab
            || t == Key.Escape
            || t == Key.Return;
    }
    // Only real typing chars go into local-query / mention-filter.
    pure function is-filter-char(t: string) -> bool {
        return t != ""
            && t != " "
            && !root.is-nav-or-edit-key(t)
            && t.character-count == 1;
    }
    // Shared key handler for compose + mini search while popup is open.
    function mention-key(event: KeyEvent) -> EventResult {
        if (event.text == Key.Escape) {
            root.close-local-mention();
            compose.focus();
            return EventResult.accept;
        }
        if (event.text == Key.DownArrow) {
            root.mention-move(1);
            return EventResult.accept;
        }
        if (event.text == Key.UpArrow) {
            root.mention-move(-1);
            return EventResult.accept;
        }
        // Left/Right: do not accept — let TextInput move the caret.
        // (Still must not be treated as filter chars; see is-filter-char.)
        if (event.text == Key.LeftArrow || event.text == Key.RightArrow
            || event.text == Key.Home || event.text == Key.End
            || event.text == Key.PageUp || event.text == Key.PageDown
            || event.text == Key.Delete) {
            return EventResult.reject;
        }
        if (event.text == Key.Return && !event.modifiers.shift && !event.modifiers.control) {
            root.apply-mention-sel();
            return EventResult.accept;
        }
        // Phase 15 keyboard nav: Ctrl+Enter on a highlighted @ MCP row
        // triggers its inline lifecycle action (Connect while auth is
        // pending, Enable/Disable otherwise) -- every popup action stays
        // reachable keyboard-only, mirroring the mouse action button.
        if (event.text == Key.Return && event.modifiers.control
            && root.token-prefix == "@"
            && root.mention-sel >= 0 && root.mention-sel < root.mcp-options.length) {
            if (root.mcp-options[root.mention-sel].transport == "http"
                && root.mcp-options[root.mention-sel].needs-auth) {
                root.mcp-connect-requested(root.mcp-options[root.mention-sel].name);
            } else {
                root.mcp-enabled-changed(root.mcp-options[root.mention-sel].name,
                    !root.mcp-options[root.mention-sel].enabled);
            }
            return EventResult.accept;
        }
        if (event.text == " ") {
            root.close-local-mention();
            return EventResult.reject;
        }
        return EventResult.reject;
    }

    // Second-row band height — same as SearchableDropdown + ContextRing
    // so all three share one center line.
    property <length> row2-h: 24px;
    // Row 2's mode + model triggers (each min-width 72px, see
    // searchable_dropdown.slint) plus the context ring (row2-h wide) and
    // inter-item spacing add up to just over 180px at their narrowest --
    // in a compact/narrow dock (observed live at ~230px total width, only
    // ~180px of that left after this component's own pad-2xl horizontal
    // padding) that already exceeds the available width. Nothing here
    // clips (root.clip is false, deliberately, so the mention popup can
    // escape upward) -- content past the visible width just renders
    // outside the panel's own pixel buffer and is effectively invisible,
    // which is the "hidden model selector" symptom this threshold fixes:
    // drop the least essential item (the context ring) first so the two
    // selects stay reachable.
    // Drop context ring earlier on narrow docks so mode/model triggers
    // stay fully inside the panel (composer_input_text_cutoff_small_width).
    property <bool> row2-compact: root.width < 320px;
    // setup-followups plan, provider_fastmode_profile_persistence: the
    // profile picker is a 3rd SearchableDropdown (also min-width 72px)
    // added to a row whose own doc comment above already documents
    // mode+model+ring as sitting right at the edge of a compact dock's
    // width budget (~180px available at ~230px total width) -- adding a
    // 3rd 72px-min dropdown unconditionally would have pushed mode/model
    // off-panel-edge (invisible, not clipped -- this component's own
    // `clip: false`) in exactly the docks that threshold was built to
    // protect. Same "drop the least essential item first" strategy as
    // row2-compact's own context-ring: only show the profile picker once
    // there's real room for all three dropdowns together, not just
    // mode+model+ring's original budget.
    property <bool> row2-has-room-for-profile: root.width >= 360px;

    width: 100%;
    horizontal-stretch: 1;
    // Composer is a fixed-height chrome band, not an elastic region —
    // without vertical-stretch:0 it could expand and steal space from
    // the message Flickable (user_input_bottom_box_view_cutoff).
    vertical-stretch: 0;
    // Don't clip the upward mention popup (overflows above this bar).
    // Row content itself is clipped inside input-box / row2 below.
    clip: false;
    background: Theme.bg-sidebar;

    VerticalLayout {
        width: 100%;
        vertical-stretch: 0;
        // Horizontal gutter matches permission-card dock (pad-2xl).
        // Vertical: pad-md (12px) — pad-xl (24px) made the bar look over-tall.
        padding-left: Metrics.pad-2xl;
        padding-right: Metrics.pad-2xl;
        padding-top: Metrics.pad-md;
        padding-bottom: Metrics.pad-md;
        spacing: Metrics.gap-md;

        // Indeterminate progress bar while a turn is in flight.
        // audit-fixes animation_tick_loaders: keep mounted (height/opacity
        // collapse when idle) and drive travel with animation-tick(). A
        // mount-time `if root.sending` + `bar-t: 1.0` + `animate` never
        // transitioned (instantiated already at end value) so the bar
        // looked frozen.
        Rectangle {
            height: root.sending ? 2px : 0px;
            opacity: root.sending ? 1.0 : 0.0;
            animate height, opacity { duration: 150ms; easing: ease-in-out; }
            width: 100%;
            background: Theme.border-default;
            clip: true;
            property <float> bar-t: root.sending
                ? mod(animation-tick(), 1100ms) / 1100ms
                : 0.0;
            Rectangle {
                width: parent.width * 0.35;
                height: parent.height;
                x: (parent.width + self.width) * bar-t - self.width;
                background: Theme.bg-primary.with-alpha(0.9);
                border-radius: 1px;
            }
        }

        // Row 1 — input fills remaining width; send fixed, bottom-aligned.
        HorizontalLayout {
            width: 100%;
            spacing: Metrics.gap-sm;
            input-box := Rectangle {
                horizontal-stretch: 1;
                preferred-width: 0px;
                min-width: 0px;
                // Clip glyphs at the right edge so multi-line compose
                // never paints under the send button or past the dock
                // (composer_input_text_cutoff_small_width).
                clip: true;
                height: Math.clamp(compose.preferred-height + Metrics.pad-lg, 34px, 120px);
                background: Theme.bg-tertiary;
                border-radius: Theme.radius-md;
                Text {
                    // setup-followups plan, chat_input_placeholder_copy:
                    // keep a single placeholder regardless of `sending`
                    // state -- the composer's own spinning-ring/stop-icon
                    // (see in_flight_turn_loading_indicator) is already
                    // the in-progress signal; the placeholder itself
                    // doesn't need a second one.
                    text: "Ask the agent…  / skills  @ mcp  # files";
                    color: Theme.text-muted;
                    font-size: 11px * Theme.font-scale;
                    font-family: Theme.font-sans;
                    wrap: no-wrap;
                    overflow: elide;
                    visible: compose.text == "";
                    x: Metrics.pad-lg;
                    y: Metrics.pad-lg / 2;
                    width: parent.width - 2 * Metrics.pad-lg;
                }
                Flickable {
                    x: Metrics.pad-lg;
                    y: Metrics.pad-lg / 2;
                    width: parent.width - 2 * Metrics.pad-lg;
                    height: parent.height - Metrics.pad-lg;
                    viewport-height: compose.preferred-height;
                    viewport-width: self.width;
                    compose := TextInput {
                        accessible-label: "Compose message";
                        text <=> root.compose-text;
                        enabled: root.inputs-enabled;
                        color: Theme.text-primary;
                        font-family: Theme.font-sans;
                        font-size: 11px * Theme.font-scale;
                        width: parent.width;
                        height: max(self.preferred-height, parent.height);
                        single-line: false;
                        wrap: word-wrap;
                        changed has-focus => { CursorHost.kind = self.has-focus ? "text" : "default"; }
                        key-pressed(event) => {
                            if (root.panel-shortcut(event) == EventResult.accept) {
                                return EventResult.accept;
                            }
                            // Open / @ # popup (local state for slint-viewer;
                            // host path also re-detects via TextUtil).
                            if (event.text == "/" || event.text == "@" || event.text == "#") {
                                root.open-local-mention(event.text);
                                return EventResult.reject;
                            }
                            if (root.mention-open || root.local-mention-active) {
                                // Arrows / Enter / Esc handled for selection.
                                if (root.mention-key(event) == EventResult.accept) {
                                    return EventResult.accept;
                                }
                                if (event.text == Key.Backspace) {
                                    if (!root.textutil-ready && root.local-mention-active) {
                                        if (root.local-query == "") {
                                            root.close-local-mention();
                                        } else {
                                            root.local-query = "";
                                            root.mention-filter = "";
                                        }
                                    }
                                    return EventResult.reject;
                                }
                                // Printable char only → extend filter.
                                // Never append Left/Right/etc. (private
                                // unicode key codes looked like junk glyphs).
                                if (root.local-mention-active && root.is-filter-char(event.text)) {
                                    root.local-query = root.local-query + event.text;
                                    root.mention-filter = root.local-query;
                                }
                            }
                            if (event.text == Key.Return && !event.modifiers.shift && !event.modifiers.control) {
                                root.send-requested();
                                return EventResult.accept;
                            }
                            if (event.text == Key.Backspace && event.modifiers.control) {
                                if (root.textutil-ready) {
                                    self.set-selection-offsets(
                                        TextUtil.word-boundary-before(self.text, self.cursor-position-byte-offset),
                                        self.cursor-position-byte-offset);
                                }
                                return EventResult.reject;
                            }
                            return EventResult.reject;
                        }
                    }
                }
            }
            VerticalLayout {
                alignment: end;
                horizontal-stretch: 0;
                width: 34px;
                Rectangle {
                    width: 34px;
                    height: 34px;
                    background: root.sending ? Theme.border-default
                        : !(root.sending || compose.text != "") ? Theme.border-default
                        : send-stop-button.has-hover ? Theme.bg-primary.with-alpha(0.85)
                        : Theme.bg-primary;
                    animate background { duration: 100ms; }
                    border-radius: Theme.radius-md;
                    opacity: (root.sending || compose.text != "") ? 1.0 : 0.7;
                    // setup-followups plan, in_flight_turn_loading_indicator:
                    // the composer previously gave zero animated feedback
                    // during an in-flight turn -- the button just went
                    // static-stop-icon and sat there. Same spinning-ring
                    // motif as sidebar.slint's own load-spin (thread.status
                    // == "loading"), so a user watching only the composer
                    // (not the sidebar) can still see the turn is actively
                    // in progress.
                    //
                    // audit-fixes animation_tick_loaders: continuous spin
                    // via animation-tick (no dynamic iteration-count).
                    property <angle> load-spin: root.sending
                        ? 360deg * mod(animation-tick(), 800ms) / 800ms
                        : 0deg;
                    if root.sending : VerticalLayout {
                        // Without this wrapper the ring rendered pinned to
                        // this Rectangle's top-left corner (a plain child
                        // Item with no layout defaults to (0,0)), not
                        // centered behind the stop icon -- unlike the stop/
                        // send Icon just below, which already has this same
                        // centering wrapper.
                        alignment: center;
                        HorizontalLayout {
                            alignment: center;
                            Icon {
                                // Larger than the stop icon (icon-sm, 12px)
                                // so it reads as a ring around it, not an
                                // overlapping duplicate at the same size.
                                source: @image-url("../assets/icons/loader-circle.svg");
                                size: 26px;
                                color: Theme.text-secondary.with-alpha(0.55);
                                transform-rotation: load-spin;
                                transform-origin: { x: self.width / 2, y: self.height / 2 };
                            }
                        }
                    }
                    send-stop-button := TouchArea {
                        mouse-cursor: pointer;
                        accessible-role: button;
                        accessible-label: root.sending ? "Stop response" : "Send message";
                        accessible-action-default => {
                            if root.sending { root.stop-requested(); }
                            else { root.send-requested(); }
                        }
                        enabled: root.inputs-enabled && (root.sending || compose.text != "");
                        clicked => {
                            if root.sending { root.stop-requested(); }
                            else { root.send-requested(); }
                        }
                        changed has-hover => { CursorHost.kind = self.has-hover ? "pointer" : "default"; }
                    }
                    VerticalLayout {
                        alignment: center;
                        HorizontalLayout {
                            alignment: center;
                            // Stop icon still renders on top so click-to-
                            // stop stays visually obvious; the spinning
                            // ring behind it is the new in-progress signal.
                            Icon {
                                source: root.sending
                                    ? @image-url("../assets/icons/square.svg")
                                    : @image-url("../assets/icons/send.svg");
                                size: Metrics.icon-sm;
                                color: root.sending ? Theme.text-secondary
                                    : (compose.text != "" ? Theme.text-on-primary : Theme.text-muted);
                            }
                        }
                    }
                }
            }
        }

        // Row 2: mode → model → context. Default for both control types:
        // same preferred height (row2-h) + parent cross-axis-alignment:
        // center so geometric midlines match. Do not stretch items.
        // Do NOT clip this row: SearchableDropdown popups are children of
        // the trigger and must paint outside the 24px band. Narrow-dock
        // cutoff is handled by row2-compact + trigger-min-width shrink,
        // plus (consolidation plan phase 10, min-width devices) a
        // horizontal pan host: when the selector strip's natural width
        // exceeds the dock, scrolling over it pans the strip so every
        // control stays reachable. A plain Flickable can't be used --
        // the dropdown popups are inline children painted UPWARD out of
        // the 24px band and a Flickable always clips. Instead the host
        // clips only while every popup is closed (is-open re-exports),
        // and the pan offset clamps to the overflow range.
        row2-host := Rectangle {
            width: 100%;
            height: root.row2-h;
            clip: !(profile-dropdown.is-open
                || mode-dropdown.is-open
                || config-dropdown.is-open
                || reasoning-dropdown.is-open);
            property <length> pan: 0px;
            property <length> overflow: max(0px, row2-strip.preferred-width - self.width);
            // Declared BEFORE the strip so every trigger keeps click
            // priority; unconsumed scroll events fall through here.
            row2-scroll := TouchArea {
                width: 100%;
                height: 100%;
                scroll-event(e) => {
                    if (row2-host.overflow > 0px) {
                        row2-host.pan = max(-row2-host.overflow,
                            min(0px, row2-host.pan + e.delta-x + e.delta-y));
                        return accept;
                    }
                    return reject;
                }
            }
        row2-strip := HorizontalLayout {
            x: row2-host.overflow > 0px ? row2-host.pan : 0px;
            height: root.row2-h;
            preferred-height: root.row2-h;
            spacing: Metrics.gap-sm;
            alignment: start;
            cross-axis-alignment: center;

            // Unconditionally mounted (visible:, not if:) -- see
            // FilterSearchBar.input-has-focus's doc comment: this
            // component's own id needs to stay referenceable from
            // secondary-text-input-has-focus below.
            // Provider (first control): pick agent/provider before model.
            // `id` = profile name (session open), `value` = agent_id,
            // `label` = provider display. Locked once a session attaches.
            profile-dropdown := SearchableDropdown {
                // Always offer Provider when profiles exist (not only on wide
                // docks) — it's the cascade root for the model list.
                visible: root.profile-dropdown-entries.length > 0;
                enabled: root.inputs-enabled && !root.active-thread-has-session;
                horizontal-stretch: 0;
                vertical-stretch: 0;
                height: root.row2-h;
                preferred-height: root.row2-h;
                trigger-min-width: root.row2-compact ? 56px : 72px;
                trigger-label: root.profile-label-shown;
                options: root.profile-dropdown-entries;
                selected-id: root.local-profile-id;
                placeholder: "Search providers...";
                popup-width: 200px;
                entry-selected(id, value, label) => {
                    root.local-profile-id = id;
                    // Show provider id (value/agent) or label without " ›".
                    root.local-profile-label = value != "" ? value : label;
                    root.profile-selected(id);
                }
                opened => {
                    mode-dropdown.close();
                    config-dropdown.close();
                    reasoning-dropdown.close();
                }
            }
            mode-dropdown := SearchableDropdown {
                enabled: root.inputs-enabled;
                visible: root.mode-dropdown-entries.length > 0;
                horizontal-stretch: 0;
                vertical-stretch: 0;
                height: root.row2-h;
                preferred-height: root.row2-h;
                trigger-min-width: root.row2-compact ? 56px : 72px;
                trigger-label: root.mode-label-shown;
                options: root.mode-dropdown-entries;
                selected-id: root.local-mode-id;
                placeholder: "Search modes...";
                popup-width: 200px;
                entry-selected(id, value, label) => {
                    root.local-mode-id = id;
                    root.local-mode-label = label;
                    root.mode-selected(id);
                }
                opened => {
                    profile-dropdown.close();
                    config-dropdown.close();
                    reasoning-dropdown.close();
                }
            }
            config-dropdown := SearchableDropdown {
                enabled: root.inputs-enabled;
                visible: root.config-dropdown-entries.length > 0;
                horizontal-stretch: 0;
                vertical-stretch: 0;
                height: root.row2-h;
                preferred-height: root.row2-h;
                trigger-min-width: root.row2-compact ? 56px : 72px;
                trigger-label: root.config-label-shown;
                options: root.config-dropdown-entries;
                selected-id: root.local-config-id;
                selected-value: root.local-config-value;
                placeholder: "Search models...";
                popup-width: 220px;
                popup-align-end: false;
                entry-selected(id, value, label) => {
                    root.local-config-id = id;
                    root.local-config-value = value;
                    root.local-config-label = label;
                    root.config-option-selected(id, value);
                }
                opened => {
                    profile-dropdown.close();
                    mode-dropdown.close();
                    reasoning-dropdown.close();
                }
            }
            // Reasoning effort — own SearchableDropdown (not under Model).
            reasoning-dropdown := SearchableDropdown {
                enabled: root.inputs-enabled;
                visible: root.reasoning-dropdown-entries.length > 0;
                horizontal-stretch: 0;
                vertical-stretch: 0;
                height: root.row2-h;
                preferred-height: root.row2-h;
                trigger-min-width: root.row2-compact ? 56px : 72px;
                trigger-label: root.reasoning-label-shown;
                options: root.reasoning-dropdown-entries;
                selected-id: root.local-reasoning-id;
                selected-value: root.local-reasoning-value;
                placeholder: "Search effort...";
                popup-width: 200px;
                entry-selected(id, value, label) => {
                    root.local-reasoning-id = id;
                    root.local-reasoning-value = value;
                    root.local-reasoning-label = label;
                    root.config-option-selected(id, value);
                }
                opened => {
                    profile-dropdown.close();
                    mode-dropdown.close();
                    config-dropdown.close();
                }
            }

            // Fast model toggle — binary config option (fastMode / etc.).
            // Only shown when the attached backend advertises one.
            if root.fast-mode-available : HorizontalLayout {
                horizontal-stretch: 0;
                vertical-stretch: 0;
                height: root.row2-h;
                spacing: Metrics.space-2;
                alignment: start;
                cross-axis-alignment: center;
                Text {
                    text: "Fast";
                    color: Theme.text-secondary;
                    font-size: 10px * Theme.font-scale;
                    font-family: Theme.font-sans;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 0;
                }
                Toggle {
                    checked: root.local-fast-mode;
                    toggle-accessible-label: root.local-fast-mode
                        ? "Disable fast mode"
                        : "Enable fast mode";
                    toggled(on) => {
                        root.local-fast-mode = on;
                        root.config-option-selected(
                            root.fast-mode-option-id,
                            on ? root.fast-mode-on-value : root.fast-mode-off-value,
                        );
                    }
                }
            }

            // Hidden below row2-compact's width threshold -- see its own
            // doc comment. Least essential of row 2's three controls
            // (decorative usage indicator, not a picker), so it's the one
            // dropped to keep the mode/model selects reachable.
            if !root.row2-compact : ContextRing {
                size: root.row2-h;
                horizontal-stretch: 0;
                vertical-stretch: 0;
                ratio: root.context-ratio;
                used-tokens: root.context-used-tokens;
                limit-tokens: root.context-limit-tokens;
                context-view-requested => { root.context-view-requested(); }
            }
        }
        }
    }

    // / @ # suggestion popup — sibling of the main VerticalLayout so it
    // is not clipped by layout packing. Anchored just above this bar.
    // Unconditionally mounted (visible:, not if:) -- mention-search-bar's
    // id needs to stay referenceable from secondary-text-input-has-focus
    // above; positioned via explicit x/y (not in a layout flow), so
    // staying mounted-but-hidden doesn't disturb sibling layout.
    Rectangle {
        visible: root.mention-open;
        x: Metrics.pad-2xl;
        y: -root.mention-popup-h - 6px;
        width: parent.width - 2 * Metrics.pad-2xl;
        height: root.mention-popup-h;
        z: 8000;
        background: Theme.bg-card;
        border-width: 1px;
        border-color: Theme.border-strong;
        border-radius: Theme.radius-md;
        drop-shadow-blur: 14px;
        drop-shadow-color: #000000.with-alpha(0.45);
        drop-shadow-offset-y: 2px;
        clip: true;

        VerticalLayout {
            padding: Metrics.pad-sm;
            spacing: Metrics.gap-sm;
            // Shared FilterSearchBar (base/) — same tokens as settings /
            // dropdown search; leading-text is the active / @ # trigger.
            mention-search-bar := FilterSearchBar {
                query <=> root.mention-filter;
                placeholder: "filter…";
                bar-accessible-label: "Filter suggestions";
                show-icon: true;
                leading-text: root.token-prefix != "" ? root.token-prefix : "/";
                edited => {
                    root.local-query = root.mention-filter;
                }
                key-pressed(event) => {
                    return root.mention-key(event);
                }
            }
            Flickable {
                vertical-stretch: 1;
                preferred-height: 0px;
                min-height: 40px;
                viewport-height: mention-col.preferred-height;
                mention-col := VerticalLayout {
                    spacing: Metrics.space-1;

                    if root.token-prefix == "/" : VerticalLayout {
                        spacing: Metrics.space-1;
                        for skill[i] in root.skill-options : MentionPickRow {
                            property <bool> hidden: root.row-hidden(skill.name, skill.description);
                            height: hidden ? 0px : 28px;
                            highlighted: !hidden && i == root.mention-sel;
                            show-icon: true;
                            icon-source: @image-url("../assets/icons/sparkles.svg");
                            title: skill.name;
                            title-font-weight: 600;
                            subtitle: skill.description;
                            clicked => {
                                root.mention-sel = i;
                                root.apply-mention-pick("/" + skill.name + " ");
                            }
                        }
                        if root.skill-options.length == 0 : Text {
                            text: "No skills discovered yet";
                            color: Theme.text-muted;
                            font-size: 11px * Theme.font-scale;
                        }
                    }

                    if root.token-prefix == "@" : VerticalLayout {
                        spacing: Metrics.space-1;
                        for srv[i] in root.mcp-options : MentionPickRow {
                            property <bool> hidden: root.row-hidden(srv.name, srv.command);
                            height: hidden ? 0px : 28px;
                            highlighted: !hidden && i == root.mention-sel;
                            show-icon: true;
                            icon-source: @image-url("../assets/icons/server.svg");
                            title: srv.name;
                            title-font-weight: 600;
                            subtitle: srv.command;
                            // Phase 15: live connection dot on MCP rows.
                            status-dot: srv.status;
                            // Connect wins when auth is pending; otherwise the
                            // action toggles enablement (Disable/Enable) via the
                            // same root callback the Settings toggle uses.
                            action-label: srv.transport == "http" && srv.needs-auth ? "Connect"
                                : (srv.enabled ? "Disable" : "Enable");
                            action-clicked => {
                                if (srv.transport == "http" && srv.needs-auth) {
                                    root.mcp-connect-requested(srv.name);
                                } else {
                                    root.mcp-enabled-changed(srv.name, !srv.enabled);
                                }
                            }
                            clicked => {
                                root.mention-sel = i;
                                root.apply-mention-pick("@" + srv.name + " ");
                            }
                        }
                        if root.mcp-options.length == 0 : Text {
                            text: "No MCP servers registered";
                            color: Theme.text-muted;
                            font-size: 11px * Theme.font-scale;
                        }
                    }

                    if root.token-prefix == "#" : VerticalLayout {
                        spacing: Metrics.space-1;
                        for f[i] in root.file-options : MentionPickRow {
                            property <bool> hidden: root.row-hidden(f, "");
                            height: hidden ? 0px : 28px;
                            highlighted: !hidden && i == root.mention-sel;
                            title: f;
                            title-font-family: Theme.font-mono;
                            clicked => {
                                root.mention-sel = i;
                                root.apply-mention-pick("#" + f + " ");
                            }
                        }
                        if root.file-options.length == 0 : Text {
                            text: "No files indexed yet";
                            color: Theme.text-muted;
                            font-size: 11px * Theme.font-scale;
                        }
                    }
                }
            }
        }
    }

    focus-compose => { compose.focus(); }

    if !root.inputs-enabled : Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.bg-canvas.with-alpha(0.35);
        TouchArea { }
        Text {
            text: "Archived thread - resume it to continue the conversation";
            color: Theme.text-muted;
            font-size: 10px * Theme.font-scale;
            font-italic: true;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: 100%;
        }
    }
}
