import { Palette } from "palette.slint";
import { PendingRequestItem } from "types.slint";

// Interactive agent-request relay addition: renders one pending
// `session/request_permission`/`fs/*`/`terminal/create` decision as a
// full-width card docked above the compose bar -- see
// `panel-rust/src/permission.rs`'s module doc comment for the
// per-method summary/response contract this visualizes. Deliberately
// monochrome, matching `message_card.slint`'s "status stays monochrome"
// convention -- approve is the filled/primary action (visually the same
// treatment as the compose bar's own Send button), reject is a plain
// bordered secondary action, no red/green semantic coloring.
export component PermissionCard inherits Rectangle {
    in property <PendingRequestItem> item;
    callback approve();
    callback reject();

    background: Palette.sys-card;
    border-color: Palette.sys-border-strong;
    border-width: 1px;
    border-radius: Palette.radius-md;

    VerticalLayout {
        padding: 10px;
        spacing: 6px;
        HorizontalLayout {
            spacing: 6px;
            Text {
                text: "\u{26A0}"; // warning-triangle glyph, stand-in for a permission-shield icon
                color: Palette.sys-primary;
                font-size: 12px;
                vertical-alignment: center;
            }
            Text {
                text: item.title;
                color: Palette.sys-text-primary;
                font-family: Palette.font-sans;
                font-size: 12px;
                font-weight: 700;
                horizontal-stretch: 1;
                preferred-width: 0px;
                min-width: 0px;
                overflow: elide;
                vertical-alignment: center;
            }
            Text {
                text: item.method;
                color: Palette.sys-text-muted;
                font-family: Palette.font-mono;
                font-size: 9px;
                vertical-alignment: center;
            }
        }
        Text {
            text: item.summary;
            color: Palette.sys-text-secondary;
            font-family: Palette.font-sans;
            font-size: 11px;
            wrap: word-wrap;
            overflow: elide;
        }
        if item.supported : HorizontalLayout {
            spacing: 8px;
            Rectangle { }
            Rectangle {
                width: 72px;
                height: 26px;
                background: Palette.sys-sidebar;
                border-color: Palette.sys-border;
                border-width: 1px;
                border-radius: Palette.radius-sm;
                TouchArea { clicked => { reject(); } }
                Text {
                    text: "Reject";
                    color: Palette.sys-text-primary;
                    font-family: Palette.font-sans;
                    font-size: 10px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            Rectangle {
                width: 72px;
                height: 26px;
                background: Palette.sys-primary;
                border-radius: Palette.radius-sm;
                TouchArea { clicked => { approve(); } }
                Text {
                    text: "Approve";
                    color: Palette.sys-on-primary;
                    font-family: Palette.font-sans;
                    font-size: 10px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
        if !item.supported : Text {
            text: "This request kind isn't supported by this UI build yet -- the agent's own request timeout/fallback policy will resolve it.";
            color: Palette.sys-text-muted;
            font-family: Palette.font-sans;
            font-size: 10px;
            font-italic: true;
            wrap: word-wrap;
        }
    }
}
