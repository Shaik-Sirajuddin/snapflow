// Layer 1 (tokens) -- radius "finish" presets, verbatim from
// index.html's `radiusPresets` object (`theme.rs::RadiusPreset::scale()`).
// Raw scale only -- resolving which preset is active (`Theme.radius-preset`,
// an FFI-set `in` property) stays in `theme.slint`.
export global Metrics {
    out property <length> radius-sm-classic: 4px;
    out property <length> radius-md-classic: 6px;
    out property <length> radius-lg-classic: 8px;

    out property <length> radius-sm-sharp: 0px;
    out property <length> radius-md-sharp: 0px;
    out property <length> radius-lg-sharp: 0px;

    out property <length> radius-sm-organic: 12px;
    out property <length> radius-md-organic: 18px;
    out property <length> radius-lg-organic: 28px;

    // Spacing scale -- shared padding/gap steps so call sites reference
    // one name instead of repeating a literal `Npx` everywhere. Not
    // theme/preset-dependent (unlike the radius scale above), so these
    // are plain constants rather than resolved through `theme.slint`.
    // Prefer the semantic pad-* / gap-* aliases below at new call sites.
    out property <length> space-1: 2px;
    out property <length> space-2: 4px;
    out property <length> space-3: 6px;
    out property <length> space-4: 8px;
    out property <length> space-5: 10px;
    out property <length> space-6: 12px;
    out property <length> space-7: 16px;
    out property <length> space-8: 24px;
    out property <length> space-9: 32px;
    out property <length> space-10: 40px;

    // Layout padding tiers (sm / md / lg / …) — semantic aliases over
    // space-*. Use these for component/box padding so UI code says
    // "pad-md" rather than picking a raw space-N ad hoc. Same idea as
    // icon-sm/md/lg and radius-sm/md/lg.
    //
    //   pad-xs   4px   dense chips, micro insets
    //   pad-sm   6px   tight gaps, compact rows
    //   pad-md  12px   default surface / bar padding
    //   pad-lg  16px   roomy control interiors
    //   pad-xl  24px   section margins / field vertical
    //   pad-2xl 32px   large field horizontal
    out property <length> pad-xs: space-2;
    out property <length> pad-sm: space-3;
    out property <length> pad-md: space-6;
    out property <length> pad-lg: space-7;
    out property <length> pad-xl: space-8;
    out property <length> pad-2xl: space-9;

    // Layout gap tiers (spacing between siblings in a row/column).
    out property <length> gap-sm: space-3;
    out property <length> gap-md: space-4;
    out property <length> gap-lg: space-6;

    // Shared icon-size tiers -- so a "header icon" and a "sidebar row
    // icon" agree on what "md" means instead of each picking its own
    // literal px value.
    out property <length> icon-sm: 12px;
    out property <length> icon-md: 16px;
    out property <length> icon-lg: 20px;

    // The squared-off corner on a message bubble's sender-side corner
    // (chat-items-redesign.md #1) -- always 0, independent of the
    // radius-preset scale above, since the whole point is that one corner
    // stays sharp regardless of which "finish" preset is active.
    out property <length> radius-corner-cut: 0px;
}
