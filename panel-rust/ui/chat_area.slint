import { Theme } from "./tokens/theme.slint";
import { Metrics } from "./tokens/metrics.slint";
import { Icon } from "./base/icon.slint";
import { CursorHost } from "./tokens/cursor_host.slint";
import { IconButton } from "./base/icon_button.slint";
import { MessageItem, PendingRequestItem, TerminalItem, DropdownEntry, LocalTerminalItem, SkillOption, McpServerOption } from "./types.slint";
import { MessageCard } from "./components/message_card.slint";
import { ChatInputLayout } from "./components/chat_input_layout.slint";
import { UserBubble } from "./chat-view/components/message/user_bubble.slint";
import { AgentBubble } from "./chat-view/components/message/agent_bubble.slint";
import { ToolEventRow } from "./chat-view/components/message/tool_event_row.slint";
import { PermissionCard } from "./components/permission_card.slint";
import { TerminalCard } from "./components/terminal_card.slint";
import { LocalTerminalCard } from "./components/local_terminal_card.slint";

// Header + message stream + compose bar -- Phase 3 of
// chat-panel-ui-theme-parity.md. Visual source: ui_html/index.html's
// "Thread Header" section (icon/title/desc/agent chip/layout label) and
// "Input Area" section (textarea look, state dot, hint text, Send
// Command button). v1 fixes on the HTML's "ltr" bubble alignment (user
// right, everything else left) -- see `message_card.slint`'s doc comment
// for why tool-call gets the richer timeline-style card instead of the
// bubble layout's flat text dump.
export component ChatArea inherits Rectangle {
    in property <string> active-thread-name: "";
    in property <string> active-thread-description: "";
    // The active thread's effective background-session mode -- drives the
    // header toggle's active state; flipping it re-runs the same per-thread
    // override the settings sheet writes.
    in property <bool> active-thread-background: false;
    callback toggle-background();
    in property <[MessageItem]> messages: [];
    // Phase 3 step 2: an upward user scroll which reaches the actual top
    // boundary asks Rust to prepend the next local JSONL page. The visible
    // button remains as an accessible fallback for keyboard/screen-reader
    // users and for a very short transcript with no scroll range.
    in property <bool> has-older-messages: false;
    in-out property <bool> loading-older-messages: false;
    callback load-older-requested();
    in property <string> agent-badge: "agent . ask";
    in property <string> connection-status: "Connecting...";
    in property <string> last-error: "";
    callback error-banner-dismissed();
    in property <bool> sending: false;
    in property <PendingRequestItem> pending-request;
    in property <[TerminalItem]> terminals: [];
    // Client-local PTY terminal addition -- see `local_terminal_card.
    // slint`'s doc comment. `local-terminal.open == false` (the
    // all-empty default) hides both the header toggle's active state
    // and the card entirely, same "no Option<T>, use an all-default
    // struct" convention `PendingRequestItem` already established.
    in property <LocalTerminalItem> local-terminal;
    in-out property <string> compose-text: "";
    // Mode/model selector addition: the *currently displayed* thread's
    // live capability advertisement (`AgentBridge::session_modes`/
    // `config_options`, flattened into domain-neutral `DropdownEntry` rows
    // via `models::to_mode_dropdown_entries`/`to_config_dropdown_entries`).
    // Each defaults to empty, which hides its own selector in the compose
    // bar's second row -- capability-gating contract per [`DropdownEntry`].
    in property <[DropdownEntry]> mode-dropdown-entries: [];
    in property <[DropdownEntry]> config-dropdown-entries: [];
    // The active mode's display name for the mode-selector trigger (empty
    // until a mode is advertised; the trigger falls back to "Mode").
    in property <string> mode-trigger-label: "";
    // Active model/config option display name for the model trigger
    // (empty until advertised; trigger falls back to "Model").
    in property <string> config-trigger-label: "";
    // Session context usage for the compose-bar context ring (ui.yaml).
    in property <float> context-ratio: 0.0;
    in property <int> context-used-tokens: 0;
    in property <int> context-limit-tokens: 0;
    // Catalogs for compose `/` `@` `#` popups.
    in property <[SkillOption]> skill-options: [];
    in property <[McpServerOption]> mcp-options: [];
    in property <[string]> file-options: [];
    callback mode-selected(string);
    callback config-option-selected(string, string);
    callback context-view-requested();
    callback send-requested();
    callback stop-requested();
    callback settings-requested();
    callback new-thread-requested();
    callback thread-rename-started();
    callback thread-rename-cancelled();
    callback thread-rename-confirmed(string);
    callback toggle-expanded(int);
    callback approve-request();
    callback reject-request();
    // One-of permission option pick (optionId from ACP / synthetic id).
    callback permission-option-selected(string);
    callback expand-terminal(string);
    callback local-terminal-toggle-requested();
    callback local-terminal-key-input(string);
    callback local-terminal-expand-requested();
    callback local-terminal-close-requested();
    // Modal overlays call this through ChatPanel after closing so keyboard
    // focus returns to the composer instead of remaining on stale terminal
    // content or falling back to the host dock.
    callback restore-compose-focus();
    // Panel-level keybindings (app.slint) re-dispatched while compose owns
    // focus — returns accept when a shortcut was handled.
    callback panel-shortcut(KeyEvent) -> EventResult;
    out property <bool> compose-has-focus: chat-input.compose-has-focus;
    out property <bool> local-terminal-has-focus:
        local-terminal.open && local-terminal-card.has-focus;
    // Mode/model dropdown search + mention popup filter -- see
    // FilterSearchBar.input-has-focus's doc comment.
    out property <bool> secondary-text-input-has-focus:
        chat-input.secondary-text-input-has-focus;

    // --- Demo approval (local one-of card, no ACP round-trip) ------------
    // Type one of these in the compose box and press Send / Enter:
    //   /demo-permission
    //   /demo-approve
    //   demo permission
    // Opens the same PermissionCard UI the host fills from real
    // session/request_permission events. Pick an option (or Esc /
    // Ctrl+Enter) to dismiss. Host pending-request always wins when active.
    property <bool> demo-approval-active: false;
    property <string> demo-approval-summary:
        "The agent wants to run: cargo test -p panel-rust --lib permission";

    pure function is-demo-permission-trigger(t: string) -> bool {
        // Exact matches (optional trailing space). Keep the set small so
        // real chat about "permission" is never hijacked.
        return t == "/demo-permission"
            || t == "/demo-permission "
            || t == "/demo-approve"
            || t == "/demo-approve "
            || t == "demo permission"
            || t == "demo permission ";
    }

    property <PendingRequestItem> demo-pending: {
        active: demo-approval-active,
        relay-id: "demo-local",
        method: "session/request_permission",
        title: "Permission requested",
        summary: demo-approval-summary,
        supported: true,
        options: [
            { option-id: "allow-once", name: "Allow once", kind: "allow_once", is-allow: true },
            { option-id: "allow-always", name: "Allow always", kind: "allow_always", is-allow: true },
            { option-id: "reject-once", name: "Reject", kind: "reject_once", is-allow: false },
        ],
    };

    // Host relay wins; otherwise show the local demo card.
    property <PendingRequestItem> shown-pending:
        pending-request.active ? pending-request : demo-pending;

    // Exposed so ChatPanel Escape / Ctrl+Enter treat demo like a real
    // pending request (app.slint checks pending-request.active — also
    // mirror via out for host shortcuts if needed).
    out property <bool> has-pending-approval: shown-pending.active;

    // Scratch so we never pass compose-text twice into helpers (SharedString
    // move quirk in generated Rust — same pattern as mention-filter).
    property <string> demo-trigger-scratch: "";

    function close-demo-approval() {
        demo-approval-active = false;
    }

    function handle-send() {
        root.demo-trigger-scratch = root.compose-text;
        if (root.is-demo-permission-trigger(root.demo-trigger-scratch)) {
            root.demo-approval-summary =
                "Demo approval triggered by: \"" + root.demo-trigger-scratch + "\"";
            root.demo-approval-active = true;
            root.compose-text = "";
            root.demo-trigger-scratch = "";
            return;
        }
        root.demo-trigger-scratch = "";
        root.send-requested();
    }

    function handle-permission-option(option-id: string) {
        if (root.demo-approval-active && !root.pending-request.active) {
            // Local demo only — dismiss and keep option id in summary
            // so the click is visible without a host.
            root.demo-approval-summary = "Demo selected: " + option-id + " (dismissed)";
            root.close-demo-approval();
            return;
        }
        root.permission-option-selected(option-id);
    }

    function handle-approve() {
        if (root.demo-approval-active && !root.pending-request.active) {
            root.demo-approval-summary = "Demo selected: allow-once (Ctrl+Enter)";
            root.close-demo-approval();
            return;
        }
        root.approve-request();
    }

    function handle-reject() {
        if (root.demo-approval-active && !root.pending-request.active) {
            root.demo-approval-summary = "Demo selected: reject-once (Esc)";
            root.close-demo-approval();
            return;
        }
        root.reject-request();
    }

    // Called from ChatPanel keyboard shortcuts (Esc / Ctrl+Enter).
    public function approve-pending() {
        root.handle-approve();
    }
    public function reject-pending() {
        root.handle-reject();
    }

    // The native v1 dock launches at 20% width. Keep the chat surface in
    // its compact side-panel treatment even after a user widens it; this
    // avoids a width-to-implicit-size binding loop in Slint layouts.
    in property <bool> compact: true;
    in property <bool> narrow: false;
    // When the thread rail is collapsed (or narrow forces the rail), match
    // the sidebar toggle header height.
    in property <bool> sidebar-expanded: true;
    property <bool> match-title-bar: !sidebar-expanded || narrow;
    in property <bool> rename-editing: false;
    in property <string> rename-focus-target: "";
    property <bool> rename-focus-pending: false;
    in-out property <string> rename-draft: "";
    // Filled hand is reserved for a pending decision/input that needs the
    // user's attention. Never use it for ordinary connection states.
    property <bool> status-needs-attention: root.shown-pending.active;
    // Shared with the collapsed sidebar toggle header.
    property <length> title-bar-h: 36px;
    // Allow compose `/` `@` `#` popup to paint above the message stream.
    clip: false;
    background: Theme.bg-chat;

    public function begin-thread-rename() {
        if (root.active-thread-name == "") {
            return;
        }
        root.thread-rename-started();
    }

    function cancel-thread-rename() {
        root.rename-focus-pending = false;
        root.thread-rename-cancelled();
    }

    function confirm-thread-rename() {
        if (root.rename-draft != "") {
            root.thread-rename-confirmed(root.rename-draft);
        }
    }

    changed rename-editing => {
        if (root.rename-editing && root.rename-focus-target == "chat") {
            root.rename-focus-pending = true;
        }
    }

    // Phase 6 (scroll-position preservation + jump-to-latest): whether the
    // user is following the newest message. Live updates only snap the
    // message Flickable back to the bottom while this holds; a user scroll
    // away flips it off (and reveals the floating jump button), a scroll
    // back to the bottom flips it on again. Pure UI state, no Rust.
    property <bool> stick-to-bottom: true;
    // How far the message Flickable can scroll -- viewport-y ranges from
    // `-msg-max-scroll` (bottom) to 0 (top).
    property <length> msg-max-scroll: Math.max(0px, message-scroll.viewport-height - message-scroll.height);

    main-layout := VerticalLayout {
        width: parent.width;
        height: parent.height;
        min-height: parent.height;
        preferred-height: parent.height;
        vertical-stretch: 1;
        // Thread header — ui.yaml `chat-view-top`.
        // When the left rail is collapsed (`match-title-bar`), its height
        // matches the collapsed sidebar toggle header.
        Rectangle {
            height: root.match-title-bar ? root.title-bar-h
                : (compact ? 48px : 56px);
            // Match sidebar title strip surface when collapsed.
            background: root.match-title-bar ? Theme.bg-card : Theme.bg-chat;
            property <angle> header-spin: 0deg;
            header-spin-timer := Timer {
                interval: 80ms;
                running: root.sending || connection-status == "Connecting...";
                triggered => { header-spin += 30deg; }
            }
            HorizontalLayout {
                width: 100%;
                height: 100%;
                // Sidebar title uses space-2/4 padding + icon-md (16px).
                padding-left: root.match-title-bar
                    ? (compact ? Metrics.space-2 : Metrics.space-4)
                    : (compact ? Metrics.space-3 : Metrics.space-6);
                padding-right: root.match-title-bar
                    ? (compact ? Metrics.space-2 : Metrics.space-4)
                    : (compact ? Metrics.space-3 : Metrics.space-6);
                spacing: root.match-title-bar
                    ? (compact ? Metrics.space-1 : Metrics.space-3)
                    : (compact ? Metrics.space-3 : Metrics.space-5);
                alignment: stretch;
                cross-axis-alignment: center;

                // --- LEFT (ui.yaml): status icon + thread title ---
                left-cluster := HorizontalLayout {
                    spacing: root.match-title-bar ? Metrics.space-2 : Metrics.space-3;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                    alignment: stretch;
                    cross-axis-alignment: center;
                    rename-focus-delay := Timer {
                        interval: 1ms;
                        running: root.rename-focus-pending;
                        triggered => {
                            root.rename-focus-pending = false;
                            rename-input.focus();
                        }
                    }
                    // Status icon — Metrics.icon-md (16px), same as sidebar title icons.
                    // No height: parent.height (binding loop with layoutinfo-v).
                    if root.sending || connection-status == "Connecting..." : Rectangle {
                        width: Metrics.icon-md;
                        height: Metrics.icon-md;
                        horizontal-stretch: 0;
                        vertical-stretch: 0;
                        Icon {
                            source: @image-url("./assets/icons/loader-circle.svg");
                            size: Metrics.icon-md;
                            color: Theme.bg-primary;
                            transform-rotation: header-spin;
                            transform-origin: { x: 8px, y: 8px };
                        }
                    }
                    if !(root.sending || connection-status == "Connecting...")
                        && root.status-needs-attention : Icon {
                        source: @image-url("./assets/icons/hand-filled.svg");
                        size: Metrics.icon-md;
                        color: Theme.bg-primary;
                        horizontal-stretch: 0;
                        vertical-stretch: 0;
                    }
                    if !(root.sending || connection-status == "Connecting...")
                        && !root.status-needs-attention : Rectangle {
                        width: 6px;
                        height: 6px;
                        border-radius: 3px;
                        background: Theme.text-muted;
                        horizontal-stretch: 0;
                        vertical-stretch: 0;
                    }
                    if !root.rename-editing : Text {
                        text: active-thread-name != "" ? active-thread-name : "No thread";
                        color: Theme.text-primary;
                        // Match sidebar "Chats" title when rail collapsed.
                        font-size: (root.match-title-bar ? 14px
                            : (compact ? 13px : 15px)) * Theme.font-scale;
                        font-weight: 600;
                        font-family: Theme.font-sans;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        overflow: elide;
                    }
                    rename-editor := Rectangle {
                        visible: root.rename-editing;
                        height: root.match-title-bar ? 26px : 30px;
                        background: Theme.bg-sidebar;
                        border-width: 1px;
                        border-color: Theme.border-default;
                        border-radius: Theme.radius-sm;
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 72px;
                        rename-input := TextInput {
                            x: Metrics.space-3;
                            y: 0px;
                            width: parent.width - 2 * Metrics.space-3;
                            height: parent.height;
                            accessible-label: "Thread name";
                            text <=> root.rename-draft;
                            color: Theme.text-primary;
                            font-family: Theme.font-sans;
                            font-size: (root.match-title-bar ? 13px
                                : (compact ? 12px : 14px)) * Theme.font-scale;
                            vertical-alignment: center;
                            single-line: true;
                            key-pressed(event) => {
                                if (event.text == Key.Return) {
                                    root.confirm-thread-rename();
                                    return EventResult.accept;
                                }
                                if (event.text == Key.Escape) {
                                    root.cancel-thread-rename();
                                    return EventResult.accept;
                                }
                                return EventResult.reject;
                            }
                        }
                    }
                    if !root.rename-editing && active-thread-name != "" : IconButton {
                        btn-width: 20px;
                        btn-height: 20px;
                        button-accessible-label: "Rename thread";
                        clicked => { root.begin-thread-rename(); }
                        Icon {
                            source: @image-url("./assets/icons/pencil.svg");
                            size: 13px;
                            color: Theme.text-muted;
                        }
                    }
                    if root.rename-editing : IconButton {
                        btn-width: 20px;
                        btn-height: 20px;
                        button-accessible-label: "Save thread name";
                        clicked => { root.confirm-thread-rename(); }
                        Icon {
                            source: @image-url("./assets/icons/check.svg");
                            size: 14px;
                            color: Theme.bg-primary;
                        }
                    }
                    if root.rename-editing : IconButton {
                        btn-width: 20px;
                        btn-height: 20px;
                        button-accessible-label: "Cancel thread rename";
                        clicked => { root.cancel-thread-rename(); }
                        Icon {
                            source: @image-url("./assets/icons/x.svg");
                            size: 14px;
                            color: Theme.text-muted;
                        }
                    }
                }

                // --- RIGHT (ui.yaml): agent name [top right] + tools ---
                right-cluster := HorizontalLayout {
                    spacing: root.match-title-bar ? Metrics.space-2
                        : (compact ? Metrics.space-2 : Metrics.space-3);
                    horizontal-stretch: 0;
                    alignment: end;
                    cross-axis-alignment: center;

                    Text {
                        text: agent-badge;
                        color: Theme.text-primary;
                        font-size: (root.match-title-bar ? 10px : 11px) * Theme.font-scale;
                        font-family: Theme.font-mono;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        horizontal-stretch: 0;
                        vertical-stretch: 0;
                        overflow: elide;
                        max-width: compact ? 120px : 200px;
                    }

                    if narrow : IconButton {
                        button-accessible-label: "New thread";
                        clicked => { new-thread-requested(); }
                        Icon {
                            source: @image-url("./assets/icons/plus.svg");
                            size: Metrics.icon-md;
                            color: Theme.bg-primary;
                        }
                    }
                    IconButton {
                        active: local-terminal.open;
                        button-accessible-label: "Toggle local terminal";
                        clicked => { local-terminal-toggle-requested(); }
                        Text {
                            text: "\u{2318}";
                            color: local-terminal.open ? Theme.bg-primary : Theme.text-secondary;
                            font-size: 12px * Theme.font-scale;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
        Rectangle {
            // Separator under the header -- Slint has no per-edge
            // border, so a thin standalone Rectangle stands in for the
            // HTML's `border-b border-sys-border`.
            height: 1px;
            background: Theme.border-default;
        }
        // Send/session-attach failure banner. Previously this only ever
        // surfaced as a small "Error: ..." sidebar subtitle under the
        // thread's name (models::describe_thread's error branch) --
        // easy to miss entirely while looking at the transcript itself,
        // which is exactly the "sent a message, got no visible response
        // or explanation at all" symptom this closes. Dismissing just
        // clears the Rust-side per-thread error string; a later real
        // error re-shows it.
        if root.last-error != "" : Rectangle {
            height: error-banner-text.preferred-height + 2 * Metrics.space-3;
            background: Theme.bg-card;
            border-color: #b91c1c;
            border-width: 1px;
            HorizontalLayout {
                padding-left: Metrics.space-6;
                padding-right: Metrics.space-6;
                padding-top: Metrics.space-3;
                padding-bottom: Metrics.space-3;
                spacing: Metrics.space-3;
                error-banner-text := Text {
                    text: "⚠ " + root.last-error;
                    color: #ef4444;
                    font-size: 10px * Theme.font-scale;
                    font-family: Theme.font-mono;
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                }
                dismiss-touch := TouchArea {
                    mouse-cursor: pointer;
                    width: 16px;
                    accessible-role: button;
                    accessible-label: "Dismiss error";
                    clicked => { root.error-banner-dismissed(); }
                    changed has-hover => { CursorHost.kind = self.has-hover ? "pointer" : "default"; }
                    Text {
                        text: "\u{2715}";
                        color: Theme.text-muted;
                        font-size: 10px * Theme.font-scale;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
        message-area := Rectangle {
            // The one elastic region in the chat column: the Flickable fills
            // it and the floating jump-to-latest button overlays its
            // bottom-right corner.
            vertical-stretch: 1;
            preferred-height: 0px;
            min-height: 0px;
            message-scroll := Flickable {
                width: 100%;
                height: 100%;
                // Live updates grow `viewport-height`; snap back to the bottom
                // only while the user is following the latest message, so a
                // read-back-in-history scroll position is never stolen.
                changed viewport-height => {
                    if (root.stick-to-bottom) {
                        self.viewport-y = -root.msg-max-scroll;
                    }
                }
                // A user scroll updates whether they're following the bottom
                // and -- only a user-originated movement at the real top
                // boundary -- may page in older history.
                flicked => {
                    root.stick-to-bottom = (self.viewport-y + root.msg-max-scroll) < 8px;
                    if has-older-messages
                        && !loading-older-messages
                        && self.viewport-y >= -1px {
                        loading-older-messages = true;
                        load-older-requested();
                    }
                }
                VerticalLayout {
                // Match ChatInputLayout shell (pad-2xl H / pad-xl V) so the
                // message column lines up with the compose bar.
                padding-left: Metrics.pad-2xl;
                padding-right: Metrics.pad-2xl;
                padding-top: Metrics.pad-xl;
                padding-bottom: Metrics.pad-xl;
                spacing: compact ? Metrics.gap-md : Metrics.gap-lg;
                if has-older-messages : Rectangle {
                    height: 22px;
                    border-radius: Theme.radius-sm;
                    background: load-older-button.has-hover ? Theme.bg-primary-container : Theme.bg-sidebar;
                    animate background { duration: 100ms; }
                    load-older-button := TouchArea {
                        mouse-cursor: loading-older-messages ? default : pointer;
                        accessible-role: button;
                        accessible-label: "Load older messages";
                        enabled: !loading-older-messages;
                        accessible-action-default => {
                            if !loading-older-messages {
                                loading-older-messages = true;
                                load-older-requested();
                            }
                        }
                        clicked => {
                            if !loading-older-messages {
                                loading-older-messages = true;
                                load-older-requested();
                            }
                        }
                        changed has-hover => {
                            CursorHost.kind = (self.has-hover && !loading-older-messages) ? "pointer" : "default";
                        }
                    }
                    Text {
                        text: loading-older-messages ? "Loading older messages..." : "Load older messages";
                        color: Theme.text-secondary;
                        font-size: 10px * Theme.font-scale;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                // chat-items-redesign.md #11: kind switch — user /
                // agent|thinking / tool-event / legacy MessageCard.
                for msg[i] in messages : HorizontalLayout {
                    property <bool> is-user: msg.kind == "user";
                    property <bool> is-agent-side: msg.kind == "agent"
                        || msg.kind == "thinking";
                    property <bool> is-tool-event: msg.kind == "tool_use"
                        || msg.kind == "mcp_server_call"
                        || msg.kind == "skill_load"
                        || msg.kind == "skill_use";
                    // Active-session rail on the *latest* row while the
                    // thread is loading (same `sending` state as the
                    // header/sidebar spinner). Pulse *flows* top → bottom.
                    property <bool> is-live-tail:
                        root.sending && i == root.messages.length - 1;
                    // Fixed gutter widths — never toggle 0↔N when the live
                    // rail appears, or the bubble column jumps horizontally.
                    property <length> rail-w: 3px;
                    property <length> rail-gap: Metrics.space-3;
                    property <length> user-indent: 8px;
                    // 0..1 progress of the traveling highlight.
                    property <float> flow-t: 0.0;
                    property <length> flow-blob: 36px;
                    live-flow-timer := Timer {
                        interval: 40ms;
                        running: is-live-tail;
                        triggered => {
                            // ~1.2s full trip (30 × 40ms), then loop.
                            flow-t = flow-t + 0.033;
                            if (flow-t > 1.0) {
                                flow-t = 0.0;
                            }
                        }
                    }

                    // Left rail track — always reserved for non-user rows
                    // so agent/tool width is stable when is-live-tail flips.
                    // User rows keep a fixed indent instead (no rail).
                    live-rail := Rectangle {
                        // Always claim rail-w for non-user rows (placeholder
                        // when idle) so live pulse never changes row width.
                        width: is-user ? 0px : rail-w;
                        horizontal-stretch: 0;
                        min-height: 12px;
                        clip: true;
                        border-radius: 1.5px;
                        // Dim track only while live; transparent placeholder
                        // otherwise (same width, no layout shift).
                        background: is-live-tail
                            ? Theme.bg-primary.with-alpha(0.18)
                            : transparent;

                        // Bright segment that travels down the rail.
                        if is-live-tail : Rectangle {
                            width: parent.width;
                            height: min(flow-blob, parent.height);
                            y: (parent.height + flow-blob) * flow-t - flow-blob;
                            border-radius: 1.5px;
                            background: Theme.bg-primary.with-alpha(0.95);
                        }
                        if is-live-tail : Rectangle {
                            width: parent.width;
                            height: min(flow-blob * 0.55, parent.height);
                            y: (parent.height + flow-blob) * flow-t - flow-blob * 1.45;
                            border-radius: 1.5px;
                            background: Theme.bg-primary.with-alpha(0.35);
                        }
                    }
                    // Gap after rail / user indent — fixed per kind.
                    Rectangle {
                        width: is-user ? user-indent : rail-gap;
                        horizontal-stretch: 0;
                    }
                    if is-user : UserBubble {
                        // Stretch within the available chat column instead
                        // of binding width back to the Flickable viewport.
                        // A fixed width clips at the 20%-dock target, while
                        // a parent.width binding creates a Slint layout loop.
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        item: msg;
                    }
                    if is-agent-side : AgentBubble {
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        vertical-stretch: 0;
                        item: msg;
                    }
                    if is-tool-event : ToolEventRow {
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        vertical-stretch: 0;
                        kind: msg.kind;
                        first-use: msg.first-use;
                        text: msg.text;
                        cap-height: root.height * 0.3;
                        // chat-items-remaining-wiring.md #4: execution-view
                        // content (terminal/api-call) click-to-open state,
                        // same `expanded`/`index` round-trip `MessageCard`
                        // already uses for its own log body.
                        raw-input: msg.raw-input;
                        raw-output: msg.raw-output;
                        expanded: msg.expanded;
                        index: msg.index;
                        toggle-expanded(idx) => { toggle-expanded(idx); }
                    }
                    if !is-user && !is-agent-side && !is-tool-event : card := MessageCard {
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        item: msg;
                        toggle-expanded(idx) => { toggle-expanded(idx); }
                    }
                    Rectangle { width: 0px; }
                }
            }
            }
            // Floating jump-to-latest button -- shown only while the user has
            // scrolled away from the bottom. It swaps its down-arrow for the
            // approval "hand" glyph when a permission request is pending, so a
            // scrolled-up user still gets a single affordance pointing at the
            // decision waiting below (the docked PermissionCard).
            if !root.stick-to-bottom : Rectangle {
                width: 32px;
                height: 32px;
                x: parent.width - self.width - Metrics.space-6;
                y: parent.height - self.height - Metrics.space-6;
                border-radius: self.height / 2;
                background: jump-touch.has-hover ? Theme.bg-primary.with-alpha(0.85) : Theme.bg-primary;
                animate background { duration: 100ms; }
                border-color: Theme.border-strong;
                border-width: 1px;
                jump-touch := TouchArea {
                    mouse-cursor: pointer;
                    accessible-role: button;
                    accessible-label: root.shown-pending.active ? "Jump to pending request" : "Jump to latest message";
                    accessible-action-default => {
                        root.stick-to-bottom = true;
                        message-scroll.viewport-y = -root.msg-max-scroll;
                    }
                    clicked => {
                        root.stick-to-bottom = true;
                        message-scroll.viewport-y = -root.msg-max-scroll;
                    }
                    changed has-hover => { CursorHost.kind = self.has-hover ? "pointer" : "default"; }
                }
                Icon {
                    source: root.shown-pending.active
                        ? @image-url("./assets/icons/hand.svg")
                        : @image-url("./assets/icons/arrow-down.svg");
                    size: Metrics.icon-sm;
                    color: Theme.text-on-primary;
                }
            }
        }
        // Terminal-view addition: one bounded max-height card per live/
        // finished agent-created terminal on the active thread, docked
        // above the compose bar like the permission card below --
        // deliberately outside the scrollable message Flickable so a
        // running command stays visible without scrolling.
        for term in terminals : Rectangle {
            background: Theme.bg-chat;
            HorizontalLayout {
                padding: compact ? 6px : 10px;
                TerminalCard {
                    item: term;
                    compact: compact;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                    expand => { expand-terminal(term.terminal-id); }
                }
            }
        }
        // Client-local PTY terminal card -- same docking spot as the
        // agent-created terminal cards above (outside the scrollable
        // message Flickable), shown whenever the user has toggled it
        // open via the header button.
        Rectangle {
            height: local-terminal.open ? local-terminal-card.height : 0px;
            visible: local-terminal.open;
            background: Theme.bg-chat;
            HorizontalLayout {
                padding: compact ? 6px : 10px;
                local-terminal-card := LocalTerminalCard {
                    item: local-terminal;
                    compact: compact;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                    expand => { local-terminal-expand-requested(); }
                    key-input(text) => { local-terminal-key-input(text); }
                    close-requested => { local-terminal-close-requested(); }
                }
            }
        }
        // Approval band — full-width bg-approval-band so the strip reads
        // as a decision zone vs chat (bg-chat) and compose (bg-sidebar).
        if root.shown-pending.active : VerticalLayout {
            vertical-stretch: 0;
            // Top hairline only (full border on the band looked heavy).
            Rectangle {
                height: 1px;
                background: Theme.border-strong;
            }
            Rectangle {
                vertical-stretch: 0;
                background: Theme.bg-approval-band;
                HorizontalLayout {
                    width: 100%;
                    padding-left: Metrics.pad-2xl;
                    padding-right: Metrics.pad-2xl;
                    padding-top: Metrics.pad-xs;
                    padding-bottom: Metrics.pad-xs;
                    alignment: stretch;
                    PermissionCard {
                        item: root.shown-pending;
                        horizontal-stretch: 1;
                        vertical-stretch: 0;
                        preferred-width: 0px;
                        min-width: 0px;
                        option-selected(option-id) => { root.handle-permission-option(option-id); }
                        approve() => { root.handle-approve(); }
                        reject() => { root.handle-reject(); }
                    }
                }
            }
        }
        // Separator above the compose bar.
        Rectangle {
            height: 1px;
            background: Theme.border-default;
        }
        // User input + mode/model selectors (extracted ChatInputLayout).
        chat-input := ChatInputLayout {
            width: 100%;
            horizontal-stretch: 1;
            compose-text <=> compose-text;
            sending: sending;
            mode-dropdown-entries: mode-dropdown-entries;
            config-dropdown-entries: config-dropdown-entries;
            mode-trigger-label: mode-trigger-label;
            config-trigger-label: config-trigger-label;
            context-ratio: context-ratio;
            context-used-tokens: context-used-tokens;
            context-limit-tokens: context-limit-tokens;
            skill-options: skill-options;
            mcp-options: mcp-options;
            file-options: file-options;
            send-requested => { root.handle-send(); }
            stop-requested => { stop-requested(); }
            mode-selected(id) => { mode-selected(id); }
            config-option-selected(option-id, value) => { config-option-selected(option-id, value); }
            context-view-requested => { context-view-requested(); }
            panel-shortcut(event) => { return panel-shortcut(event); }
        }
    }
    restore-compose-focus => { chat-input.focus-compose(); }
}
