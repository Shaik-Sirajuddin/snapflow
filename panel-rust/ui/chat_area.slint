import { Theme } from "./tokens/theme.slint";
import { Metrics } from "./tokens/metrics.slint";
import { Icon } from "./base/icon.slint";
import { CursorHost } from "./tokens/cursor_host.slint";
import { IconButton } from "./base/icon_button.slint";
import { MessageItem, PendingRequestItem, TerminalItem, DropdownEntry, LocalTerminalItem } from "./types.slint";
import { MessageCard } from "./components/message_card.slint";
import { ChatInputLayout } from "./components/chat_input_layout.slint";
import { UserBubble } from "./chat-view/components/message/user_bubble.slint";
import { AgentBubble } from "./chat-view/components/message/agent_bubble.slint";
import { ToolEventRow } from "./chat-view/components/message/tool_event_row.slint";
import { PermissionCard } from "./components/permission_card.slint";
import { TerminalCard } from "./components/terminal_card.slint";
import { LocalTerminalCard } from "./components/local_terminal_card.slint";

// Header + message stream + compose bar -- Phase 3 of
// chat-panel-ui-theme-parity.md. Visual source: ui_html/index.html's
// "Thread Header" section (icon/title/desc/agent chip/layout label) and
// "Input Area" section (textarea look, state dot, hint text, Send
// Command button). v1 fixes on the HTML's "ltr" bubble alignment (user
// right, everything else left) -- see `message_card.slint`'s doc comment
// for why tool-call gets the richer timeline-style card instead of the
// bubble layout's flat text dump.
export component ChatArea inherits Rectangle {
    in property <string> active-thread-name: "";
    in property <string> active-thread-description: "";
    // The active thread's effective background-session mode -- drives the
    // header toggle's active state; flipping it re-runs the same per-thread
    // override the settings sheet writes.
    in property <bool> active-thread-background: false;
    callback toggle-background();
    in property <[MessageItem]> messages: [];
    // Phase 3 step 2: an upward user scroll which reaches the actual top
    // boundary asks Rust to prepend the next local JSONL page. The visible
    // button remains as an accessible fallback for keyboard/screen-reader
    // users and for a very short transcript with no scroll range.
    in property <bool> has-older-messages: false;
    in-out property <bool> loading-older-messages: false;
    callback load-older-requested();
    in property <string> agent-badge: "agent . ask";
    in property <string> connection-status: "Connecting...";
    in property <bool> sending: false;
    in property <PendingRequestItem> pending-request;
    in property <[TerminalItem]> terminals: [];
    // Client-local PTY terminal addition -- see `local_terminal_card.
    // slint`'s doc comment. `local-terminal.open == false` (the
    // all-empty default) hides both the header toggle's active state
    // and the card entirely, same "no Option<T>, use an all-default
    // struct" convention `PendingRequestItem` already established.
    in property <LocalTerminalItem> local-terminal;
    in-out property <string> compose-text: "";
    // Mode/model selector addition: the *currently displayed* thread's
    // live capability advertisement (`AgentBridge::session_modes`/
    // `config_options`, flattened into domain-neutral `DropdownEntry` rows
    // via `models::to_mode_dropdown_entries`/`to_config_dropdown_entries`).
    // Each defaults to empty, which hides its own selector in the compose
    // bar's second row -- capability-gating contract per [`DropdownEntry`].
    in property <[DropdownEntry]> mode-dropdown-entries: [];
    in property <[DropdownEntry]> config-dropdown-entries: [];
    // The active mode's display name for the mode-selector trigger (empty
    // until a mode is advertised; the trigger falls back to "Mode").
    in property <string> mode-trigger-label: "";
    callback mode-selected(string);
    callback config-option-selected(string, string);
    callback send-requested();
    callback stop-requested();
    callback settings-requested();
    callback new-thread-requested();
    callback toggle-expanded(int);
    callback approve-request();
    callback reject-request();
    callback expand-terminal(string);
    callback local-terminal-toggle-requested();
    callback local-terminal-key-input(string);
    callback local-terminal-expand-requested();
    callback local-terminal-close-requested();
    // Modal overlays call this through ChatPanel after closing so keyboard
    // focus returns to the composer instead of remaining on stale terminal
    // content or falling back to the host dock.
    callback restore-compose-focus();
    // Panel-level keybindings (app.slint) re-dispatched while compose owns
    // focus — returns accept when a shortcut was handled.
    callback panel-shortcut(KeyEvent) -> EventResult;
    out property <bool> compose-has-focus: chat-input.compose-has-focus;
    out property <bool> local-terminal-has-focus:
        local-terminal.open && local-terminal-card.has-focus;

    // The native v1 dock launches at 20% width. Keep the chat surface in
    // its compact side-panel treatment even after a user widens it; this
    // avoids a width-to-implicit-size binding loop in Slint layouts.
    in property <bool> compact: true;
    in property <bool> narrow: false;
    background: Theme.bg-chat;

    // Phase 6 (scroll-position preservation + jump-to-latest): whether the
    // user is following the newest message. Live updates only snap the
    // message Flickable back to the bottom while this holds; a user scroll
    // away flips it off (and reveals the floating jump button), a scroll
    // back to the bottom flips it on again. Pure UI state, no Rust.
    property <bool> stick-to-bottom: true;
    // How far the message Flickable can scroll -- viewport-y ranges from
    // `-msg-max-scroll` (bottom) to 0 (top).
    property <length> msg-max-scroll: Math.max(0px, message-scroll.viewport-height - message-scroll.height);

    main-layout := VerticalLayout {
        width: parent.width;
        height: parent.height;
        min-height: parent.height;
        preferred-height: parent.height;
        vertical-stretch: 1;
        // Thread header -- icon glyph + title/description + right-hand
        // agent-name chip and static layout label (HTML's layout
        // switcher is out of scope, per the plan; this always reads
        // "CHAT").
        Rectangle {
            height: compact ? 44px : 52px;
            background: Theme.bg-chat;
            HorizontalLayout {
                padding: compact ? Metrics.space-3 : Metrics.space-6;
                spacing: compact ? Metrics.space-3 : Metrics.space-5;
                Rectangle {
                    width: compact ? 22px : 28px;
                    height: compact ? 22px : 28px;
                    background: Theme.bg-primary-container;
                    border-color: Theme.border-default;
                    border-width: 1px;
                    border-radius: Theme.radius-sm;
                    Icon {
                        source: @image-url("./assets/icons/chevron-right.svg");
                        size: Metrics.icon-md;
                        color: Theme.bg-primary;
                    }
                }
                if !compact : VerticalLayout {
                    alignment: center;
                    spacing: 1px;
                    Text {
                        text: active-thread-name;
                        color: Theme.text-primary;
                        font-size: (compact ? 11px : 13px) * Theme.font-scale;
                        font-weight: 600;
                        font-family: Theme.font-sans;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        overflow: elide;
                    }
                    Text {
                        text: active-thread-description;
                        color: Theme.text-muted;
                        font-size: 10px * Theme.font-scale;
                        font-family: Theme.font-sans;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                        visible: !compact && active-thread-description != "";
                        // Same overflow-avoidance convention as the
                        // thread-name Text above: without preferred/min
                        // width pinned to 0, this Text's un-elided natural
                        // width (descriptions can run to
                        // THREAD_DESCRIPTION_MAX_CHARS) forces the whole
                        // header wider than the available small/tablet
                        // width instead of eliding.
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        overflow: elide;
                    }
                }
                Rectangle { }
                if !compact : Text {
                    text: "Agent:";
                    color: Theme.text-secondary;
                    font-size: 10px * Theme.font-scale;
                    font-family: Theme.font-sans;
                    vertical-alignment: center;
                }
                if !compact : Rectangle {
                    background: Theme.bg-canvas;
                    border-color: Theme.border-default;
                    border-width: 1px;
                    border-radius: Theme.radius-sm;
                    HorizontalLayout {
                        padding-left: Metrics.space-3;
                        padding-right: Metrics.space-3;
                        padding-top: Metrics.space-1;
                        padding-bottom: Metrics.space-1;
                        Text {
                            text: agent-badge;
                            color: Theme.text-primary;
                            font-size: 10px * Theme.font-scale;
                            font-family: Theme.font-mono;
                            vertical-alignment: center;
                        }
                    }
                }
                if !compact : Rectangle {
                    width: 1px;
                    background: Theme.border-default;
                }
                if !compact : Text {
                    text: "CHAT";
                    color: Theme.bg-primary;
                    font-size: 9px * Theme.font-scale;
                    font-weight: 700;
                    font-family: Theme.font-mono;
                    vertical-alignment: center;
                }
                if !compact : HorizontalLayout {
                    spacing: Metrics.space-1;
                    accessible-role: text;
                    accessible-label: "Connection status: " + connection-status;
                    // The inner Text already elides, but without pinning
                    // this wrapping layout's own preferred/min width to 0
                    // it can't actually shrink below its natural content
                    // width under space pressure -- same convention gap as
                    // the description Text above.
                    preferred-width: 0px;
                    min-width: 0px;
                    // Same left-end state-icon language as the sidebar's
                    // thread rows (see sidebar.slint) -- a spinner while
                    // still connecting, otherwise a plain idle dot.
                    if connection-status == "Connecting..." : Icon {
                        source: @image-url("./assets/icons/loader-circle.svg");
                        size: Metrics.icon-sm;
                        color: Theme.bg-primary;
                    }
                    if connection-status != "Connecting..." : Rectangle {
                        width: 6px;
                        height: 6px;
                        border-radius: 3px;
                        background: Theme.text-muted;
                    }
                    Text {
                        text: connection-status;
                        color: Theme.text-muted;
                        font-size: 9px * Theme.font-scale;
                        font-family: Theme.font-mono;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        overflow: elide;
                    }
                }
                if narrow : IconButton {
                    button-accessible-label: "New thread";
                    clicked => { new-thread-requested(); }
                    Text {
                        text: "+";
                        color: Theme.bg-primary;
                        font-size: 16px * Theme.font-scale;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                IconButton {
                    active: active-thread-background;
                    button-accessible-label: active-thread-background
                        ? "Disable background mode for this thread"
                        : "Enable background mode for this thread";
                    clicked => { toggle-background(); }
                    Icon {
                        source: @image-url("./assets/icons/moon.svg");
                        size: Metrics.icon-sm;
                        color: active-thread-background ? Theme.text-tertiary : Theme.text-secondary;
                    }
                }
                IconButton {
                    active: local-terminal.open;
                    button-accessible-label: "Toggle local terminal";
                    clicked => { local-terminal-toggle-requested(); }
                    Text {
                        text: "\u{2318}"; // same terminal glyph stand-in as TerminalCard
                        color: local-terminal.open ? Theme.bg-primary : Theme.text-secondary;
                        font-size: 12px * Theme.font-scale;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                // Settings lives at the bottom of the thread sidebar only.
            }
        }
        Rectangle {
            // Separator under the header -- Slint has no per-edge
            // border, so a thin standalone Rectangle stands in for the
            // HTML's `border-b border-sys-border`.
            height: 1px;
            background: Theme.border-default;
        }
        message-area := Rectangle {
            // The one elastic region in the chat column: the Flickable fills
            // it and the floating jump-to-latest button overlays its
            // bottom-right corner.
            vertical-stretch: 1;
            preferred-height: 0px;
            min-height: 0px;
            message-scroll := Flickable {
                width: 100%;
                height: 100%;
                // Live updates grow `viewport-height`; snap back to the bottom
                // only while the user is following the latest message, so a
                // read-back-in-history scroll position is never stolen.
                changed viewport-height => {
                    if (root.stick-to-bottom) {
                        self.viewport-y = -root.msg-max-scroll;
                    }
                }
                // A user scroll updates whether they're following the bottom
                // and -- only a user-originated movement at the real top
                // boundary -- may page in older history.
                flicked => {
                    root.stick-to-bottom = (self.viewport-y + root.msg-max-scroll) < 8px;
                    if has-older-messages
                        && !loading-older-messages
                        && self.viewport-y >= -1px {
                        loading-older-messages = true;
                        load-older-requested();
                    }
                }
                VerticalLayout {
                // Match ChatInputLayout shell (pad-2xl H / pad-xl V) so the
                // message column lines up with the compose bar.
                padding-left: Metrics.pad-2xl;
                padding-right: Metrics.pad-2xl;
                padding-top: Metrics.pad-xl;
                padding-bottom: Metrics.pad-xl;
                spacing: compact ? Metrics.gap-md : Metrics.gap-lg;
                if has-older-messages : Rectangle {
                    height: 22px;
                    border-radius: Theme.radius-sm;
                    background: load-older-button.has-hover ? Theme.bg-primary-container : Theme.bg-sidebar;
                    animate background { duration: 100ms; }
                    load-older-button := TouchArea {
                        mouse-cursor: loading-older-messages ? default : pointer;
                        accessible-role: button;
                        accessible-label: "Load older messages";
                        enabled: !loading-older-messages;
                        accessible-action-default => {
                            if !loading-older-messages {
                                loading-older-messages = true;
                                load-older-requested();
                            }
                        }
                        clicked => {
                            if !loading-older-messages {
                                loading-older-messages = true;
                                load-older-requested();
                            }
                        }
                        changed has-hover => {
                            CursorHost.kind = (self.has-hover && !loading-older-messages) ? "pointer" : "default";
                        }
                    }
                    Text {
                        text: loading-older-messages ? "Loading older messages..." : "Load older messages";
                        color: Theme.text-secondary;
                        font-size: 10px * Theme.font-scale;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                // chat-items-redesign.md #11: kind switch — user /
                // agent|thinking / tool-event / legacy MessageCard.
                for msg[i] in messages : HorizontalLayout {
                    property <bool> is-user: msg.kind == "user";
                    property <bool> is-agent-side: msg.kind == "agent"
                        || msg.kind == "thinking";
                    property <bool> is-tool-event: msg.kind == "tool_use"
                        || msg.kind == "mcp_server_call"
                        || msg.kind == "skill_load"
                        || msg.kind == "skill_use";
                    // In the compact dock, full-width cards are more
                    // legible than the desktop right-anchored bubble
                    // treatment, which would leave user cards only a few
                    // pixels wide beside the thread list.
                    Rectangle { width: is-user ? 8px : 0px; }
                    if is-user : UserBubble {
                        // Stretch within the available chat column instead
                        // of binding width back to the Flickable viewport.
                        // A fixed width clips at the 20%-dock target, while
                        // a parent.width binding creates a Slint layout loop.
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        item: msg;
                    }
                    if is-agent-side : AgentBubble {
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        vertical-stretch: 0;
                        item: msg;
                    }
                    if is-tool-event : ToolEventRow {
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        vertical-stretch: 0;
                        kind: msg.kind;
                        first-use: msg.first-use;
                        text: msg.text;
                        cap-height: root.height * 0.3;
                        // chat-items-remaining-wiring.md #4: execution-view
                        // content (terminal/api-call) click-to-open state,
                        // same `expanded`/`index` round-trip `MessageCard`
                        // already uses for its own log body.
                        raw-input: msg.raw-input;
                        raw-output: msg.raw-output;
                        expanded: msg.expanded;
                        index: msg.index;
                        toggle-expanded(idx) => { toggle-expanded(idx); }
                    }
                    if !is-user && !is-agent-side && !is-tool-event : card := MessageCard {
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        item: msg;
                        toggle-expanded(idx) => { toggle-expanded(idx); }
                    }
                    Rectangle { width: 0px; }
                }
            }
            }
            // Floating jump-to-latest button -- shown only while the user has
            // scrolled away from the bottom. It swaps its down-arrow for the
            // approval "hand" glyph when a permission request is pending, so a
            // scrolled-up user still gets a single affordance pointing at the
            // decision waiting below (the docked PermissionCard).
            if !root.stick-to-bottom : Rectangle {
                width: 32px;
                height: 32px;
                x: parent.width - self.width - Metrics.space-6;
                y: parent.height - self.height - Metrics.space-6;
                border-radius: self.height / 2;
                background: jump-touch.has-hover ? Theme.bg-primary.with-alpha(0.85) : Theme.bg-primary;
                animate background { duration: 100ms; }
                border-color: Theme.border-strong;
                border-width: 1px;
                jump-touch := TouchArea {
                    mouse-cursor: pointer;
                    accessible-role: button;
                    accessible-label: pending-request.active ? "Jump to pending request" : "Jump to latest message";
                    accessible-action-default => {
                        root.stick-to-bottom = true;
                        message-scroll.viewport-y = -root.msg-max-scroll;
                    }
                    clicked => {
                        root.stick-to-bottom = true;
                        message-scroll.viewport-y = -root.msg-max-scroll;
                    }
                    changed has-hover => { CursorHost.kind = self.has-hover ? "pointer" : "default"; }
                }
                Icon {
                    source: pending-request.active
                        ? @image-url("./assets/icons/hand.svg")
                        : @image-url("./assets/icons/arrow-down.svg");
                    size: Metrics.icon-sm;
                    color: Theme.text-on-primary;
                }
            }
        }
        // Terminal-view addition: one bounded max-height card per live/
        // finished agent-created terminal on the active thread, docked
        // above the compose bar like the permission card below --
        // deliberately outside the scrollable message Flickable so a
        // running command stays visible without scrolling.
        for term in terminals : Rectangle {
            background: Theme.bg-chat;
            HorizontalLayout {
                padding: compact ? 6px : 10px;
                TerminalCard {
                    item: term;
                    compact: compact;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                    expand => { expand-terminal(term.terminal-id); }
                }
            }
        }
        // Client-local PTY terminal card -- same docking spot as the
        // agent-created terminal cards above (outside the scrollable
        // message Flickable), shown whenever the user has toggled it
        // open via the header button.
        Rectangle {
            height: local-terminal.open ? local-terminal-card.height : 0px;
            visible: local-terminal.open;
            background: Theme.bg-chat;
            HorizontalLayout {
                padding: compact ? 6px : 10px;
                local-terminal-card := LocalTerminalCard {
                    item: local-terminal;
                    compact: compact;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                    expand => { local-terminal-expand-requested(); }
                    key-input(text) => { local-terminal-key-input(text); }
                    close-requested => { local-terminal-close-requested(); }
                }
            }
        }
        // Interactive agent-request relay addition: docked above the
        // compose bar whenever the active thread has a live pending
        // decision -- deliberately outside the scrollable message
        // Flickable above, so it stays visible without the user needing
        // to scroll to the bottom to see/answer it.
        if pending-request.active : Rectangle {
            background: Theme.bg-chat;
            HorizontalLayout {
                padding: compact ? 6px : 10px;
                PermissionCard {
                    item: pending-request;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                    approve() => { approve-request(); }
                    reject() => { reject-request(); }
                }
            }
        }
        // Separator above the compose bar.
        Rectangle {
            height: 1px;
            background: Theme.border-default;
        }
        // User input + mode/model selectors (extracted ChatInputLayout).
        chat-input := ChatInputLayout {
            width: 100%;
            horizontal-stretch: 1;
            compose-text <=> compose-text;
            sending: sending;
            mode-dropdown-entries: mode-dropdown-entries;
            config-dropdown-entries: config-dropdown-entries;
            mode-trigger-label: mode-trigger-label;
            send-requested => { send-requested(); }
            stop-requested => { stop-requested(); }
            mode-selected(id) => { mode-selected(id); }
            config-option-selected(option-id, value) => { config-option-selected(option-id, value); }
            panel-shortcut(event) => { return panel-shortcut(event); }
        }
    }
    restore-compose-focus => { chat-input.focus-compose(); }
}
