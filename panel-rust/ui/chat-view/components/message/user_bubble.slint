import { Theme } from "../../../tokens/theme.slint";
import { Metrics } from "../../../tokens/metrics.slint";
import { MessageItem } from "../../../types.slint";

// User bubble — tertiary fill, no border, larger 3-corner radius with
// LTR outgoing cut (bottom-right). Keeps the proven Flickable + preferred-
// height body pattern from the working baseline (do not replace with a
// bare Text that re-introduces stretch-height bugs).
export component UserBubble inherits Rectangle {
    in property <MessageItem> item;

    vertical-stretch: 0;

    background: Theme.bg-tertiary;
    border-width: 0px;
    border-top-left-radius: Theme.radius-lg;
    border-top-right-radius: Theme.radius-lg;
    border-bottom-left-radius: Theme.radius-lg;
    border-bottom-right-radius: Metrics.radius-corner-cut;

    content := VerticalLayout {
        padding: Metrics.space-4;
        Flickable {
            height: bubble-text.preferred-height;
            viewport-height: bubble-text.preferred-height;
            bubble-text := Text {
                text: item.text;
                font-family: Theme.font-sans;
                font-size: 12px * Theme.font-scale;
                color: Theme.text-primary;
                wrap: word-wrap;
                overflow: elide;
                horizontal-alignment: left;
                vertical-alignment: top;
                width: parent.width;
            }
        }
    }
}
