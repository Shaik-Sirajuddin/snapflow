import { Theme } from "../../../tokens/theme.slint";
import { Metrics } from "../../../tokens/metrics.slint";
import { MessageItem } from "../../../types.slint";
import { MarkdownView } from "../../../base/markdown_view.slint";

// Agent / thinking bubble — chat-items-redesign.md #3 / #10.
// Agent: elevated fill, no label, 3-corner radius (bottom-left cut).
// Thinking: transparent, muted, no card chrome.
// Body: MarkdownView (StyledText when has-body-styled).
export component AgentBubble inherits Rectangle {
    in property <MessageItem> item;
    callback link-clicked(string);

    property <bool> is-thinking: item.kind == "thinking";

    vertical-stretch: 0;

    background: is-thinking ? transparent : Theme.bg-primary-container;
    border-width: 0px;
    border-top-left-radius: is-thinking ? 0px : Theme.radius-lg;
    border-top-right-radius: is-thinking ? 0px : Theme.radius-lg;
    border-bottom-left-radius: is-thinking ? 0px : Metrics.radius-corner-cut;
    border-bottom-right-radius: is-thinking ? 0px : Theme.radius-lg;

    content := VerticalLayout {
        padding: is-thinking ? Metrics.space-2 : Metrics.space-4;
        // Proven content-height pattern (UserBubble): Flickable height
        // tracks the body's preferred-height at the laid-out width.
        Flickable {
            height: md.preferred-height;
            viewport-height: md.preferred-height;
            horizontal-stretch: 1;
            preferred-width: 0px;
            min-width: 0px;
            md := MarkdownView {
                width: parent.width;
                source: item.text;
                body-styled: item.body-styled;
                has-body-styled: item.has-body-styled;
                text-color: is-thinking ? Theme.text-muted : Theme.text-primary;
                font-size: (is-thinking ? 11px : 12px) * Theme.font-scale;
                font-family: Theme.font-sans;
                plain-italic: is-thinking;
                link-clicked(link) => { root.link-clicked(link); }
            }
        }
    }
}
