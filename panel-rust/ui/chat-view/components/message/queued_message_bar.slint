import { Theme } from "../../../tokens/theme.slint";
import { Metrics } from "../../../tokens/metrics.slint";
import { Icon } from "../../../base/icon.slint";
import { IconButton } from "../../../base/icon_button.slint";

// A user message still in the send queue -- chat-items-redesign.md #2.
// Tertiary background (same role as `UserBubble`, since a queued message
// is still "mine", just not sent yet) with three controls: cancel/drop
// (x), edit (pencil), stop-sending (x, shown only while actively
// in-flight). `can-edit` is caller-computed -- the spec's rule is "edit
// only for the most-recent unqueued message," which depends on the whole
// queue's order, not anything this component can determine on its own
// from a single item.
export component QueuedMessageBar inherits Rectangle {
    in property <string> text;
    in property <bool> can-edit: false;
    in property <bool> sending: false;
    callback cancel-requested();
    callback edit-requested();
    callback stop-requested();

    background: Theme.bg-tertiary;
    border-color: Theme.border-tertiary;
    border-width: 1px;
    border-radius: Theme.radius-md;

    HorizontalLayout {
        padding: Metrics.space-3;
        spacing: Metrics.space-3;
        Text {
            text: root.text;
            font-family: Theme.font-sans;
            font-size: 12px * Theme.font-scale;
            color: Theme.text-primary;
            wrap: word-wrap;
            overflow: elide;
            horizontal-alignment: left;
            vertical-alignment: center;
            horizontal-stretch: 1;
            preferred-width: 0px;
            min-width: 0px;
        }
        if can-edit && !sending : IconButton {
            btn-width: 18px;
            btn-height: 18px;
            button-accessible-label: "Edit queued message";
            clicked => { edit-requested(); }
            Icon {
                source: @image-url("../../../assets/icons/pencil.svg");
                size: 13px;
                color: Theme.text-secondary;
            }
        }
        if sending : IconButton {
            btn-width: 18px;
            btn-height: 18px;
            button-accessible-label: "Stop sending";
            clicked => { stop-requested(); }
            Icon {
                source: @image-url("../../../assets/icons/x.svg");
                size: 13px;
                color: Theme.text-secondary;
            }
        }
        if !sending : IconButton {
            btn-width: 18px;
            btn-height: 18px;
            button-accessible-label: "Cancel queued message";
            clicked => { cancel-requested(); }
            Icon {
                source: @image-url("../../../assets/icons/x.svg");
                size: 13px;
                color: Theme.text-muted;
            }
        }
    }
}
