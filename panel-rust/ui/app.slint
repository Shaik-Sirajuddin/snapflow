import { Theme } from "tokens/theme.slint";
import { ThreadItem, MessageItem, PendingRequestItem, PermissionOptionItem, TerminalItem, ProfileOption, ModeOption, ConfigOptionRow, DropdownEntry, McpServerOption, AgentCatalogEntry, LocalTerminalItem, RemoteSessionOption, SkillOption } from "types.slint";
import { Sidebar } from "components/sidebar.slint";
import { ChatArea } from "chat_area.slint";
import { TerminalOverlay } from "components/terminal_card.slint";
import { LocalTerminalOverlay } from "components/local_terminal_card.slint";
import { SettingsPage } from "pages/settings/settings_page.slint";
import { SkillEditorView } from "pages/skills/skill_view.slint";
import { TextUtil } from "base/text_util.slint";

export { ThreadItem, MessageItem, PendingRequestItem, PermissionOptionItem, TerminalItem, ProfileOption, ModeOption, ConfigOptionRow, DropdownEntry, McpServerOption, AgentCatalogEntry, LocalTerminalItem, RemoteSessionOption, SkillOption, TextUtil, Theme }

// Root window -- Rust-facing public API (property/callback names) is
// unchanged from the pre-reskin inline-macro version so
// `panel-rust/src/lib.rs`'s generated `ChatPanel` bindings (set_threads,
// set_messages, on_thread_selected, on_send_requested, etc.) needed zero
// changes for this phase. `theme` and `radius-preset` moved from
// `ChatPanel` properties (pre-reskin: only `theme` existed, driving a
// single `is-dark` bool) onto the `Theme` global directly (formerly named
// `Palette`, split into `tokens/` per `DESIGN_SYSTEM.md`) -- Rust code
// now reads/writes them via the generated `Theme::get(&component)`
// accessor (see `panel_rust_set_theme` in lib.rs) rather than
// `component.set_theme(...)`, since Slint globals' `in` properties are
// set through their own accessor, not by binding `Global.prop: expr;`
// from a plain component property (that syntax does not parse -- tried
// and rejected during this phase). `radius-preset` is new in this phase
// (Phase 0/1 addition), default-only for now -- no settings UI wires it
// yet, tracked separately.
export component ChatPanel inherits Window {
    default-font-family: Theme.font-sans;
    default-font-size: 13px * Theme.font-scale;
    background: Theme.bg-chat;
    // Forward window focus into the keybinding FocusScope so panel
    // shortcuts work even when no TextInput currently owns focus.
    forward-focus: panel-keys;
    out property <bool> compose-has-focus: chat-area.compose-has-focus;
    // Aggregates every editable Slint surface's own focus state besides
    // compose/local-terminal (thread search, skill search -- both share
    // Sidebar's one thread-search FilterSearchBar instance) -- see
    // FilterSearchBar.input-has-focus's doc comment for why this chain
    // exists: the host's panel_rust_input_key only forwards real
    // keystrokes into Slint when *something* in this OR-chain reads true,
    // so a field left out of it silently receives clicks but no typed
    // text at all.
    // settings-page-instance only exists while settings-open is true
    // (conditional element); referencing its property outside that scope
    // still resolves to false when absent, same as the other conditional
    // refs in this OR-chain.
    out property <bool> secondary-text-input-has-focus:
        sidebar.search-has-focus
        || chat-area.secondary-text-input-has-focus
        || settings-page-instance.search-has-focus;
    out property <bool> local-terminal-has-focus:
        chat-area.local-terminal-has-focus
        || (local-terminal-overlay-open && local-terminal-overlay.has-focus);
    in-out property <int> selected-thread: 0;
    in-out property <[ThreadItem]> threads: [];
    in-out property <[MessageItem]> messages: [];
    // Phase 3 paging state -- forwarded to the message Flickable so a
    // top-edge gesture cannot queue duplicate predecessor-page loads.
    in property <bool> has-older-messages: false;
    in-out property <bool> loading-older-messages: false;
    callback load-older-requested();
    in-out property <string> compose-text: "";
    in-out property <bool> settings-open: false;
    in-out property <string> settings-scope: "global";
    // Retains the active settings section while the page is open. The dev
    // fixture sets this to "agents" so its agent cards are visible on load.
    in-out property <string> settings-active-section: "mcp_servers";
    in-out property <bool> settings-sections-expanded: true;
    in-out property <string> default-profile: "";
    in-out property <string> permission-profile: "";
    in-out property <bool> background-default: false;
    in-out property <string> default-agent-id: "";
    in-out property <bool> background-override-set: false;
    in-out property <bool> background-override: false;
    in property <string> connection-status: "Connecting...";
    in property <bool> compact: true;
    in-out property <bool> narrow: false;
    in-out property <bool> sidebar-expanded: false;
    in property <PendingRequestItem> pending-request;
    in property <[TerminalItem]> terminals: [];
    // Client-local PTY terminal addition -- see `chat_area.slint`'s own
    // doc comment on `LocalTerminalItem`. Populated per the *currently
    // selected* thread, same convention `terminals`/`pending-request`
    // already follow.
    in property <LocalTerminalItem> local-terminal;
    in-out property <bool> local-terminal-overlay-open: false;
    // Profile-picker addition: populated by Rust (`AgentBridge::
    // list_profiles`, see `models::to_profile_options`) whenever the
    // settings sheet opens. Chip-clicking sets `default-profile`/
    // `permission-profile` directly rather than needing a distinct
    // "selected profile" property -- picking a chip is exactly
    // equivalent to typing that exact name into the existing free-text
    // field, just without the user needing to know exact profile names.
    in-out property <[ProfileOption]> available-profiles: [];
    // Settings-sheet addition: real `mcp_servers/list`/`agents/list`
    // results (see `SettingsSheet`'s own doc comment) -- populated by
    // `lib.rs` whenever the settings sheet opens, same convention as
    // `available-profiles`.
    in property <[McpServerOption]> available-mcp-servers: [];
    in property <[AgentCatalogEntry]> agent-catalog: [];
    in property <[RemoteSessionOption]> recoverable-sessions: [];
    // Skill-manager backend addition (skill_discovery_backend phase) --
    // populated by `lib.rs` from `models::to_skill_options`. Plumbed
    // through now, ahead of the sidebar/settings UI that will actually
    // render it (sidebar_skill_tree_and_new_skill_flow /
    // skills_management_settings phases), same "property exists before
    // its consuming UI" precedent as `available-mcp-servers` originally.
    in property <[SkillOption]> available-skills: [];
    in property <bool> dev-mode: false;
    // `active_pane_and_editor_view` phase: which surface the main content
    // area shows -- "chat" (ChatArea, the default) or "skill" (a live
    // SkillEditorView for the sidebar's currently-selected skill).
    in-out property <string> active-pane: "chat";
    in property <string> active-skill-name: "";
    in property <string> active-skill-path: "";
    in-out property <string> active-skill-content: "";
    in property <[string]> detected-editors: [];
    // `thread_item_project_context` phase: the currently-open MLT
    // project's path (mirrors PanelSingleton::active_project_path),
    // pushed from Rust on every `panel_rust_set_project_path` FFI call.
    // Empty string means no project is open. Sidebar rows use this to
    // decide whether a thread's own project-path differs from "here".
    in property <string> active-project-path: "";
    callback skill-content-edited(string, string /* path, new content */);
    callback skill-copy-path-requested(string);
    callback skill-open-in-editor-requested(string, string /* editor name, path */);
    callback skill-open-with-os-default-requested(string);
    callback skill-editor-open-requested(string /* path */);
    // Mode/config selector addition -- see chat_area.slint's own doc
    // comment on these properties; passed straight through to `ChatArea`
    // below (this root component owns no mode/config state of its own,
    // same "just plumbing" role it plays for every other ChatArea prop).
    in-out property <[DropdownEntry]> mode-dropdown-entries: [];
    in-out property <[DropdownEntry]> config-dropdown-entries: [];
    in-out property <string> mode-trigger-label: "";
    // Active model/config display name for the compose-bar trigger
    // (host: models::current_config_trigger_label). Empty → "Model".
    in-out property <string> config-trigger-label: "";
    // Session context ring (ui.yaml chat-view-input). Host fills real
    // numbers when available; defaults stay at zero until then.
    in property <float> context-ratio: 0.0;
    in property <int> context-used-tokens: 0;
    in property <int> context-limit-tokens: 0;
    // Compose `/` `@` `#` popup catalogs (skills / mcp / files).
    in property <[string]> file-options: [];
    callback context-view-requested();
    // Set by Rust whenever `expand-terminal` fires (looked up from
    // `terminals` at that moment, since Slint has no `for`-as-expression
    // find/filter construct) -- an empty `terminal-id` means no overlay
    // is shown. Cleared (terminal-id: "") by the overlay's own close
    // callback.
    in-out property <TerminalItem> expanded-terminal: { terminal-id: "" };

    callback thread-selected(int);
    // Relative move in the filtered thread list -- +1/-1 for next/previous,
    // wrapping. Fired by `handle-panel-shortcut`'s Ctrl+Alt+Up/Down, and by
    // anything re-dispatching through it (see that function's doc comment).
    callback thread-navigation-requested(int);
    callback new-thread-requested();
    callback new-skill-requested(string, string);
    callback skill-promote-to-global(string);
    callback dev-mode-toggled(bool);
    callback thread-close-requested(int);
    callback thread-delete-requested(int);
    callback thread-archive-requested(int);
    callback thread-rename-requested(int, string);
    callback search-submitted(string, bool, bool);
    callback send-requested();
    callback stop-requested();
    callback settings-requested();
    callback settings-scope-changed(string);
    callback settings-save();
    callback settings-close();
    callback mcp-server-create(string, string);
    callback mcp-server-delete(string);
    callback mcp-server-enabled-changed(string, bool);
    callback profile-create(string, string, bool, bool);
    callback profile-delete(string);
    callback agent-install-requested(string);
    callback recover-session-attach(string, string, string);
    callback search-changed(string);
    callback toggle-expanded(int);
    callback approve-request();
    callback reject-request();
    // One-of permission option pick (ACP optionId or synthetic approve/reject).
    callback permission-option-selected(string);
    callback expand-terminal(string);
    callback close-terminal-overlay();
    callback local-terminal-toggle-requested();
    callback local-terminal-key-input(string);
    callback local-terminal-close-requested();
    callback mode-selected(string);
    callback config-option-selected(string, string);
    callback thread-toggle-background(int);
    property <int> rename-thread-index: -1;
    property <string> rename-thread-draft: "";
    property <string> rename-focus-target: "";
    property <bool> pending-compose-focus: false;

    function start-new-thread() {
        root.active-pane = "chat";
        if (root.narrow) {
            root.sidebar-expanded = false;
        }
        root.pending-compose-focus = true;
        root.new-thread-requested();
    }

    function begin-thread-rename(index: int, focus-target: string) {
        if (index < 0 || index >= root.threads.length) {
            return;
        }
        root.selected-thread = index;
        root.active-pane = "chat";
        root.thread-selected(index);
        root.rename-thread-draft = root.threads[index].name;
        root.rename-focus-target = focus-target;
        root.rename-thread-index = index;
    }

    function cancel-thread-rename() {
        root.rename-thread-index = -1;
        root.rename-thread-draft = "";
        root.rename-focus-target = "";
    }

    function confirm-thread-rename(index: int, name: string) {
        if (name != "") {
            root.thread-rename-requested(index, name);
        }
        root.cancel-thread-rename();
    }

    compose-focus-delay := Timer {
        interval: 100ms;
        running: root.pending-compose-focus;
        triggered => {
            root.pending-compose-focus = false;
            chat-area.restore-compose-focus();
        }
    }

    // Open the settings overlay in Slint itself, then notify the host.
    // Pure viewers (slint-viewer --auto-reload) have no Rust callback that
    // can set `settings-open`; only firing the callback left the UI stuck
    // closed. Hosts that listen still get `settings-requested` for prefs
    // load / gateway list refresh (and may set open again — harmless).
    function open-settings() {
        settings-open = true;
        settings-requested();
    }

    // Shared target for Ctrl+K and the C++-side global "focus thread
    // search" command (`panel_rust_invoke_command`'s open-search case),
    // so both paths stay in sync with whatever "open search" means here.
    public function open-thread-search() {
        sidebar.open-search();
    }

    // layout-redesign.md Phase 5 -- panel-level shortcuts. Also re-run
    // from the compose TextInput (chat_area) so they still fire while the
    // composer owns focus (TextInput swallows keys before this scope).
    function handle-panel-shortcut(event: KeyEvent) -> EventResult {
        // Escape: reject pending permission, else close the top overlay /
        // settings sheet. Always wins over type-to-compose.
        if (event.text == Key.Escape) {
            // Host pending OR local `/demo-permission` card.
            if (pending-request.active || chat-area.has-pending-approval) {
                chat-area.reject-pending();
                return EventResult.accept;
            }
            if (expanded-terminal.terminal-id != "") {
                expanded-terminal = { terminal-id: "" };
                close-terminal-overlay();
                chat-area.restore-compose-focus();
                return EventResult.accept;
            }
            if (local-terminal-overlay-open) {
                local-terminal-overlay-open = false;
                chat-area.restore-compose-focus();
                return EventResult.accept;
            }
            if (settings-open) {
                settings-open = false;
                settings-close();
                chat-area.restore-compose-focus();
                return EventResult.accept;
            }
            return EventResult.reject;
        }
        if (event.modifiers.control) {
            // Ctrl+B -- toggle sidebar (no-op while narrow forces rail).
            if (event.text == "b" || event.text == "B") {
                if (!root.narrow) {
                    sidebar-expanded = !sidebar-expanded;
                }
                return EventResult.accept;
            }
            // Ctrl+N -- new thread.
            if (event.text == "n" || event.text == "N") {
                root.start-new-thread();
                return EventResult.accept;
            }
            // Ctrl+, -- open settings.
            if (event.text == ",") {
                root.open-settings();
                return EventResult.accept;
            }
            // Ctrl+K -- expand rail if needed and focus thread search.
            if (event.text == "k" || event.text == "K") {
                root.open-thread-search();
                return EventResult.accept;
            }
            // Ctrl+Alt+Up/Down -- previous/next thread, wrapping. Deliberately
            // not bare arrows, Ctrl+Up/Down, or PageUp/PageDown -- those
            // collide with in-field text navigation and Shotcut's own
            // transport/navigation shortcuts (see the execution plan).
            if (event.modifiers.alt && event.text == Key.UpArrow) {
                root.thread-navigation-requested(-1);
                return EventResult.accept;
            }
            if (event.modifiers.alt && event.text == Key.DownArrow) {
                root.thread-navigation-requested(1);
                return EventResult.accept;
            }
            // Ctrl+Enter -- first allow option (host or local demo card).
            if ((event.text == Key.Return || event.text == "\n")
                && (pending-request.active || chat-area.has-pending-approval)) {
                chat-area.approve-pending();
                return EventResult.accept;
            }
        }
        return EventResult.reject;
    }

    panel-keys := FocusScope {
        key-pressed(event) => {
            // Don't steal keystrokes from a focused local/agent terminal.
            if (root.local-terminal-has-focus) {
                return EventResult.reject;
            }
            return root.handle-panel-shortcut(event);
        }
        Rectangle {
            width: root.width;
            height: root.height;
            background: Theme.bg-chat;
            sidebar := Sidebar {
                x: 0px;
                y: 0px;
                height: parent.height;
                // Narrow mode begins collapsed, but the user can open the
                // rail to browse. Double-clicking a selected row closes it
                // again to reveal the chat or skill editor.
                threads: threads;
                selected-thread: selected-thread;
                compact: compact;
                narrow: root.narrow;
                expanded: sidebar-expanded;
                skills: available-skills;
                active-project-path: root.active-project-path;
                rename-thread-index <=> root.rename-thread-index;
                rename-thread-draft <=> root.rename-thread-draft;
                rename-focus-target: root.rename-focus-target;
                thread-selected(i) => {
                    selected-thread = i;
                    // Leave live skill editor when a thread is chosen —
                    // main surface returns to chat (active-pane switch).
                    root.active-pane = "chat";
                    thread-selected(i);
                }
                new-thread-requested => {
                    root.start-new-thread();
                }
                new-skill-requested(name, scope) => { new-skill-requested(name, scope); }
                skill-selected(path) => {
                    root.active-pane = "skill";
                    root.skill-editor-open-requested(path);
                }
                thread-close-requested(i) => { thread-close-requested(i); }
                thread-delete-requested(i) => { thread-delete-requested(i); }
                thread-archive-requested(i) => { thread-archive-requested(i); }
                thread-rename-started(i) => { root.begin-thread-rename(i, "sidebar"); }
                thread-rename-cancelled => { root.cancel-thread-rename(); }
                thread-rename-confirmed(i, name) => { root.confirm-thread-rename(i, name); }
                settings-requested => { root.open-settings(); }
                skills-settings-requested => {
                    root.settings-active-section = "skills";
                    root.open-settings();
                }
                search-changed(q) => { search-changed(q); }
                search-submitted(query, search-skills, show-global) => {
                    root.search-submitted(query, search-skills, show-global);
                }
                toggle-expanded => { sidebar-expanded = !sidebar-expanded; }
                collapse-requested => { sidebar-expanded = false; }
                expand-requested => {
                    sidebar-expanded = true;
                }
            }
            chat-area := ChatArea {
                visible: root.active-pane == "chat";
                x: sidebar.width;
                y: 0px;
                width: root.width - self.x;
                height: parent.height;
                compact: compact;
                narrow: root.narrow;
                sidebar-expanded: sidebar-expanded;
                rename-editing: root.rename-thread-index == selected-thread;
                rename-draft <=> root.rename-thread-draft;
                rename-focus-target: root.rename-focus-target;
                active-thread-name: threads.length > 0 ? threads[selected-thread].name : "";
                active-thread-description: threads.length > 0 ? threads[selected-thread].description : "";
                active-thread-background: threads.length > 0 ? threads[selected-thread].background : false;
                toggle-background => { thread-toggle-background(selected-thread); }
                messages: messages;
                has-older-messages: has-older-messages;
                loading-older-messages <=> loading-older-messages;
                load-older-requested => { load-older-requested(); }
                // `default_variables_display` phase: `agent-badge` used to
                // be a static "agent . ask" default that nothing ever set
                // from Rust, so it never reflected the active thread's real
                // provider/model or updated on model selection. Derived
                // here instead, the same way `active-thread-name`/
                // `active-thread-description` already are, from the same
                // live per-thread `provider`/`model` fields the sidebar row
                // already shows -- always current, no separate Rust-side
                // property push needed.
                agent-badge: threads.length > 0 && threads[selected-thread].provider != ""
                    ? threads[selected-thread].provider
                        + (threads[selected-thread].model != "" ? " . " + threads[selected-thread].model : "")
                    : "agent . ask";
                connection-status: connection-status;
                sending: threads.length > 0
                    ? threads[selected-thread].status == "loading"
                        || threads[selected-thread].status == "cancelling"
                    : false;
                compose-text <=> compose-text;
                send-requested => { send-requested(); }
                stop-requested => { stop-requested(); }
                settings-requested => { root.open-settings(); }
                new-thread-requested => { root.start-new-thread(); }
                thread-rename-started => {
                    root.begin-thread-rename(selected-thread, "chat");
                }
                thread-rename-cancelled => { root.cancel-thread-rename(); }
                thread-rename-confirmed(name) => {
                    root.confirm-thread-rename(selected-thread, name);
                }
                toggle-expanded(i) => { toggle-expanded(i); }
                pending-request: pending-request;
                approve-request => { approve-request(); }
                reject-request => { reject-request(); }
                permission-option-selected(option-id) => { permission-option-selected(option-id); }
                terminals: terminals;
                expand-terminal(id) => { expand-terminal(id); }
                local-terminal: local-terminal;
                local-terminal-toggle-requested => { local-terminal-toggle-requested(); }
                local-terminal-key-input(text) => { local-terminal-key-input(text); }
                local-terminal-expand-requested => { local-terminal-overlay-open = true; }
                local-terminal-close-requested => { local-terminal-close-requested(); }
                mode-dropdown-entries: mode-dropdown-entries;
                config-dropdown-entries: config-dropdown-entries;
                mode-trigger-label: mode-trigger-label;
                config-trigger-label: config-trigger-label;
                context-ratio: context-ratio;
                context-used-tokens: context-used-tokens;
                context-limit-tokens: context-limit-tokens;
                skill-options: available-skills;
                mcp-options: available-mcp-servers;
                file-options: file-options;
                mode-selected(id) => { mode-selected(id); }
                config-option-selected(option-id, value) => { config-option-selected(option-id, value); }
                context-view-requested => { context-view-requested(); }
                // Compose owns focus for typing -- re-dispatch panel chords
                // so Ctrl+B/N/K/, and Escape still work while composing.
                panel-shortcut(event) => {
                    return root.handle-panel-shortcut(event);
                }
            }
            if root.active-pane == "skill" : SkillEditorView {
                x: sidebar.width;
                y: 0px;
                width: root.width - self.x;
                height: parent.height;
                skill-name: root.active-skill-name;
                skill-path: root.active-skill-path;
                skill-content <=> root.active-skill-content;
                detected-editors: root.detected-editors;
                copy-path-requested => { root.skill-copy-path-requested(root.active-skill-path); }
                open-in-editor-requested(editor-name) => {
                    root.skill-open-in-editor-requested(editor-name, root.active-skill-path);
                }
                open-with-os-default-requested => {
                    root.skill-open-with-os-default-requested(root.active-skill-path);
                }
                content-edited(new-content) => {
                    root.skill-content-edited(root.active-skill-path, new-content);
                }
                close-requested => { root.active-pane = "chat"; }
            }
        }
        if expanded-terminal.terminal-id != "" : TerminalOverlay {
            item: expanded-terminal;
            container-width: root.width;
            container-height: root.height;
            close => {
                expanded-terminal = { terminal-id: "" };
                close-terminal-overlay();
                chat-area.restore-compose-focus();
            }
        }
        local-terminal-overlay := LocalTerminalOverlay {
            visible: local-terminal-overlay-open;
            item: local-terminal;
            container-width: root.width;
            container-height: root.height;
            close => {
                local-terminal-overlay-open = false;
                chat-area.restore-compose-focus();
            }
            close-requested => {
                local-terminal-overlay-open = false;
                local-terminal-close-requested();
                chat-area.restore-compose-focus();
            }
            key-input(text) => { local-terminal-key-input(text); }
        }
        // Full-size host for SettingsPage. A bare Rectangle with no
        // width/height under FocusScope collapses to 0×0; SettingsPage
        // then binds width/height to that parent and never paints even
        // when `settings-open` is true (sidebar click / Ctrl+, look dead).
        if settings-open : Rectangle {
            width: root.width;
            height: root.height;
            // Dim chat behind the sheet so the overlay is obvious.
            background: #00000088;
            // Click-through guard on the dimmer (close is via X / Escape).
            TouchArea { }
        }

        // SettingsPage itself is a sibling of the dimmer above, not nested
        // inside it: `secondary-text-input-has-focus` below needs to
        // reference this element's id, which Slint doesn't allow for
        // `if`-only elements ("Cannot access id"). Unconditionally mounted
        // + `visible:` instead (Slint's `visible: false` also disables
        // input handling, so this stays inert while settings is closed,
        // same as the dimmer's own click-guard staying `if`-gated so it
        // never blocks chat clicks when settings is closed). `parent` here
        // is the same `width: root.width; height: root.height` Rectangle
        // the dimmer above uses, so the x/y/width math is unchanged.
        settings-page-instance := SettingsPage {
            visible: root.settings-open;
            x: 8px;
            y: 8px;
            width: parent.width - 16px;
            height: parent.height - 16px;
            active-section <=> root.settings-active-section;
            scope <=> root.settings-scope;
            sections-expanded <=> root.settings-sections-expanded;
            default-profile <=> default-profile;
            permission-profile <=> permission-profile;
            background-default <=> background-default;
            default-agent-id <=> root.default-agent-id;
            background-override-set <=> background-override-set;
            background-override <=> background-override;
            available-profiles: available-profiles;
            available-mcp-servers: available-mcp-servers;
            agent-catalog: agent-catalog;
            recoverable-sessions: recoverable-sessions;
            available-skills: available-skills;
            dev-mode: dev-mode;
            save => { settings-save(); }
            scope-changed(scope) => { root.settings-scope-changed(scope); }
            close => {
                settings-open = false;
                settings-close();
                chat-area.restore-compose-focus();
            }
            mcp-server-create(name, command) => { mcp-server-create(name, command); }
            mcp-server-delete(name) => { mcp-server-delete(name); }
            mcp-server-enabled-changed(name, enabled) => {
                mcp-server-enabled-changed(name, enabled);
            }
            profile-create(name, agent-id, terminal-enabled, fs-enabled) => {
                profile-create(name, agent-id, terminal-enabled, fs-enabled);
            }
            profile-delete(name) => { profile-delete(name); }
            agent-install-requested(id) => { agent-install-requested(id); }
            recover-session-attach(session-id, provider, title) => { recover-session-attach(session-id, provider, title); }
            skill-promote-to-global(path) => { skill-promote-to-global(path); }
            dev-mode-toggled(enabled) => { dev-mode-toggled(enabled); }
        }
    }
}
