import { Theme } from "../../../tokens/theme.slint";
import { FilterSearchBar } from "../../../base/filter_search_bar.slint";

// Settings page — thin wrap of shared FilterSearchBar with settings defaults.
// All settings search sites should use this (or FilterSearchBar directly).
// Cursor-kind reporting (pointer/text) lives inside FilterSearchBar itself.
export component SettingsSearchBar inherits FilterSearchBar {
    show-icon: false;
    icon-trailing: false;
    bar-bg: Theme.bg-tertiary;
    placeholder: "Search settings...";
    bar-accessible-label: "Search settings";
}
