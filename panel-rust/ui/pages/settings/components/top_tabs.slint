import { Metrics } from "../../../tokens/metrics.slint";
import { NavItem } from "../../../base/nav_item.slint";

// Settings page chrome -- the `[Project | Global]` scope switcher from the
// settings-pane-redesign plan's "Component layout" section. Project is the
// default-selected scope (owned by the caller, `SettingsPage`, not this
// component -- this is a dumb controlled tab strip, same division of
// ownership `left_tabs.slint`/`search_bar.slint` follow).
export component SettingsTopTabs inherits Rectangle {
    in property <string> scope: "project"; // "project" | "global"
    callback scope-selected(string);

    height: 28px;

    HorizontalLayout {
        alignment: start;
        spacing: Metrics.space-2;

        NavItem {
            width: 72px;
            label: "Project";
            button-accessible-label: "Show project settings";
            active: root.scope == "project";
            centered: true;
            label-font-weight-active: 600;
            label-font-weight-inactive: 600;
            clicked => { root.scope-selected("project"); }
        }
        NavItem {
            width: 72px;
            label: "Global";
            button-accessible-label: "Show global settings";
            active: root.scope == "global";
            centered: true;
            label-font-weight-active: 600;
            label-font-weight-inactive: 600;
            clicked => { root.scope-selected("global"); }
        }
    }
}
