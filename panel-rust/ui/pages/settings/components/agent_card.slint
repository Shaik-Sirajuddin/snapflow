import { Theme } from "../../../tokens/theme.slint";
import { Metrics } from "../../../tokens/metrics.slint";
import { Icon } from "../../../base/icon.slint";
import { AgentLogo } from "../components/agent_logo.slint";
import { Button } from "../../../base/button.slint";
import { Toggle } from "../../../base/toggle.slint";

// Grid tile for the Agents view -- one per catalog entry (auto-discovered
// or installable), per the settings-pane-redesign plan's "Agents view is a
// grid, not a row list" section.
//
// Layout (per the design-doc `changes.yaml` "rows" task):
//   1. logo + name, left-aligned
//   2. [status icon] status text, plus a "make default" toggle
//   3. Model label + searchable model picker
//   4. Profile label + permission-mode picker (same picker design)
//   5. Install / Connect / Disconnect action per status
//
// LOGO REVERSAL: an earlier pass this session removed the agent logo per
// an offhand "no logo" request; the checked-in `changes.yaml` task doc
// then explicitly asks for "logo, name first row left align", so it is
// back. `AgentCatalogEntry` has no per-agent logo/icon-url field, and
// `@image-url` needs a compile-time-constant path (so a dynamic per-agent
// URL couldn't render even if the struct carried one -- see
// `icon.slint`'s doc comment). The per-agent official brand mark is
// therefore resolved by `AgentLogo`, a static id->`@image-url` lookup over
// the vendored logos in `ui/assets/logos/` (falling back to the generic
// `sparkles` placeholder for unknown ids) -- see `agent_logo.slint`.
//
// Status is monochrome text + a `check`/`circle` glyph only -- never a
// colored dot (this project's established no-status-color language, see
// `theme.slint`'s module doc and `AgentCatalogEntry.status`'s doc
// comment). Default selection is now an explicit `Toggle` (was a silent
// whole-card click before).
export component AgentCard inherits Rectangle {
    in property <string> agent-id;
    in property <string> agent-name;
    // Registry wire status string (`AgentStatus::as_wire_str`):
    // "installed" | "installed_no_session" | "not_installed" |
    // "runtime_missing" | <unknown>. Derived into the three display states
    // below rather than passed as separate bools, so the card owns the
    // status->presentation mapping in one place.
    in property <string> status: "";
    in property <bool> is-default: false;
    // setup-followups plan, agent_settings_ordering_and_install_enable_
    // flow: the real "install > enable" second step -- distinct from
    // is-present/is-connected (registry detection), this is the admin-
    // plane's own durable per-agent gate on session/new. Defaults true
    // (see AgentCatalogEntry's own doc comment) so a card never looks
    // disabled before the admin plane's real state has loaded.
    in property <bool> enabled: true;
    // Set by AgentsView so narrow settings panes can use a full-width
    // single-column card instead of overflowing the two-column grid.
    in property <length> card-width: 260px;
    callback set-default(bool);
    callback install-requested();
    callback connect-requested();
    callback disconnect-requested();
    callback set-enabled(bool);

    // "installed" is the registry's "present with a live session" state --
    // treat as connected. "installed_no_session" is present-but-not-running.
    // Everything else (not_installed / runtime_missing / unknown) is
    // not-found -> offer Install.
    property <bool> is-connected: root.status == "installed";
    property <bool> is-present: root.status == "installed" || root.status == "installed_no_session";

    width: card-width;
    // setup-followups plan, agent_settings_ordering_and_install_enable_
    // flow: +16px over the original 136px for the new Enabled toggle
    // row (only present once installed).
    height: 152px;
    // Same tertiary tone the search box uses so cards read as one
    // consistent surface with the rest of this page's chrome; the default
    // card gets the primary-container tint to stand out. No hover tint on
    // the card body itself -- only its interactive controls get hover
    // feedback.
    background: is-default ? Theme.bg-primary-container : Theme.bg-tertiary;
    animate background { duration: 100ms; }
    // setup-followups plan, agent_settings_ordering_and_install_enable_
    // flow: not-installed/runtime-missing agents previously looked
    // identical to installed ones (background only ever varied by
    // is-default) -- dim the whole card for a subtle disabled-looking
    // affordance instead. Same 0.7 opacity chat_input_layout.slint's
    // send button already uses for its own disabled state, keeping this
    // consistent with the app's established "no status-color language"
    // convention (dimming, not a new color).
    opacity: is-present ? 1.0 : 0.7;
    animate opacity { duration: 100ms; }
    border-radius: Theme.radius-md;
    // Defensive: contain any future internal overflow at this card's own
    // boundary instead of letting it bleed into the neighboring grid
    // column (no element anywhere on this page had `clip: true` before --
    // real root cause of one visible bug was the Select width fix above,
    // but nothing enforced a hard boundary if something else overflows
    // later). Doesn't affect `Select`'s dropdown -- that's a real
    // `PopupWindow`, which renders above everything, unaffected by an
    // ancestor's `clip`.
    clip: true;

    VerticalLayout {
        // Explicit fill -- this Rectangle's sole-child VerticalLayout
        // doesn't reliably auto-fill a fixed-size parent (same class of
        // bug found repeatedly elsewhere this session). Left unbound, a
        // card whose content is shorter (e.g. a not-yet-installed agent,
        // which skips the Model/Profile rows below) sized this layout to
        // its own shorter natural height and centered it in the fixed
        // 226px card box, showing as unexplained blank margin above the
        // content instead of the bottom-pinned action row `vertical-
        // stretch: 1` below is meant to produce.
        width: parent.width;
        height: parent.height;
        padding: Metrics.space-6;
        spacing: Metrics.space-3;

        // Row 1: logo + name, left-aligned.
        HorizontalLayout {
            spacing: Metrics.space-2;
            AgentLogo {
                agent-id: root.agent-id;
                size: 16px;
                color: Theme.text-secondary;
            }
            Text {
                text: root.agent-name;
                color: Theme.text-primary;
                font-size: 13px * Theme.font-scale;
                font-weight: 700;
                horizontal-stretch: 1;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        // Row 2: [status icon] status text  +  make-default toggle.
        HorizontalLayout {
            spacing: Metrics.space-2;
            Icon {
                size: 12px;
                color: Theme.text-secondary;
                source: root.is-connected
                    ? @image-url("../../../assets/icons/check.svg")
                    : @image-url("../../../assets/icons/circle.svg");
                vertical-alignment: center;
            }
            Text {
                text: root.is-connected ? "Connected" : (root.is-present ? "Installed" : "Not found");
                color: Theme.text-secondary;
                font-size: 10px * Theme.font-scale;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }
            Text {
                text: "Default";
                color: Theme.text-secondary;
                font-size: 10px * Theme.font-scale;
                vertical-alignment: center;
            }
            // Split into two `if` branches (rather than one `Toggle`
            // with `checked: root.is-default`) so the whole element gets
            // destroyed and recreated -- and its `checked` binding fully
            // reset -- whenever `is-default` flips. `Toggle.checked` is
            // `in-out` and self-assigns on click (`toggle.slint`'s own
            // `clicked` handler does `root.checked = !root.checked`),
            // which is fine for `Toggle`'s other, single-instance,
            // self-managed call sites (e.g. the MCP-server enable
            // toggles), but a plain one-way `checked: root.is-default`
            // binding gets permanently severed the first time a user
            // clicks it -- so clicking a *different* card's default
          // toggle afterward never turned this one back off, letting
            // more than one card show as default at once. This is the
            // reason "the default agent should only be one" broke.
            if root.is-default : Toggle {
                checked: true;
                toggle-accessible-label: "Unset " + root.agent-name + " as default agent";
                toggled(new-checked) => { root.set-default(new-checked); }
            }
            if !root.is-default : Toggle {
                checked: false;
                toggle-accessible-label: "Set " + root.agent-name + " as default agent";
                toggled(new-checked) => { root.set-default(new-checked); }
            }
        }

        // Row 2b: install > enable. Only meaningful once installed --
        // an agent that isn't present yet has nothing to enable/disable.
        if root.is-present : HorizontalLayout {
            spacing: Metrics.space-2;
            Text {
                text: "Enabled";
                color: Theme.text-secondary;
                font-size: 10px * Theme.font-scale;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }
            if root.enabled : Toggle {
                checked: true;
                toggle-accessible-label: "Disable " + root.agent-name;
                toggled(new-checked) => { root.set-enabled(new-checked); }
            }
            if !root.enabled : Toggle {
                checked: false;
                toggle-accessible-label: "Enable " + root.agent-name;
                toggled(new-checked) => { root.set-enabled(new-checked); }
            }
        }

        // Only expose actions backed by the agent registry. There is no
        // per-agent model/profile/connect API in ACPX, so those controls
        // must not masquerade as persisted runtime settings.
        Rectangle {
            vertical-stretch: 1;
            HorizontalLayout {
                y: parent.height - self.height;
                width: parent.width;
                alignment: start;
                if !root.is-present : Button {
                    label: "Install";
                    button-accessible-label: "Install agent " + root.agent-name;
                    btn-width: 72px;
                    btn-height: 24px;
                    font-size: 10px;
                    font-weight: 400;
                    clicked => { root.install-requested(); }
                }
            }
        }
    }
}
