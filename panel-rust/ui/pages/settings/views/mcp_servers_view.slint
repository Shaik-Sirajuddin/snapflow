import { Theme } from "../../../tokens/theme.slint";
import { Metrics } from "../../../tokens/metrics.slint";
import { Button } from "../../../base/button.slint";
import { Toggle } from "../../../base/toggle.slint";
import { TextField } from "../../../base/text_field.slint";
import { SettingsRow } from "../../../base/settings_row.slint";
import { SettingsSection, SettingsSectionHeader, SettingsRowGroup } from "../../../base/settings_section.slint";
import { McpServerOption, McpToolOption } from "../../../types.slint";
import { TextUtil } from "../../../base/text_util.slint";

// MCP Servers left-tab view. Started as a phase-1 shell that only re-hosted
// the former `components/settings_sheet.slint` list unchanged (name +
// command + Remove, plus a name/command add row). This pass fills the row
// out to match the *set of per-server config options* established coding
// agents expose for MCP management -- benchmarked against opencode's `mcp`
// config schema (https://opencode.ai/docs/mcp-servers): a `type` of
// `"local"` (a `command`) vs `"remote"` (a `url`, optional `oauth`), an
// `enabled` flag, per-tool enable/disable (opencode's global `tools` glob
// config), and deferred/lazy tool loading (opencode's experimental
// `mcp_lazy`/`mcp_search`, mirroring Claude Code's ToolSearch). Cross-checked
// against Zed's `context_servers` and Codex's `mcp_servers`, and the MCP
// spec's `tools/list` (per-server tool catalog) + stdio/Streamable-HTTP
// transports.
//
// Layout: each server is a header row (`SettingsRow`: name, command-or-url
// hint, transport tag, auth status, connection status, OAuth "Connect",
// enable toggle, Remove) plus, when it advertises tools, an expand/collapse
// nested list of per-tool rows (name, "deferred" tag, enable toggle).
//
// Backend reality: `src/agent_bridge.rs`'s `mcp_servers/*` RPCs still only
// support create/delete by name+command. So every per-row control beyond
// create/delete (transport tag, url, status text, auth status, enable
// toggle, OAuth "Connect", the whole per-tool list) is **UI-only** for now
// -- driven by `McpServerOption`'s UI-only fields (which
// `models::to_mcp_server_options` default-fills empty), the same "UI ahead
// of backend" posture `harness_view.slint` documents for its own toggles.
// Every toggle's state is local/visual only and is not persisted or read by
// any runtime code; "Connect" is a placeholder for a future
// `mcp_servers/authenticate` round trip; the tool list is a placeholder for
// a future `tools/list` round trip (always empty today). Only the
// create/delete round trip is wired to real Rust.
export component McpServersView inherits Rectangle {
    in property <[McpServerOption]> servers: [];
    // settings_page_search_filter: page-level query filters this list.
    in property <string> page-search-query: "";
    callback mcp-server-create(string, string);
    callback mcp-server-delete(string);
    callback mcp-server-enabled-changed(string, bool);
    // See FilterSearchBar.input-has-focus's doc comment / TextField.has-focus's
    // own doc comment: this view's add-server name/command fields never had
    // any focus state to aggregate up into settings_page.slint's OR-chain,
    // so every keystroke typed into either field was silently dropped.
    out property <bool> search-has-focus:
        new-mcp-name-field.has-focus || new-mcp-command-field.has-focus;

    property <string> new-mcp-name: "";
    property <string> new-mcp-command: "";

    background: transparent;

    SettingsSection {
        width: parent.width;

        SettingsSectionHeader { text: "MCP Servers"; }

        SettingsRowGroup {
            width: parent.width;

            for server in root.servers : server-block := VerticalLayout {
                width: parent.width;
                // Hide non-matching servers when page search is active.
                visible: root.page-search-query == ""
                    || TextUtil.matches-filter(
                        server.name + "\n" + server.command + "\n" + server.url,
                        root.page-search-query,
                    );
                // `pad-xs` (4px) -- the compact pre-reveal gap between a
                // server's header row and its (conditionally shown)
                // expanded tool panel.
                spacing: Metrics.pad-xs;

                // Per-instance expand state for this server's tool list -- UI-only
                // and local (Slint has no round-trip need here: nothing persists
                // it, unlike the chat-view's Rust-side `expanded` vec).
                property <bool> tools-expanded: false;

                // Pre-formatted in Rust (`McpServerOption.status-line`).
                property <string> status-line: server.status-line;

                // Header row -- consolidated to 4 trailing controls (was 7:
                // transport tag, auth-status, status and Connect were each
                // their own item, competing with Tools/enable-Toggle/Remove
                // for the same cramped trailing slot at 9-10px font sizes).
                // Transport/auth/status now collapse into one combined
                // subtitle line via `status-line` below; Connect only shows
                // when actually relevant. This is also why the enable toggle
                // read as "missing" -- it was there, just visually lost among
                // too many same-sized neighbors.
                SettingsRow {
                    width: parent.width;
                    label: server.name;
                    label-font-family: Theme.font-mono;
                    hint: server.transport == "http" ? server.url : server.command;
                    hint-font-family: Theme.font-mono;

                    // Transport + auth + connection status, combined into one
                    // muted subtitle instead of three separate trailing items --
                    // still plain monochrome text, never a colored badge.
                    if server-block.status-line != "" : Text {
                        text: server-block.status-line;
                        color: Theme.text-muted;
                        font-size: 9px * Theme.font-scale;
                        vertical-alignment: center;
                        // Capped + elided -- unbounded, this could still
                        // overflow the row for a server with several
                        // combined status segments (e.g. "http ·
                        // not authenticated · auth required"), the same
                        // class of overflow bug hit repeatedly earlier
                        // this session.
                        max-width: 120px;
                        overflow: elide;
                    }

                    // Enable/disable without removing the entry (opencode/Codex
                    // per-server `enabled`) is registry-backed and immediately
                    // re-listed by the Rust host after update.
                    Toggle {
                        checked: server.enabled;
                        toggle-accessible-label: "Toggle MCP server " + server.name;
                        toggled(enabled) => { root.mcp-server-enabled-changed(server.name, enabled); }
                    }

                    Button {
                        label: "Remove";
                        button-accessible-label: "Remove MCP server " + server.name;
                        // Bumped from 44x20 -- `Button` has no separate
                        // padding concept (fixed btn-width/btn-height with
                        // centered text), so more breathing room around
                        // the label means a larger box.
                        btn-width: 56px;
                        btn-height: 24px;
                        font-size: 9px;
                        font-weight: 400;
                        clicked => { root.mcp-server-delete(server.name); }
                    }
                }
            }
        }

        HorizontalLayout {
            // `gap-sm` (6px) -- gap between the two add-server fields and
            // the Add button.
            spacing: Metrics.gap-sm;
            new-mcp-name-field := TextField {
                horizontal-stretch: 1;
                text <=> root.new-mcp-name;
                field-accessible-label: "New MCP server name";
            }
            new-mcp-command-field := TextField {
                horizontal-stretch: 1;
                text <=> root.new-mcp-command;
                field-accessible-label: "New MCP server command or URL";
            }
            Button {
                label: "Add";
                button-accessible-label: "Add MCP server";
                primary: true;
                btn-width: 56px;
                btn-height: 26px;
                font-size: 11px;
                font-weight: 400;
                clicked => {
                    if (root.new-mcp-name != "") {
                        root.mcp-server-create(root.new-mcp-name, root.new-mcp-command);
                        root.new-mcp-name = "";
                        root.new-mcp-command = "";
                    }
                }
            }
        }
    }
}
