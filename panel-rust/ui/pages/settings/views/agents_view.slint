import { Theme } from "../../../tokens/theme.slint";
import { Metrics } from "../../../tokens/metrics.slint";
import { Button } from "../../../base/button.slint";
import { SettingsRow } from "../../../base/settings_row.slint";
import { SettingsSection, SettingsSectionHeader, SettingsField, SettingsDivider } from "../../../base/settings_section.slint";
import { SettingsSearchBar } from "../components/search_bar.slint";
import { AgentCard } from "../components/agent_card.slint";
import { ProfileOption, AgentCatalogEntry, RemoteSessionOption } from "../../../types.slint";

// Agents left-tab view -- phase 1 shell. Re-hosts every slice of the
// former `components/settings_sheet.slint` that is agent/profile/session
// shaped and doesn't cleanly belong under MCP Servers or Harness: the
// profile picker + profile management (`profiles/*`, default agent
// behavior per chat), the agent catalog itself (`agents/list`,
// install-only per the current Rust-side reality -- see the
// settings-pane-redesign plan's "Rust-side reality check"), and
// Recoverable Sessions (real gateway sessions re-attached onto a thread
// for a given agent/provider). All three are agent-catalog/profile-
// adjacent, unlike the MCP-server registry or the (currently
// thread-background-only) Harness section, so they land here rather than
// being split into a fourth left tab that the plan's "Component layout"
// section doesn't call for. No new fields, no new data wiring -- same
// models/callbacks `settings_sheet.slint` already used.
export component AgentsView inherits Rectangle {
    in-out property <string> default-profile: "";
    in-out property <string> permission-profile: "";
    in property <[ProfileOption]> available-profiles: [];
    in property <[AgentCatalogEntry]> agent-catalog: [];
    in property <[RemoteSessionOption]> recoverable-sessions: [];
    callback profile-create(string, string, bool, bool);
    callback profile-delete(string);
    callback agent-install-requested(string);
    callback recover-session-attach(string, string, string);
    // Connect/disconnect a single agent's live session. UI-only
    // placeholders -- there is no per-agent connect/disconnect RPC in
    // `src/agent_bridge.rs` today (only `agents/install`), so these are
    // terminated here (empty handlers on the cards) exactly like
    // `mcp_servers_view.slint`'s "Connect" button. Declared so the seam
    // exists when a real `agents/connect` round trip lands.
    callback agent-connect-requested(string);
    callback agent-disconnect-requested(string);

    property <string> new-profile-name: "";
    property <string> new-profile-agent-id: "";
    property <bool> new-profile-terminal-enabled: false;
    property <bool> new-profile-fs-enabled: false;
    // Armed-delete confirmation state -- see settings_sheet.slint's
    // original doc comment on `profile-pending-delete` for why this is a
    // two-step confirm rather than an immediate delete.
    property <string> profile-pending-delete: "";

    // Agents-grid-local search -- scoped to just this grid, separate from
    // the page-level `SettingsSearchBar` in `settings_page.slint` (which
    // filters nothing yet either, per that component's own doc comment --
    // Slint's `string` type has no `contains`/`index-of` builtin, so real
    // substring filtering needs a small Rust-side helper; wiring the query
    // itself now and leaving actual filtering for that later pass, same
    // posture the page-level bar already takes).
    property <string> agent-search-query: "";
    property <string> default-agent-id: "";

    background: transparent;

    SettingsSection {
        width: parent.width;

        SettingsSectionHeader { text: "Chat Defaults"; }

        SettingsField {
            width: parent.width;
            label: "Profile";
            Rectangle {
                height: 26px;
                background: Theme.bg-sidebar;
                border-width: 1px;
                border-color: Theme.border-default;
                border-radius: Theme.radius-sm;
                TextInput {
                    accessible-label: "Default profile";
                    accessible-action-default => { self.focus(); }
                    text <=> root.default-profile;
                    color: Theme.text-primary;
                    font-size: 12px * Theme.font-scale;
                    x: 6px;
                    width: parent.width - 12px;
                    vertical-alignment: center;
                }
            }
        }

        Flickable {
            height: root.available-profiles.length > 0 ? 30px : 0px;
            viewport-width: profile-chip-row.preferred-width;
            profile-chip-row := HorizontalLayout {
                spacing: Metrics.space-3;
                for profile in root.available-profiles : Rectangle {
                    height: 24px;
                    // Width computed purely from the leaf `Text.preferred-width`
                    // below -- never bind a repeated item's own width to a
                    // child layout's `preferred-width` when that child
                    // layout has no explicit width of its own (it would
                    // otherwise size to fill this same Rectangle): that is
                    // a real binding cycle. Slint doesn't error on it, it
                    // silently corrupts this whole window's later
                    // accessible-element geometry (see the original of
                    // this row, `components/settings_sheet.slint`, for the
                    // bisection that found this).
                    width: profile-chip-label.preferred-width + 16px
                        + 2px
                        + (root.profile-pending-delete == profile.name ? 114px : 20px);
                    HorizontalLayout {
                        spacing: 2px;
                        Rectangle {
                            width: profile-chip-label.preferred-width + 16px;
                            height: 24px;
                            background: profile.name == root.default-profile ? Theme.bg-primary : Theme.bg-sidebar;
                            border-color: Theme.border-default;
                            border-width: 1px;
                            border-radius: Theme.radius-sm;
                            TouchArea {
                                accessible-role: button;
                                accessible-label: "Select profile " + profile.name;
                                accessible-action-default => { root.default-profile = profile.name; }
                                clicked => { root.default-profile = profile.name; }
                            }
                            profile-chip-label := Text {
                                text: profile.name
                                    + (profile.terminal-enabled ? " T" : "")
                                    + (profile.fs-enabled ? " F" : "");
                                color: profile.name == root.default-profile ? Theme.text-on-primary : Theme.text-primary;
                                font-family: Theme.font-mono;
                                font-size: 10px * Theme.font-scale;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        if root.profile-pending-delete != profile.name : Button {
                            label: "\u{2715}";
                            button-accessible-label: "Remove profile " + profile.name;
                            btn-width: 20px;
                            btn-height: 24px;
                            font-size: 10px;
                            font-weight: 400;
                            clicked => { root.profile-pending-delete = profile.name; }
                        }
                        if root.profile-pending-delete == profile.name : HorizontalLayout {
                            spacing: 2px;
                            Button {
                                label: "Confirm";
                                button-accessible-label: "Confirm delete profile " + profile.name;
                                primary: true;
                                btn-width: 64px;
                                btn-height: 24px;
                                font-size: 9px;
                                font-weight: 400;
                                clicked => {
                                    root.profile-pending-delete = "";
                                    root.profile-delete(profile.name);
                                }
                            }
                            Button {
                                label: "Cancel";
                                button-accessible-label: "Cancel delete profile " + profile.name;
                                btn-width: 48px;
                                btn-height: 24px;
                                font-size: 9px;
                                font-weight: 400;
                                clicked => { root.profile-pending-delete = ""; }
                            }
                        }
                    }
                }
            }
        }

        SettingsDivider { width: parent.width; }

        // Add Profile -- commented out of view for now (kept in source, not
        // deleted, per request while the Agents view is being reworked into
        // a grid layout). Re-enable once the redesign settles on where
        // profile creation belongs in the new layout.
        /*
        Text { text: "Add Profile"; color: Theme.text-primary; font-size: 13px * Theme.font-scale; font-weight: 700; }
        HorizontalLayout {
            spacing: Metrics.space-3;
            Rectangle {
                horizontal-stretch: 1;
                height: 26px;
                background: Theme.bg-sidebar;
                border-width: 1px;
                border-color: Theme.border-default;
                border-radius: Theme.radius-sm;
                TextInput {
                    accessible-label: "New profile name";
                    accessible-action-default => { self.focus(); }
                    text <=> root.new-profile-name;
                    color: Theme.text-primary;
                    font-size: 11px * Theme.font-scale;
                    x: 6px;
                    vertical-alignment: center;
                }
            }
            Rectangle {
                horizontal-stretch: 1;
                height: 26px;
                background: Theme.bg-sidebar;
                border-width: 1px;
                border-color: Theme.border-default;
                border-radius: Theme.radius-sm;
                TextInput {
                    accessible-label: "New profile agent id";
                    accessible-action-default => { self.focus(); }
                    text <=> root.new-profile-agent-id;
                    color: Theme.text-primary;
                    font-size: 11px * Theme.font-scale;
                    x: 6px;
                    vertical-alignment: center;
                }
            }
            Button {
                label: "T";
                button-accessible-label: "Toggle new profile terminal access";
                btn-width: 28px;
                btn-height: 26px;
                font-size: 10px;
                font-weight: 400;
                bg: root.new-profile-terminal-enabled ? Theme.bg-primary : Theme.bg-sidebar;
                fg: root.new-profile-terminal-enabled ? Theme.text-on-primary : Theme.text-secondary;
                clicked => { root.new-profile-terminal-enabled = !root.new-profile-terminal-enabled; }
            }
            Button {
                label: "F";
                button-accessible-label: "Toggle new profile filesystem access";
                btn-width: 28px;
                btn-height: 26px;
                font-size: 10px;
                font-weight: 400;
                bg: root.new-profile-fs-enabled ? Theme.bg-primary : Theme.bg-sidebar;
                fg: root.new-profile-fs-enabled ? Theme.text-on-primary : Theme.text-secondary;
                clicked => { root.new-profile-fs-enabled = !root.new-profile-fs-enabled; }
            }
            Button {
                label: "Add";
                button-accessible-label: "Add profile";
                primary: true;
                btn-width: 56px;
                btn-height: 26px;
                font-size: 11px;
                font-weight: 400;
                clicked => {
                    if (root.new-profile-name != "") {
                        root.profile-create(
                            root.new-profile-name,
                            root.new-profile-agent-id,
                            root.new-profile-terminal-enabled,
                            root.new-profile-fs-enabled);
                        root.new-profile-name = "";
                        root.new-profile-agent-id = "";
                        root.new-profile-terminal-enabled = false;
                        root.new-profile-fs-enabled = false;
                    }
                }
            }
        }
        */

        SettingsField {
            width: parent.width;
            label: "Permission profile";
            Rectangle {
                height: 26px;
                background: Theme.bg-sidebar;
                border-width: 1px;
                border-color: Theme.border-default;
                border-radius: Theme.radius-sm;
                TextInput {
                    accessible-label: "Permission profile";
                    accessible-action-default => { self.focus(); }
                    text <=> root.permission-profile;
                    color: Theme.text-primary;
                    font-size: 12px * Theme.font-scale;
                    x: 6px;
                    width: parent.width - 12px;
                    vertical-alignment: center;
                }
            }
        }

        SettingsDivider { width: parent.width; }

        SettingsSectionHeader { text: "Agents"; subsection: true; }

        SettingsSearchBar {
            width: parent.width;
            query <=> root.agent-search-query;
        }

        // Wrapping grid of `AgentCard` tiles, per the settings-pane-redesign
        // plan's "Agents view is a grid, not a row list" section. Slint's
        // layout primitives have no flex-wrap (confirmed against the
        // "Slint layout defaults" reference), so a real `GridLayout` can't
        // do this (it's compile-time-fixed, no `for`/`if` inside it) --
        // but a manually-built `VerticalLayout` of `HorizontalLayout`s
        // (via `for row-idx in row-count`) is the idiomatic dynamic-grid
        // pattern, and lets the layout engine own the actual x/y
        // placement instead of hand-computed pixel math. An earlier
        // version of this grid used raw `x`/`y` arithmetic (`Math.mod(i,
        // 2) * 270px`, `(i / 2) * 240px`) and shipped a real bug from it:
        // Slint's `/` on two `int`s is float division, not truncating
        // (`1 / 2 == 0.5`, confirmed via a standalone debug grid after
        // "row 0.5" showed up), so row 1 rendered at half a row's height
        // instead of a full one. The layout-engine version below has no
        // such division at all in the positioning path -- only in slicing
        // the catalog into pairs of two, which is far lower-stakes than
        // getting it wrong in a pixel coordinate.
        //
        // CONNECTED-FIRST + SEPARATOR (`changes.yaml` task 3): connected
        // ("installed") agents render first, then a full-width separator
        // line, then the rest. True in-Slint reordering isn't possible --
        // Slint 1.17.1 has no array sort/filter, so the connected-first
        // *grouping* relies on the catalog already arriving connected-first
        // from the backend (`agents/list`) -- the dev preview data is
        // ordered that way to match. The separator is now a `SettingsDivider`
        // inserted as its own row, right before the first row whose
        // *first* (even-index) agent is not connected -- a row-granularity
        // adaptation of the old per-card boundary check (which could land
        // mid-row); if the actual transition falls on an odd index (col 1
        // of an otherwise-connected row), the divider now appears one row
        // later than it strictly would per-card, which reads better than a
        // divider slicing through a row anyway. Making the default agent
        // *physically jump* to the top on toggle (vs. the connected-status
        // grouping here) would need a real reorder primitive Slint doesn't
        // have and is deferred to a Rust-side ordering pass -- the default
        // card still reads as default via its own tint wherever it sits.
        //
        // Default-model/permission-profile per card are local, UI-only
        // placeholder state for now -- `AgentCatalogEntry` has no per-agent
        // model/profile fields yet (see the plan's "Open questions": no ACP
        // RPC returns a model list keyed by agent id today), and mapping
        // `available-profiles` (`[ProfileOption]`) into the `[string]`
        // `Select.options` each card needs isn't expressible in pure Slint
        // (no array-map primitive) without a small Rust-side helper --
        // deferred until the real per-agent settings storage exists.
        VerticalLayout {
            width: parent.width;
            spacing: Metrics.space-6;

            property <int> agent-count: root.agent-catalog.length;
            // Ceiling division for row count -- exact by construction
            // (subtract the remainder first), not the classic `(N+1)/2`
            // truncating-int trick, since `/` doesn't truncate here.
            property <int> row-count:
                ((agent-count + 1) - Math.mod(agent-count + 1, 2)) / 2;

            for row-idx in row-count : VerticalLayout {
                spacing: Metrics.space-6;

                if root.agent-catalog[row-idx * 2].status != "installed"
                    && (row-idx == 0 || root.agent-catalog[row-idx * 2 - 1].status == "installed")
                    : SettingsDivider { width: parent.width; }

                HorizontalLayout {
                    spacing: Metrics.space-6;
                    alignment: start;

                    AgentCard {
                        agent-id: root.agent-catalog[row-idx * 2].id;
                        agent-name: root.agent-catalog[row-idx * 2].name != ""
                            ? root.agent-catalog[row-idx * 2].name : root.agent-catalog[row-idx * 2].id;
                        status: root.agent-catalog[row-idx * 2].status;
                        is-default: root.agent-catalog[row-idx * 2].id == root.default-agent-id;
                        model-options: ["default", "gpt-5.2", "gpt-5.2-codex", "claude-sonnet-5", "claude-opus-4-8", "claude-haiku-4-5", "gemini-3-pro"];
                        profile-options: ["default", "readonly", "full-access"];
                        set-default(new-default) => {
                            root.default-agent-id = new-default ? root.agent-catalog[row-idx * 2].id : "";
                        }
                        install-requested => { root.agent-install-requested(root.agent-catalog[row-idx * 2].id); }
                        connect-requested => { root.agent-connect-requested(root.agent-catalog[row-idx * 2].id); }
                        disconnect-requested => { root.agent-disconnect-requested(root.agent-catalog[row-idx * 2].id); }
                    }

                    if row-idx * 2 + 1 < root.agent-catalog.length : AgentCard {
                        agent-id: root.agent-catalog[row-idx * 2 + 1].id;
                        agent-name: root.agent-catalog[row-idx * 2 + 1].name != ""
                            ? root.agent-catalog[row-idx * 2 + 1].name : root.agent-catalog[row-idx * 2 + 1].id;
                        status: root.agent-catalog[row-idx * 2 + 1].status;
                        is-default: root.agent-catalog[row-idx * 2 + 1].id == root.default-agent-id;
                        model-options: ["default", "gpt-5.2", "gpt-5.2-codex", "claude-sonnet-5", "claude-opus-4-8", "claude-haiku-4-5", "gemini-3-pro"];
                        profile-options: ["default", "readonly", "full-access"];
                        set-default(new-default) => {
                            root.default-agent-id = new-default ? root.agent-catalog[row-idx * 2 + 1].id : "";
                        }
                        install-requested => { root.agent-install-requested(root.agent-catalog[row-idx * 2 + 1].id); }
                        connect-requested => { root.agent-connect-requested(root.agent-catalog[row-idx * 2 + 1].id); }
                        disconnect-requested => { root.agent-disconnect-requested(root.agent-catalog[row-idx * 2 + 1].id); }
                    }
                }
            }
        }
    }
}
