import { SettingsRow } from "../../../base/settings_row.slint";
import { SettingsSection, SettingsSectionHeader, SettingsRowGroup } from "../../../base/settings_section.slint";
import { Toggle } from "../../../base/toggle.slint";

// Harness left-tab view -- phase 1 shell. Re-hosts the background-session
// toggles that were the only "Threads"-shaped state already in
// `components/settings_sheet.slint` (background-default + this chat's own
// override), unchanged. Per the settings-pane-redesign plan's resolved
// open question, the rest of `HarnessSettings` (notifications,
// notify-on-input-required, auto-resume-on-rate-limit-reset) is a later
// phase's UI-only addition -- this view intentionally does not add those
// yet, since phase 1 is shell-only (no new fields).
//
// Rows use the shared `SettingsRow` + `Toggle` primitives (self-review
// pass) -- these previously rendered as full-width hover-highlighted text
// blocks with no actual visual switch at all, the exact hand-rolled
// pattern `toggle.slint`'s own doc comment calls out as the reason it was
// extracted, so this view was the one place in the settings page not yet
// using it.
export component HarnessView inherits Rectangle {
    in-out property <bool> background-default: false;
    in-out property <bool> background-override-set: false;
    in-out property <bool> background-override: false;

    background: transparent;

    SettingsSection {
        width: parent.width;

        SettingsSectionHeader { text: "Harness"; }

        SettingsRowGroup {
            width: parent.width;
            SettingsRow {
                label: "Background sessions";
                hint: root.background-default ? "Enabled" : "Disabled";
                Toggle {
                    checked: root.background-default;
                    toggle-accessible-label: "Toggle background session default";
                    toggled(new-checked) => { root.background-default = new-checked; }
                }
            }

            SettingsRow {
                label: "This chat";
                hint: root.background-override-set
                    ? (root.background-override ? "Background" : "Foreground")
                    : "Use default";
                Toggle {
                    checked: root.background-override-set;
                    toggle-accessible-label: "Toggle background session override";
                    toggled(new-checked) => {
                        root.background-override-set = new-checked;
                        if (new-checked) {
                            root.background-override = root.background-default;
                        }
                    }
                }
            }

            if root.background-override-set : SettingsRow {
                row-height: 24px;
                label: root.background-override ? "Set this chat foreground" : "Set this chat background";
                Toggle {
                    checked: root.background-override;
                    toggle-accessible-label: "Toggle selected chat background session";
                    toggled(new-checked) => { root.background-override = new-checked; }
                }
            }
        }
    }
}
