import { Theme } from "../../tokens/theme.slint";
import { Metrics } from "../../tokens/metrics.slint";
import { Icon } from "../../base/icon.slint";
import { IconButton } from "../../base/icon_button.slint";
import { TextPillButton } from "../../base/text_pill_button.slint";
import { CursorHost } from "../../tokens/cursor_host.slint";
import { MarkdownView } from "../../base/markdown_view.slint";
import { MarkdownLine } from "../../types.slint";

// Skill editor -- `active_pane_and_editor_view` phase. Replaces
// `ChatArea` in the main content area (see `app.slint`'s `active-pane`
// switch) while a skill is selected in the sidebar's skill list.
//
// Design tokens (aligned with chat_area / DESIGN_SYSTEM):
//   Surface     Theme.bg-chat
//   Header      44px band, Metrics.space-6 H padding, space-3 gaps,
//               cross-axis-alignment: center (same shell as chat-view-top)
//   Title       Theme.text-primary, font-sans, 12px * font-scale
//   Secondary   Theme.text-secondary, 9px actions
//   Divider     Theme.border-default 1px
//   Editor body Theme.font-mono, Theme.text-primary, Metrics.pad-md insets
//
// Closing: X button fires close-requested; selecting a thread in the
// sidebar sets active-pane back to "chat" in app.slint (thread-selected).
export component SkillEditorView inherits Rectangle {
    in property <string> skill-name;
    in property <string> skill-path;
    in-out property <string> skill-content;
    // skills_audit_report §3.1
    in property <bool> skill-saving: false;
    in property <[string]> detected-editors: [];
    // Phase 27: markdown-rendered view of skill-content (host-computed,
    // same renderer as agent chat bodies) behind a Preview toggle.
    in property <[MarkdownLine]> preview-lines: [];
    in-out property <bool> show-preview: false;
    callback copy-path-requested();
    callback open-in-editor-requested(string /* editor display name */);
    callback open-with-os-default-requested();
    callback content-edited(string);
    callback close-requested();
    // See FilterSearchBar.input-has-focus's doc comment / TextField.has-focus's
    // own doc comment -- without this, app.slint's editable-surface
    // OR-chain has no way to know the skill content editor is focused, so
    // every keystroke typed while editing a skill would be silently
    // dropped before reaching Slint.
    out property <bool> has-focus: editor-input.has-focus;

    background: Theme.bg-chat;

    VerticalLayout {
        width: parent.width;
        height: parent.height;

        Rectangle {
            height: 44px;
            background: Theme.bg-chat;
            HorizontalLayout {
                width: 100%;
                height: 100%;
                padding-left: Metrics.space-6;
                padding-right: Metrics.space-6;
                spacing: Metrics.space-3;
                alignment: stretch;
                cross-axis-alignment: center;

                // Left: glyph + title (left-aligned), matches chat-view-top.
                HorizontalLayout {
                    spacing: Metrics.space-3;
                    horizontal-stretch: 1;
                    preferred-width: 0px;
                    min-width: 0px;
                    alignment: start;
                    cross-axis-alignment: center;
                    Rectangle {
                        width: 22px;
                        height: 22px;
                        horizontal-stretch: 0;
                        background: Theme.bg-primary-container;
                        border-color: Theme.border-default;
                        border-width: 1px;
                        border-radius: Theme.radius-sm;
                        VerticalLayout {
                            width: 100%;
                            height: 100%;
                            alignment: center;
                            HorizontalLayout {
                                alignment: center;
                                Icon {
                                    source: @image-url("../../assets/icons/book-open.svg");
                                    size: Metrics.icon-md;
                                    color: Theme.bg-primary;
                                }
                            }
                        }
                    }
                    Text {
                        text: root.skill-name;
                        color: Theme.text-primary;
                        font-size: 12px * Theme.font-scale;
                        font-weight: 600;
                        font-family: Theme.font-sans;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        horizontal-stretch: 1;
                        preferred-width: 0px;
                        min-width: 0px;
                        overflow: elide;
                    }
                }

                // Right: text actions + close (end-aligned).
                HorizontalLayout {
                    spacing: Metrics.space-2;
                    horizontal-stretch: 0;
                    alignment: end;
                    cross-axis-alignment: center;

                    if root.skill-saving : Text {
                        text: "Saving…";
                        color: Theme.text-muted;
                        font-size: 9px * Theme.font-scale;
                        font-family: Theme.font-mono;
                        vertical-alignment: center;
                        horizontal-stretch: 0;
                    }

                    // Variable-width text actions — token-colored pills
                    // (Button is fixed-width; long "Open in …" labels need flex).
                    TextPillButton {
                        label: root.show-preview ? "Edit" : "Preview";
                        button-accessible-label: root.show-preview
                            ? "Back to editing" : "Preview rendered markdown";
                        clicked => { root.show-preview = !root.show-preview; }
                    }
                    TextPillButton {
                        label: "Copy path";
                        button-accessible-label: "Copy skill path";
                        clicked => { root.copy-path-requested(); }
                    }
                    for editor-name in root.detected-editors : TextPillButton {
                        label: "Open in " + editor-name;
                        button-accessible-label: "Open in " + editor-name;
                        clicked => { root.open-in-editor-requested(editor-name); }
                    }
                    TextPillButton {
                        label: "Open";
                        button-accessible-label: "Open with OS default application";
                        clicked => { root.open-with-os-default-requested(); }
                    }
                    IconButton {
                        button-accessible-label: "Close skill editor";
                        clicked => { root.close-requested(); }
                        Icon {
                            source: @image-url("../../assets/icons/x.svg");
                            size: Metrics.icon-sm;
                            color: Theme.text-secondary;
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.border-default;
        }

        Rectangle {
            vertical-stretch: 1;
            preferred-height: 0px;
            min-height: 0px;
            // Preview overlay mounts on top; the editor Flickable stays
            // mounted (visible-toggled, not if-gated) because
            // `editor-input.has-focus` above must remain a valid id
            // reference in every state.
            if root.show-preview : Flickable {
                width: 100%;
                height: 100%;
                viewport-height: max(self.height, preview-md.preferred-height + 2 * Metrics.pad-md);
                preview-md := MarkdownView {
                    x: Metrics.pad-md;
                    y: Metrics.pad-sm;
                    width: parent.width - 2 * Metrics.pad-md;
                    lines: root.preview-lines;
                    fallback-text: root.skill-content;
                }
            }
            editor-flick := Flickable {
            width: 100%;
            height: 100%;
            visible: !root.show-preview;
            viewport-height: max(self.height, editor-input.preferred-height + 2 * Metrics.pad-md);
            editor-input := TextInput {
                x: Metrics.pad-md;
                y: Metrics.pad-sm;
                width: parent.width - 2 * Metrics.pad-md;
                // Explicit height -- without one, this multi-line
                // TextInput's focusable/clickable hit-region collapsed to
                // its own single-line preferred height at y:0, leaving
                // everything below the first line visually part of the
                // editor but not actually clickable/focusable (same bug
                // class as chat_input_layout.slint's compose TextInput
                // and ui/base/text_field.slint's shared component --
                // found by this session's own /verify-impl pass against
                // skill-manager-workspace/active_pane_and_editor_view's
                // "live edit of skill files" claim).
                height: max(self.preferred-height, parent.height);
                color: Theme.text-primary;
                font-family: Theme.font-mono;
                font-size: 11px * Theme.font-scale;
                wrap: word-wrap;
                single-line: false;
                text <=> root.skill-content;
                edited => { root.content-edited(self.text); }
                changed has-focus => { CursorHost.kind = self.has-focus ? "text" : "default"; }
            }
            }
        }
    }
}
