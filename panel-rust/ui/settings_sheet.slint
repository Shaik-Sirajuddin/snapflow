// Settings-gear sheet -- extracted out of app.slint's own former inline
// `Rectangle` block for modularity (component-style-system.md's rule:
// one Slint file per logical UI unit, `app.slint` should only ever
// compose components, not define their bodies). Covers default-config
// management (profile/permission-profile/background-session, Phase 1's
// pre-existing scope) plus the two Phase-1 rows that were still
// entirely unwired at the UI layer: centrally-registered MCP servers
// (`mcp_servers/*`) and the agent catalog (`agents/list|status|
// install`). All state here is real gateway state, round-tripped
// through `AgentBridge` -- nothing in this component optimistically
// mutates its own list properties; every create/update/delete/install
// callback is expected to be followed by `lib.rs` re-populating
// `available-mcp-servers`/`agent-catalog` from a fresh `list_*` call,
// same "don't trust a client-side echo" posture the mode/config
// selector already established.
import { Palette } from "palette.slint";
import { ProfileOption, McpServerOption, AgentCatalogEntry } from "types.slint";

export component SettingsSheet inherits Rectangle {
    in-out property <string> default-profile: "";
    in-out property <string> permission-profile: "";
    in-out property <bool> background-default: false;
    in property <[ProfileOption]> available-profiles: [];
    in property <[McpServerOption]> available-mcp-servers: [];
    in property <[AgentCatalogEntry]> agent-catalog: [];
    // Local-only draft fields for the "add MCP server" row -- never
    // sent anywhere until `mcp-server-create` fires; not part of any
    // persisted state.
    property <string> new-mcp-name: "";
    property <string> new-mcp-command: "";

    callback save();
    callback close();
    callback mcp-server-create(string, string);
    callback mcp-server-delete(string);
    callback agent-install-requested(string);

    background: Palette.sys-card;
    border-color: Palette.sys-border-strong;
    border-width: 1px;
    border-radius: Palette.radius-md;

    Flickable {
        width: parent.width;
        height: parent.height;
        viewport-height: body.preferred-height + 32px;
        body := VerticalLayout {
            width: parent.width;
            padding: 16px;
            spacing: 14px;

            Text { text: "Chat Defaults"; color: Palette.sys-text-primary; font-size: 16px; font-weight: 700; }

            Text { text: "Profile"; color: Palette.sys-text-secondary; font-size: 11px; }
            TextInput { text <=> root.default-profile; color: Palette.sys-text-primary; font-size: 12px; }
            // Profile-picker chips -- real `profiles/list` choices,
            // quick-select alternative to typing an exact name into the
            // TextInput above (both write the same `default-profile`
            // property, so either path works). `T`/`F` suffix badges
            // are `allow_terminal_access`/`allow_fs_access` -- see
            // `ProfileOption`'s doc comment.
            Flickable {
                height: available-profiles.length > 0 ? 30px : 0px;
                viewport-width: profile-chip-row.preferred-width;
                profile-chip-row := HorizontalLayout {
                    spacing: 6px;
                    for profile in available-profiles : Rectangle {
                        width: profile-chip-label.preferred-width + 16px;
                        height: 24px;
                        background: profile.name == root.default-profile ? Palette.sys-primary : Palette.sys-sidebar;
                        border-color: Palette.sys-border;
                        border-width: 1px;
                        border-radius: Palette.radius-sm;
                        TouchArea { clicked => { root.default-profile = profile.name; } }
                        profile-chip-label := Text {
                            text: profile.name
                                + (profile.terminal-enabled ? " T" : "")
                                + (profile.fs-enabled ? " F" : "");
                            color: profile.name == root.default-profile ? Palette.sys-on-primary : Palette.sys-text-primary;
                            font-family: Palette.font-mono;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Text { text: "Permission profile"; color: Palette.sys-text-secondary; font-size: 11px; }
            TextInput { text <=> root.permission-profile; color: Palette.sys-text-primary; font-size: 12px; }

            Rectangle {
                height: 28px;
                background: Palette.sys-sidebar;
                border-radius: Palette.radius-sm;
                TouchArea { clicked => { root.background-default = !root.background-default; } }
                Text {
                    text: root.background-default ? "Background sessions: enabled" : "Background sessions: disabled";
                    color: Palette.sys-text-primary; x: 8px; vertical-alignment: center; font-size: 11px;
                }
            }

            Rectangle { height: 1px; background: Palette.sys-border; }

            // MCP servers section -- centrally-registered `mcp_servers/*`
            // entries, merged additively into every session that uses a
            // profile naming them (see `acpx-core::mcp_servers::
            // merge_mcp_servers`'s doc comment). Real list, real create/
            // delete round trip -- no optimistic local mutation.
            Text { text: "MCP Servers"; color: Palette.sys-text-primary; font-size: 13px; font-weight: 700; }
            for server in available-mcp-servers : Rectangle {
                height: 26px;
                background: Palette.sys-sidebar;
                border-radius: Palette.radius-sm;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;
                    Text {
                        text: server.name;
                        color: Palette.sys-text-primary;
                        font-size: 11px;
                        font-family: Palette.font-mono;
                        vertical-alignment: center;
                        horizontal-stretch: 0;
                        overflow: elide;
                    }
                    Text {
                        text: server.command;
                        color: Palette.sys-text-secondary;
                        font-size: 10px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    Rectangle {
                        width: 44px; height: 20px;
                        background: Palette.sys-card;
                        border-color: Palette.sys-border;
                        border-width: 1px;
                        border-radius: Palette.radius-sm;
                        TouchArea { clicked => { root.mcp-server-delete(server.name); } }
                        Text { text: "Remove"; color: Palette.sys-text-secondary; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
            HorizontalLayout {
                spacing: 6px;
                Rectangle {
                    horizontal-stretch: 1;
                    height: 26px;
                    background: Palette.sys-sidebar;
                    border-radius: Palette.radius-sm;
                    new-mcp-name-input := TextInput {
                        text <=> root.new-mcp-name;
                        color: Palette.sys-text-primary;
                        font-size: 11px;
                        x: 6px;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    height: 26px;
                    background: Palette.sys-sidebar;
                    border-radius: Palette.radius-sm;
                    TextInput {
                        text <=> root.new-mcp-command;
                        color: Palette.sys-text-primary;
                        font-size: 11px;
                        x: 6px;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    width: 56px; height: 26px;
                    background: Palette.sys-primary;
                    border-radius: Palette.radius-sm;
                    TouchArea {
                        clicked => {
                            if (root.new-mcp-name != "") {
                                root.mcp-server-create(root.new-mcp-name, root.new-mcp-command);
                                root.new-mcp-name = "";
                                root.new-mcp-command = "";
                            }
                        }
                    }
                    Text { text: "Add"; color: Palette.sys-on-primary; horizontal-alignment: center; vertical-alignment: center; font-size: 11px; }
                }
            }

            Rectangle { height: 1px; background: Palette.sys-border; }

            // Agent catalog section -- `agents/list`'s real registry
            // entries with each entry's own live detection `status`
            // (`acpx_proto::AgentStatus`, plain monochrome text, no
            // color-coded badge per this project's design language).
            Text { text: "Agents"; color: Palette.sys-text-primary; font-size: 13px; font-weight: 700; }
            for agent in agent-catalog : Rectangle {
                height: 26px;
                background: Palette.sys-sidebar;
                border-radius: Palette.radius-sm;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;
                    Text {
                        text: agent.name != "" ? agent.name : agent.id;
                        color: Palette.sys-text-primary;
                        font-size: 11px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    Text {
                        text: agent.status;
                        color: Palette.sys-text-secondary;
                        font-size: 10px;
                        font-family: Palette.font-mono;
                        vertical-alignment: center;
                        horizontal-stretch: 0;
                    }
                    Rectangle {
                        width: 52px; height: 20px;
                        background: Palette.sys-card;
                        border-color: Palette.sys-border;
                        border-width: 1px;
                        border-radius: Palette.radius-sm;
                        TouchArea { clicked => { root.agent-install-requested(agent.id); } }
                        Text { text: "Install"; color: Palette.sys-text-secondary; font-size: 9px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }

            Rectangle { height: 6px; }
            HorizontalLayout {
                spacing: 8px;
                Rectangle {
                    width: 72px; height: 30px; background: Palette.sys-primary; border-radius: Palette.radius-sm;
                    TouchArea { clicked => { root.save(); } }
                    Text { text: "Save"; color: Palette.sys-on-primary; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 72px; height: 30px; background: Palette.sys-sidebar; border-radius: Palette.radius-sm;
                    TouchArea { clicked => { root.close(); } }
                    Text { text: "Close"; color: Palette.sys-text-primary; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }
}
