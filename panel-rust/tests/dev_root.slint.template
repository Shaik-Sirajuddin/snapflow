            sending: false,
            first-use: false,
        },
        {
            kind: "thinking",
            text: "Likely a race between the upload finishing and the test asserting on the resulting file -- checking the test harness's wait condition first.",
            markdown-lines: [],
            status: "",
            expanded: false,
            index: 1,
            raw-input: "",
            raw-output: "",
            queued: false,
            can-edit: false,
            sending: false,
            first-use: false,
        },
        {
            kind: "tool_use",
            text: "grep -rn \"wait_for_upload\" tests/",
            status: "COMPLETED",
            expanded: false,
            index: 2,
            raw-input: "{\"pattern\":\"wait_for_upload\",\"path\":\"tests/\"}",
            raw-output: "tests/support/upload_helpers.rs:42:pub fn wait_for_upload(...)\ntests/e2e/upload_flow.rs:18:    wait_for_upload(&client, id).await;",
            queued: false,
