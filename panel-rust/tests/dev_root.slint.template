            status: "error",
            busy: false,
            open: true,
            background: true,
            description: "Heap growth in the render worker after ~2h",
            closed: false,
            provider: "claude",
            model: "claude-haiku-4",
        },
        {
            name: "Docs: onboarding guide",
            status: "closed",
            busy: false,
            open: true,
            background: false,
            description: "Draft reviewed and merged",
            closed: true,
            provider: "",
            model: "",
