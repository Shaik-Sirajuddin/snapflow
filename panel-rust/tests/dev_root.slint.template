    // Allow once / Allow always / Reject options. Esc or pick dismisses.
    // (Real ACP permissions still arrive via host `pending-request`.)
    pending-request: {
        active: false,
        relay-id: "",
        method: "",
        title: "",
        summary: "",
        supported: false,
        options: [],
