        },
        {
            kind: "mcp_server_call",
            text: "mcp__claude-in-chrome__tabs_context_mcp",
            markdown-lines: [],
            status: "COMPLETED",
            expanded: true,
            index: 14,
            raw-input: "{}",
            raw-output: "{\"tabs\":[{\"id\":7,\"title\":\"GitHub PR #142\",\"active\":true}]}",
            queued: false,
            can-edit: false,
            sending: false,
            first-use: false,
        },
    ];

    // ----- floating size adjuster (dev-only chrome, bottom-right) -----
    size-bar := Rectangle {
        // Anchor to bottom-right; width/height change with open state so
        // recompute x/y from root each frame.
        x: root.width - self.width - 10px;
        y: root.height - self.height - 10px;
        z: 100000;
        width: size-bar-open ? min(760px, root.width - 20px) : 148px;
        height: size-bar-open ? 108px : 32px;
        background: #0f172a.with-alpha(0.94);
        border-radius: 10px;
        border-width: 1px;
        border-color: #334155;
        drop-shadow-blur: 12px;
        drop-shadow-color: #000000.with-alpha(0.45);
        drop-shadow-offset-y: 2px;

        VerticalBox {
            padding: 6px;
            spacing: 4px;

            HorizontalBox {
                spacing: 8px;
                alignment: start;

                Text {
                    text: size-bar-open
                        ? "Viewport  " + viewport-w + " × " + viewport-h
                        : viewport-w + "×" + viewport-h;
                    color: #e2e8f0;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Button {
                    text: size-bar-open ? "▾ hide" : "▸ size";
                    clicked => { size-bar-open = !size-bar-open; }
                }
            }

            if size-bar-open: VerticalBox {
                spacing: 4px;
                padding: 0;

                HorizontalBox {
                    spacing: 6px;
                    alignment: center;

                    Text { text: "W"; color: #94a3b8; font-size: 11px; vertical-alignment: center; horizontal-stretch: 0; }
                    SpinBox {
                        minimum: 320;
                        maximum: 3840;
                        step-size: 10;
                        value <=> viewport-w;
                        horizontal-stretch: 0;
                        width: 110px;
                        edited(v) => { apply-size(v, viewport-h); }
                    }
                    Slider {
                        minimum: 320;
                        maximum: 1920;
                        step: 10;
                        value <=> viewport-w-f;
                        horizontal-stretch: 1;
                        min-width: 80px;
                        changed(v) => { apply-size(round(v), viewport-h); }
                    }
                    Button { text: "−50"; clicked => { bump-w(-50); } }
                    Button { text: "+50"; clicked => { bump-w(50); } }
                }

                HorizontalBox {
                    spacing: 6px;
                    alignment: center;

                    Text { text: "H"; color: #94a3b8; font-size: 11px; vertical-alignment: center; horizontal-stretch: 0; }
                    SpinBox {
                        minimum: 240;
                        maximum: 2400;
                        step-size: 10;
                        value <=> viewport-h;
                        horizontal-stretch: 0;
                        width: 110px;
                        edited(v) => { apply-size(viewport-w, v); }
                    }
                    Slider {
                        minimum: 240;
                        maximum: 1200;
                        step: 10;
                        value <=> viewport-h-f;
                        horizontal-stretch: 1;
                        min-width: 80px;
                        changed(v) => { apply-size(viewport-w, round(v)); }
                    }
                    Button { text: "−50"; clicked => { bump-h(-50); } }
                    Button { text: "+50"; clicked => { bump-h(50); } }
                }

                HorizontalBox {
                    spacing: 4px;
                    alignment: start;
                    Text { text: "Presets"; color: #64748b; font-size: 10px; vertical-alignment: center; }
                    Button { text: "390×844"; clicked => { apply-size(390, 844); } }
                    Button { text: "768×1024"; clicked => { apply-size(768, 1024); } }
                    Button { text: "1280×800"; clicked => { apply-size(1280, 800); } }
                    Button { text: "1600×1000"; clicked => { apply-size(1600, 1000); } }
                    Button { text: "1920×1200"; clicked => { apply-size(1920, 1200); } }
                }
            }
        }
    }

    // Drag grip just outside the size chip (bottom-right corner).
    resize-grip := TouchArea {
        z: 100001;
        width: 22px;
        height: 22px;
        x: root.width - self.width - 4px;
        y: root.height - self.height - 4px;
        // Sit on the outer corner; size-bar is inset 10px so they don't fully overlap.
        mouse-cursor: nwse-resize;

        property <int> grab-w: 0;
        property <int> grab-h: 0;
        property <length> grab-mx: 0px;
        property <length> grab-my: 0px;

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                grab-w = viewport-w;
                grab-h = viewport-h;
                grab-mx = self.mouse-x;
                grab-my = self.mouse-y;
            }
        }
        moved => {
            if (self.pressed) {
                apply-size(
                    grab-w + round((self.mouse-x - grab-mx) / 1px),
                    grab-h + round((self.mouse-y - grab-my) / 1px)
                );
            }
        }

        Rectangle {
            background: #38bdf8.with-alpha(parent.has-hover || parent.pressed ? 0.95 : 0.7);
            border-radius: 4px;
            Text {
                text: "⤡";
                color: #0f172a;
                font-size: 12px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
