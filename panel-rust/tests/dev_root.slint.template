    // Slash catalog includes the demo trigger so `/demo` filters to it.
    available-skills: [
        { name: "demo-permission", description: "Open the local approval one-of card (type /demo-permission + Enter)", scope: "global", path: "/skills/demo-permission", started-from: "" },
