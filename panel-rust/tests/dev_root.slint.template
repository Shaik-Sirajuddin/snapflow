// Dev-only viewer wrapper -- NOT part of production ui/ sources.
// Wraps the real ChatPanel with a floating size adjuster so you can
// live-resize the panel over VNC/slint-viewer without restarting.
// Imports the real app.slint unmodified, so --auto-reload still
// picks up edits to any production .slint file.
//
// Mock chat data below is set as plain property-override bindings
// (not --load-data JSON) -- --load-data only reflects properties
// declared directly on the loaded component, not ones inherited
// from ChatPanel. Overriding via normal inheritance works.
import { Button, SpinBox, Slider, HorizontalBox, VerticalBox } from "std-widgets.slint";
import { ChatPanel } from "__CHATPANEL_SLINT__";

export component DevRoot inherits ChatPanel {
    // Live OS-window size driven by the floating adjuster bar / corner grip.
    // Prefer binding width/height (not only preferred-*) so SpinBox/Slider
    // changes take effect immediately instead of acting as a first-show hint.
    in-out property <int> viewport-w: 1280;
    in-out property <int> viewport-h: 800;
    in-out property <bool> size-bar-open: false;
    // Keep float mirrors so Slider (float) stays in sync with SpinBox (int).
    property <float> viewport-w-f: 1280;
    property <float> viewport-h-f: 800;

    // Binding width/height is mutually exclusive with min-width/min-height
    // on Window; clamp in apply-size instead.
    width: viewport-w * 1px;
    height: viewport-h * 1px;
    preferred-width: viewport-w * 1px;
    preferred-height: viewport-h * 1px;

    pure function clamp-w(v: int) -> int {
        return max(320, min(3840, v));
    }
    pure function clamp-h(v: int) -> int {
        return max(240, min(2400, v));
    }
    function apply-size(w: int, h: int) {
        viewport-w = clamp-w(w);
        viewport-h = clamp-h(h);
        viewport-w-f = viewport-w;
        viewport-h-f = viewport-h;
    }
    function bump-w(delta: int) {
        apply-size(viewport-w + delta, viewport-h);
    }
    function bump-h(delta: int) {
        apply-size(viewport-w, viewport-h + delta);
    }

    selected-thread: 0;
    connection-status: "Connected";
    compact: false;
    sidebar-expanded: true;
    narrow: false;
    settings-open: true;
    settings-active-section: "agents";
    // agent-badge is derived in ChatPanel from the selected thread's
    // provider/model (default_variables_display phase) — not a root prop.
    has-older-messages: true;
    loading-older-messages: false;

    // Settings / permission profile mocks so the sheet has chips to click.
    default-profile: "default";
    permission-profile: "default";
    available-profiles: [
        { name: "default", agent-id: "codex", terminal-enabled: true, fs-enabled: true },
        { name: "read-only", agent-id: "codex", terminal-enabled: false, fs-enabled: false },
        { name: "full-access", agent-id: "claude", terminal-enabled: true, fs-enabled: true },
    ];

    // Session context ring (ui.yaml chat-view-input).
    context-ratio: 0.42;
    context-used-tokens: 42000;
    context-limit-tokens: 100000;

    // Compose `/` skills · `@` mcp · `#` files popup catalogs.
    // (skills list set below with demo-permission trigger included)
    available-mcp-servers: [
        { name: "snapshot", command: "snapshotd", transport: "stdio", url: "", enabled: true, status: "connected", needs-auth: false, auth-status: "", tools: [] },
        { name: "chrome", command: "mcp-chrome", transport: "stdio", url: "", enabled: true, status: "connected", needs-auth: false, auth-status: "", tools: [] },
        { name: "github", command: "", transport: "http", url: "https://api.github.com/mcp", enabled: true, status: "idle", needs-auth: true, auth-status: "required", tools: [] },
    ];
    // Connected entries come first so the Agents view shows its installed
    // row before the not-found row and separator.
