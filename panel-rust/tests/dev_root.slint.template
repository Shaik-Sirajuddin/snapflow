        { id: "claude-code", name: "Claude Code", version: "1.0.34", status: "installed" },
        { id: "gemini-cli", name: "Gemini CLI", version: "0.18.2", status: "installed_no_session" },
        { id: "amp", name: "Amp", version: "", status: "runtime_missing" },
    ];
    file-options: [
        "panel-rust/ui/app.slint",
        "panel-rust/ui/chat_area.slint",
        "panel-rust/ui/components/sidebar.slint",
        "memory/acpx/tasks/ui.yaml",
    ];

    // Compose bar row 2 -- mode + model selectors. Shape matches what the
    // host builds via models::to_mode_dropdown_entries /
